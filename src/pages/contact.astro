---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import { team } from '../data/team';
---

<BaseLayout title="Contact | Levenhall" description="Schedule a confidential consultation with Levenhall — market intelligence, US federal market entry, ventures, and proprietary products.">

    <PageHeader
        label="Get in Touch"
        title="Contact"
    />

    <!-- ── CONSULTATION + DIRECT CONTACT (INK) ── -->
    <section class="section contact-section">
        <div class="container">
            <div class="contact-grid">
                <!-- LEFT: Primary CTA -->
                <div class="contact-primary">
                    <span class="section-label">Consultation</span>
                    <h2>Schedule a Consultation</h2>
                    <p>Initial consultations are confidential and without obligation. We will discuss your market, the intelligence questions you are trying to answer, and whether Levenhall is the right partner &mdash; whether your interest is intelligence, US federal market entry, a venture engagement, or one of our products.</p>
                    <a href="https://calendly.com/hgad-levenhall/30min" class="btn btn-primary contact-book" target="_blank" rel="noopener noreferrer">Book a Time</a>
                </div>

                <!-- RIGHT: Direct Contact — ink panel, hairline ledger -->
                <div class="contact-direct">
                    <div class="contact-panel-head">
                        <span>Direct Contact</span>
                        <span>Levenhall / DC</span>
                    </div>
                    <div class="contact-list">
                        {team.map(member => (
                            <div class="contact-person">
                                <span class="contact-name">{member.name}</span>
                                <span class="contact-role">{member.title}</span>
                                <div class="contact-links">
                                    <a href={`mailto:${member.email}`} class="contact-email">{member.email}</a>
                                    {member.phone && <a href={`tel:${member.phone.replace(/[\s()-]/g, '')}`} class="contact-phone">{member.phone}</a>}
                                </div>
                            </div>
                        ))}
                    </div>

                    <div class="contact-location">
                        <h4>Location</h4>
                        <p>Washington, DC Metropolitan Area</p>
                    </div>

                    <div class="contact-credentials">
                        <h4>Federal Identifiers</h4>
                        <dl>
                            <div class="cred-row">
                                <dt>UEI</dt>
                                <dd>Z4N8GQNVG826</dd>
                            </div>
                            <div class="cred-row">
                                <dt>CAGE</dt>
                                <dd>20CN1</dd>
                            </div>
                        </dl>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ── WHAT TO EXPECT (PANEL) ── -->
    <section class="section section-panel expect-section">
        <div class="container">
            <div class="section-header">
                <span class="section-label">What to Expect</span>
                <h2>The Initial Conversation</h2>
            </div>
            <div class="expect-grid">
                <div class="expect-item">
                    <span class="expect-num">01</span>
                    <h4>Confidential</h4>
                    <p>Every conversation with Levenhall is held in strict confidence. We discuss sensitive technology, competitive positioning, intelligence requirements, and strategic plans, and treat that information accordingly.</p>
                </div>
                <div class="expect-item">
                    <span class="expect-num">02</span>
                    <h4>Direct</h4>
                    <p>We will tell you honestly whether the market you are targeting is right for your firm at this stage, which pathways are realistic, and what timeline to expect. No inflated projections or vague promises.</p>
                </div>
                <div class="expect-item">
                    <span class="expect-num">03</span>
                    <h4>Selective</h4>
                    <p>Not every inquiry results in an engagement. We take on a limited number of clients in each technology domain to ensure our intelligence work and institutional knowledge serve each one without dilution.</p>
                </div>
            </div>
        </div>
    </section>

</BaseLayout>

<style>
    /* ── CONSULTATION (INK) ── */
    .contact-section { background: var(--ink); }

    .contact-grid {
        display: grid;
        grid-template-columns: minmax(0, 55fr) minmax(0, 45fr);
        gap: 4.5rem;
        align-items: start;
    }

    .contact-primary h2 {
        font-size: clamp(1.7rem, 3vw, 2.4rem);
        margin-bottom: 1.2rem;
    }

    .contact-primary p {
        font-size: 1.02rem;
        line-height: 1.75;
        max-width: 56ch;
    }

    .contact-book {
        margin-top: 2.2rem;
    }

    /* Direct contact — ink panel, hairline borders, square corners */
    .contact-direct {
        background: var(--ink-panel);
        border: 1px solid var(--hairline);
        padding: 1.8rem 2rem 2rem;
    }

    .contact-panel-head {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        font-family: var(--mono);
        font-size: 0.6rem;
        font-weight: 500;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--dim);
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--hairline);
    }
    .contact-panel-head span:first-child { color: var(--gold); }

    .contact-list {
        display: flex;
        flex-direction: column;
    }

    .contact-person {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
        padding: 1.2rem 0;
        border-bottom: 1px solid var(--hairline);
    }

    .contact-name {
        font-weight: 600;
        font-size: 0.98rem;
        color: var(--bone);
    }

    .contact-role {
        font-family: var(--mono);
        font-size: 0.6rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--dim);
        margin-bottom: 0.3rem;
    }

    .contact-links {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .contact-email,
    .contact-phone {
        font-family: var(--mono);
        font-size: 0.72rem;
        letter-spacing: 0.04em;
        color: var(--muted);
        text-decoration: none;
        transition: color var(--t-short);
    }

    .contact-email:hover,
    .contact-phone:hover {
        color: var(--gold);
    }

    .contact-location {
        padding-top: 1.4rem;
    }

    .contact-location h4 { margin-bottom: 0.4rem; color: var(--dim); }

    .contact-location p {
        font-size: 0.9rem;
        color: var(--muted);
    }

    .contact-credentials {
        padding-top: 1.4rem;
        margin-top: 1.4rem;
        border-top: 1px solid var(--hairline);
    }

    .contact-credentials h4 { margin-bottom: 0.8rem; color: var(--dim); }

    .contact-credentials dl {
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
    }

    .contact-credentials .cred-row {
        display: flex;
        align-items: baseline;
        gap: 1rem;
    }

    .contact-credentials dt {
        font-family: var(--mono);
        font-size: 0.6rem;
        font-weight: 500;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--gold);
        min-width: 3.2rem;
    }

    .contact-credentials dd {
        margin: 0;
        font-family: var(--mono);
        font-size: 0.78rem;
        letter-spacing: 0.06em;
        color: var(--muted);
        font-variant-numeric: tabular-nums;
    }

    /* ── EXPECT (PANEL) ── */
    .expect-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        border: 1px solid var(--hairline);
    }

    .expect-item {
        padding: 2rem 1.8rem 2.2rem;
        border-right: 1px solid var(--hairline);
        background: var(--ink);
        transition: background var(--t-short);
    }
    .expect-item:last-child { border-right: none; }
    .expect-item:hover { background: var(--ink-panel); }

    .expect-num {
        display: block;
        font-family: var(--mono);
        font-size: 0.62rem;
        font-weight: 500;
        letter-spacing: 0.18em;
        color: var(--gold);
        margin-bottom: 1rem;
    }

    .expect-item h4 {
        color: var(--bone);
        margin-bottom: 0.7rem;
    }

    .expect-item p {
        font-size: 0.9rem;
        line-height: 1.65;
        color: var(--muted);
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 992px) {
        .contact-grid { grid-template-columns: 1fr; gap: 3rem; }
    }

    @media (max-width: 768px) {
        .expect-grid { grid-template-columns: 1fr; }
        .expect-item { border-right: none; border-bottom: 1px solid var(--hairline); }
        .expect-item:last-child { border-bottom: none; }
        .contact-direct { padding: 1.5rem 1.4rem 1.6rem; }
    }
</style>
