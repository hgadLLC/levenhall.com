---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';
import TeamCard from '../components/TeamCard.astro';
import BioModal from '../components/BioModal.astro';
import NishankBioModal from '../components/NishankBioModal.astro';
import HassanBioModal from '../components/HassanBioModal.astro';
import AzimuthalMap from '../components/AzimuthalMap.astro';
import CoverageGlobe from '../components/CoverageGlobe.astro';
import { team } from '../data/team';
import { services } from '../data/services';
import { nations } from '../data/nations';

const romans = ['I', 'II', 'III', 'IV', 'V'];
---

<BaseLayout title="Levenhall | Market Intelligence Consulting" description="Levenhall is a market intelligence consulting firm serving defense, government, and dual-use markets. Intelligence, market entry, ventures, and proprietary products.">

    <!-- ── HERO: POSTER + INSTRUMENT ── -->
    <section class="hero sweep-field texture-grain">
        <div class="rail" aria-hidden="true">
            <span class="idx"><b>01</b> / Advisory</span>
            <span class="idx"><b>02</b> / Market Entry</span>
            <span class="idx"><b>03</b> / Ventures</span>
            <span class="idx"><b>04</b> / Systems</span>
        </div>

        <div class="hero-grid">
            <div class="hero-statement">
                <div>
                    <img src="/images/five-eyes-star.png" alt="Levenhall — five allied nations" class="hero-emblem">
                    <span class="route-line hero-route">Market Intelligence · Allied Defense &amp; Dual-Use · <span class="live">● Washington, DC</span></span>
                    <h1>They see what others can&rsquo;t.</h1>
                    <p class="hero-tagline editorial-italic">Structure, not access.</p>
                    <p class="hero-subtitle">Levenhall is a market intelligence consulting firm. We help allied companies, investors, and government partners navigate the markets where information asymmetry decides outcomes &mdash; defense procurement, regulated dual-use technology, and the geopolitical environment shaping both.</p>
                </div>
                <div class="btn-group hero-cta">
                    <a href="https://calendly.com/hgad-levenhall/30min" class="btn btn-primary" target="_blank" rel="noopener noreferrer">Request a Briefing</a>
                    <a href="/services" class="mono-link">The Practice →</a>
                </div>
            </div>

            <div class="hero-instrument" id="lensField">
                <div class="feed-head">
                    <span>Procurement Signal / Bridger Index</span>
                    <span class="feed-utc" id="etClock">--:--:-- ET</span>
                </div>
                <div class="feed" id="feed">
                    <div class="feed-layer feed-dim" aria-hidden="true">
                        <div class="sig"><span class="t">09:31 ET</span><span class="b">AFRL · <span class="redact">██████████</span> · CSO PRE-RFP</span><span class="v">$<span class="redact">███</span>M</span></div>
                        <div class="sig"><span class="t">09:12 ET</span><span class="b">DIU · AUTONOMY <span class="redact">████████</span> OTA</span><span class="v">$<span class="redact">██</span>M</span></div>
                        <div class="sig"><span class="t">08:58 ET</span><span class="b">NAVSEA · <span class="redact">████████████</span> P-2028</span><span class="v">$<span class="redact">███</span>M</span></div>
                        <div class="sig"><span class="t">08:41 ET</span><span class="b">DARPA · <span class="redact">██████</span> PHASE III</span><span class="v">$<span class="redact">██</span>M</span></div>
                        <div class="sig"><span class="t">08:22 ET</span><span class="b">USSOCOM · <span class="redact">███████████</span> FOLLOW-ON</span><span class="v">$<span class="redact">███</span>M</span></div>
                        <div class="sig"><span class="t">08:05 ET</span><span class="b">SDA · TRANCHE <span class="redact">██</span> TRANSPORT</span><span class="v">$<span class="redact">███</span>M</span></div>
                    </div>
                    <div class="feed-layer feed-resolved" id="lensResolved">
                        <div class="sig"><span class="t">09:31 ET</span><span class="b">AFRL · HYPERSONIC TPS · CSO PRE-RFP</span><span class="v">$140M</span></div>
                        <div class="sig"><span class="t">09:12 ET</span><span class="b">DIU · AUTONOMY MARITIME OTA</span><span class="v">$62M</span></div>
                        <div class="sig"><span class="t">08:58 ET</span><span class="b">NAVSEA · UNDERSEA SENSING P-2028</span><span class="v">$310M</span></div>
                        <div class="sig"><span class="t">08:41 ET</span><span class="b">DARPA · ACE-II PHASE III</span><span class="v">$48M</span></div>
                        <div class="sig"><span class="t">08:22 ET</span><span class="b">USSOCOM · ISR-EDGE FOLLOW-ON</span><span class="v">$215M</span></div>
                        <div class="sig"><span class="t">08:05 ET</span><span class="b">SDA · TRANCHE 4 TRANSPORT</span><span class="v">$480M</span></div>
                    </div>
                    <div class="lens-ring" id="lensRing" aria-hidden="true"></div>
                </div>
                <div class="feed-foot">
                    <span class="lens-hint" id="lensHint">Move cursor to resolve · client access decrypts in full</span>
                    <span class="feed-note">Representative signal</span>
                </div>
            </div>
        </div>

        <!-- Evidence bar — replaces the floating stat cards -->
        <div class="data-bar">
            <div class="datum"><span class="d-val">$1.5T+</span><span class="d-cap">US Defense Budget</span></div>
            <div class="datum"><span class="d-val">60–120</span><span class="d-cap">Days to Award · CSO/OTA</span></div>
            <div class="datum"><span class="d-val">$18B+</span><span class="d-cap">OTA Obligations Tracked</span></div>
            <div class="datum"><span class="d-val gold">100%</span><span class="d-cap">Engagement Success Rate</span></div>
        </div>
    </section>

    <!-- ── PRACTICE STRIP ── -->
    <section class="practice-strip">
        <a href="/services#market-intelligence" class="practice-cell">
            <span class="p-num">I.</span>
            <h3>Market Intelligence</h3>
            <p>The core practice. Assessed, sourced intelligence on defense procurement, allied policy, and regulated markets.</p>
            <span class="p-arrow">→</span>
        </a>
        <a href="/services#advisory" class="practice-cell">
            <span class="p-num">II.</span>
            <h3>US Federal Market Entry</h3>
            <p>Advisory for allied-nation technology firms entering the US &mdash; CSOs, OTAs, follow-on production. Months, not years.</p>
            <span class="p-arrow">→</span>
        </a>
        <a href="/ventures" class="practice-cell">
            <span class="p-num">III.</span>
            <h3>Ventures &amp; Systems</h3>
            <p>Services-for-equity in five allied companies a year. Bridger, AIGIS, and Intelligence &mdash; proof the practice works.</p>
            <span class="p-arrow">→</span>
        </a>
    </section>

    <!-- ── ALLIED COVERAGE (PAPER) ── -->
    <section class="section section-paper allied-section">
        <div class="container">
            <div class="allied-grid">
                <div class="allied-text">
                    <span class="section-label">02 / Who We Serve</span>
                    <h2>Intelligence-led.<br/>Allied-aligned.</h2>
                    <p class="allied-lede">Levenhall serves allied defense, government technology, and dual-use firms, along with the investors and program offices that work alongside them. Our intelligence practice is the foundation; our market entry, ventures, and product work all run on top of it.</p>
                    <p>For firms targeting the US federal market, CSOs, OTAs, and follow-on production agreements have created a faster procurement ecosystem. We architect that entry, reducing timelines from years to months &mdash; intelligence first, execution second.</p>
                    <a href="/partners" class="mono-link allied-link">Our Partners →</a>
                </div>
                <div class="allied-chart">
                    <div class="chart-head">
                        <span>Coverage / Live Globe · Drag to Rotate</span>
                    </div>
                    <CoverageGlobe />
                    <noscript>
                        <div class="az-wrap">
                            <AzimuthalMap />
                        </div>
                    </noscript>
                    <div class="nations-ledger">
                        {nations.map(nation => (
                            <div class="nation-row">
                                <span class="nation-flag">{nation.flag}</span>
                                <span class="nation-name">{nation.name}</span>
                                <span class="nation-tag">{nation.tagline}</span>
                            </div>
                        ))}
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ── PRACTICE LEDGER (INK) ── -->
    <section class="section services-section">
        <div class="container">
            <div class="section-header">
                <span class="section-label">01 / The Practice</span>
                <h2>What we do.</h2>
                <p>Market intelligence is the core. Everything else &mdash; federal market entry, executive placement, rapid procurement, tax structuring &mdash; runs on top of it.</p>
            </div>
            <div class="services-ledger">
                {services.map((service, i) => (
                    <a href={`/services#${service.id}`} class="service-row">
                        <span class="sr-num">{romans[i]}.</span>
                        <span class="sr-label">{service.label}</span>
                        <span class="sr-body">
                            <h3>{service.title}</h3>
                            <p>{service.summary}</p>
                        </span>
                        <span class="sr-metric">
                            <span class="sr-val">{service.highlight.value}</span>
                            <span class="sr-cap">{service.highlight.label}</span>
                        </span>
                        <span class="sr-arrow">→</span>
                    </a>
                ))}
            </div>
        </div>
    </section>

    <!-- ── SYSTEMS (PANEL) ── -->
    <section class="section section-panel systems-section">
        <div class="container">
            <div class="section-header">
                <span class="section-label">04 / Systems</span>
                <h2>The proprietary layer.</h2>
                <p>The technology built on the intelligence practice &mdash; and the investment arm that runs alongside it.</p>
            </div>
            <div class="systems-grid">
                <a href="/products/bridger" class="system-cell">
                    <svg class="sys-instrument" viewBox="0 0 220 64" aria-hidden="true">
                        <g class="ins-frame">
                            <line x1="0" y1="63.5" x2="220" y2="63.5"/>
                            {Array.from({ length: 12 }, (_, i) => <line x1={i * 20} y1="60" x2={i * 20} y2="64"/>)}
                        </g>
                        <path class="ins-area" d="M0 52 L18 48 L36 50 L54 41 L72 44 L90 34 L108 37 L126 27 L144 30 L162 20 L180 24 L198 12 L216 15 L216 63 L0 63 Z"/>
                        <path class="ins-line" d="M0 52 L18 48 L36 50 L54 41 L72 44 L90 34 L108 37 L126 27 L144 30 L162 20 L180 24 L198 12 L216 15"/>
                        <circle class="ins-dot" cx="216" cy="15" r="2.5"/>
                        <text class="ins-note" x="0" y="10">$760B/YR INDEXED</text>
                    </svg>
                    <span class="sys-tag">Platform</span>
                    <span class="sys-brand"><img src="/images/products/bridger-mark.png" alt="" class="sys-mark" loading="lazy"><h3>Bridger</h3></span>
                    <p>Market entry intelligence for US federal contracting. $760B/yr indexed, pre-RFP signal, opportunity scoring, and a six-officer agentic staff running the watch cycle.</p>
                    <span class="sys-link">Explore Bridger →</span>
                </a>
                <a href="/products/aigis" class="system-cell">
                    <svg class="sys-instrument" viewBox="0 0 220 64" aria-hidden="true">
                        <g class="ins-matrix">
                            {Array.from({ length: 3 }, (_, r) =>
                                Array.from({ length: 11 }, (_, c) => {
                                    const covered = [0,1,2,3,4,5,7,8,11,12,13,14,16,18,22,23,24,26,28,30].includes(r * 11 + c);
                                    return <rect x={c * 20 + 1} y={r * 20 + 1} width="14" height="14" class={covered ? 'ins-cell-on' : 'ins-cell'}/>;
                                })
                            )}
                        </g>
                    </svg>
                    <span class="sys-tag">Platform</span>
                    <span class="sys-brand"><img src="/images/products/aigis-lockup.png" alt="AIGIS" class="sys-mark sys-mark-wide" loading="lazy"></span>
                    <p>The system of record for AI governance. Inventory, map, test, and prove &mdash; audit-ready evidence across the EU AI Act, NIST AI RMF, and every framework in between.</p>
                    <span class="sys-link">Explore AIGIS →</span>
                </a>
                <a href="/products/intelligence" class="system-cell">
                    <svg class="sys-instrument" viewBox="0 0 220 64" aria-hidden="true">
                        <g class="ins-frame">
                            <circle cx="110" cy="58" r="14"/>
                            <circle cx="110" cy="58" r="30"/>
                            <circle cx="110" cy="58" r="46"/>
                            <line x1="110" y1="58" x2="110" y2="8"/>
                            <line x1="60" y1="58" x2="160" y2="58"/>
                        </g>
                        <g class="ins-sweep-g">
                            <path class="ins-sweep" d="M110 58 L110 8 A50 50 0 0 1 145 22 Z"/>
                        </g>
                        <circle class="ins-dot" cx="88" cy="34" r="2"/>
                        <circle class="ins-dot ins-dot-2" cx="132" cy="44" r="2"/>
                    </svg>
                    <span class="sys-tag">Dashboard</span>
                    <span class="sys-brand"><img src="/images/products/intelligence-mark.png" alt="" class="sys-mark" loading="lazy"><h3>Intelligence</h3></span>
                    <p>Defense &amp; alliance advisory dashboard. Live procurement, alliance dynamics, Indo-Pacific strategy, and government contracting intel.</p>
                    <span class="sys-link">Explore Intelligence →</span>
                </a>
                <a href="/ventures" class="system-cell">
                    <svg class="sys-instrument" viewBox="0 0 220 64" aria-hidden="true">
                        {[46, 30, 38, 18, 26].map((h, i) => (
                            <g>
                                <rect class="ins-bar" x={i * 44 + 2} y={62 - h} width="30" height={h}/>
                                <rect class="ins-bar-cap" x={i * 44 + 2} y={62 - h} width="30" height="2"/>
                            </g>
                        ))}
                        <line class="ins-baseline" x1="0" y1="63" x2="220" y2="63"/>
                        <text class="ins-note" x="0" y="8">5 / YR · SERVICES-FOR-EQUITY</text>
                    </svg>
                    <span class="sys-tag">Ventures</span>
                    <h3>Levenhall Ventures</h3>
                    <p>Our investment arm. Services-for-equity partnerships with five allied defense and government technology companies per year.</p>
                    <span class="sys-link">Explore Ventures →</span>
                </a>
            </div>
        </div>
    </section>

    <!-- ── TEAM (STONE) ── -->
    <section class="section section-stone team-section">
        <div class="container">
            <div class="section-header">
                <span class="section-label">03 / Leadership</span>
                <h2>Meet the team.</h2>
                <p>Former intelligence, military, diplomatic, and government professionals who understand the markets we cover from inside.</p>
            </div>
            <div class="team-grid">
                {team.map(member => (
                    <TeamCard
                        name={member.name}
                        title={member.title}
                        photo={member.photo}
                        linkedin={member.linkedin}
                        isModalTrigger={member.isModalTrigger}
                    />
                ))}
            </div>
        </div>
    </section>

    <CTASection />
    <BioModal />
    <NishankBioModal />
    <HassanBioModal />

</BaseLayout>

<script>
    // Eastern-time clock (platform timing is ET per user directive)
    const clock = document.getElementById('etClock');
    const etFmt = new Intl.DateTimeFormat('en-US', {
        timeZone: 'America/New_York',
        hour12: false, hour: '2-digit', minute: '2-digit', second: '2-digit',
        timeZoneName: 'short',
    });
    function tick() {
        if (clock) clock.textContent = etFmt.format(new Date()).replace(',', '');
    }
    tick();
    setInterval(tick, 1000);

    // The Lens — cursor resolves the dimmed signal feed
    const field = document.getElementById('lensField');
    const feed = document.getElementById('feed');
    const resolved = document.getElementById('lensResolved');
    const ring = document.getElementById('lensRing');
    const hint = document.getElementById('lensHint');
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const isTouch = window.matchMedia('(pointer: coarse)').matches;

    if (field && feed && resolved && ring) {
        if (isTouch || reduceMotion) {
            // Touch / reduced motion: press-and-hold (or tap) toggles full reveal
            if (hint) hint.textContent = 'Tap to resolve · client access decrypts in full';
            let revealed = false;
            field.addEventListener('click', () => {
                revealed = !revealed;
                resolved.style.clipPath = revealed ? 'none' : 'circle(0px at 50% 50%)';
            });
        } else {
            field.addEventListener('mousemove', (e) => {
                const r = feed.getBoundingClientRect();
                const x = e.clientX - r.left;
                const y = e.clientY - r.top;
                resolved.style.clipPath = `circle(90px at ${x}px ${y}px)`;
                ring.style.left = `${x}px`;
                ring.style.top = `${y}px`;
                ring.style.opacity = '1';
            });
            field.addEventListener('mouseleave', () => {
                resolved.style.clipPath = 'circle(0px at 50% 50%)';
                ring.style.opacity = '0';
            });
        }
    }
</script>

<style>
    /* ── HERO ── */
    .hero {
        position: relative;
        padding-top: 72px; /* nav clearance */
        border-bottom: 1px solid var(--hairline);
    }

    .hero-grid {
        display: grid;
        grid-template-columns: minmax(0, 58fr) minmax(0, 42fr);
        min-height: calc(88vh - 72px);
    }

    .hero-statement {
        padding: 5rem 3rem 3.5rem calc(var(--rail-w) + 3rem);
        border-right: 1px solid var(--hairline);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        gap: 3rem;
    }

    .hero-emblem {
        width: 72px;
        height: auto;
        margin-bottom: 1.6rem;
    }

    .hero-route {
        display: block;
        margin-bottom: 2.2rem;
    }

    .hero h1 {
        max-width: 11ch;
    }

    .hero-tagline {
        font-size: 1.35rem;
        margin-top: 1.6rem;
    }

    .hero-subtitle {
        margin-top: 1.8rem;
        max-width: 54ch;
        font-size: 1rem;
        color: var(--muted);
    }

    /* ── INSTRUMENT (signal feed + lens) ── */
    .hero-instrument {
        position: relative;
        padding: 2.4rem 2.4rem 3.6rem;
        font-family: var(--mono);
        cursor: none;
        display: flex;
        flex-direction: column;
        /* chart-paper grid */
        background-image:
            linear-gradient(var(--hairline-soft) 1px, transparent 1px),
            linear-gradient(90deg, var(--hairline-soft) 1px, transparent 1px);
        background-size: 28px 28px;
        background-position: 0 0;
    }

    .hero-instrument::after {
        /* fade the grid toward the fold so the feed stays legible */
        content: '';
        position: absolute;
        inset: 0;
        pointer-events: none;
        z-index: 0;
        background: linear-gradient(180deg, rgba(10,18,32,0.25) 0%, rgba(10,18,32,0.7) 78%, var(--ink) 100%);
    }
    .feed-head, .feed { position: relative; z-index: 1; }

    .feed-head {
        display: flex;
        justify-content: space-between;
        font-size: 0.6rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--dim);
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--hairline);
        margin-bottom: 0.4rem;
    }

    .feed-utc { color: var(--gold); }

    .feed { position: relative; }

    .feed-layer { display: flex; flex-direction: column; }

    .sig {
        display: grid;
        grid-template-columns: auto 1fr auto;
        gap: 1rem;
        align-items: baseline;
        padding: 0.78rem 0;
        border-bottom: 1px solid var(--hairline-soft);
        font-size: 0.7rem;
        letter-spacing: 0.02em;
    }

    .sig .t { color: var(--dim); font-size: 0.62rem; }
    .sig .b { color: var(--muted); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .sig .v { color: var(--muted); }

    .feed-resolved {
        position: absolute;
        inset: 0;
        background: var(--ink);
        clip-path: circle(0px at 50% 50%);
        pointer-events: none;
    }

    .feed-resolved .sig .b { color: var(--bone); }
    .feed-resolved .sig .t,
    .feed-resolved .sig .v { color: var(--gold); }
    .feed-resolved .sig .v { font-weight: 700; }

    .lens-ring {
        position: absolute;
        width: 180px;
        height: 180px;
        border: 1px solid var(--gold);
        border-radius: 50%;
        transform: translate(-50%, -50%);
        pointer-events: none;
        opacity: 0;
        transition: opacity 0.25s;
    }

    .lens-ring::after {
        content: 'RESOLVED';
        position: absolute;
        top: calc(100% + 6px);
        left: 50%;
        transform: translateX(-50%);
        font-size: 0.55rem;
        letter-spacing: 0.2em;
        color: var(--gold);
    }

    .feed-foot {
        position: absolute;
        z-index: 1;
        bottom: 1.2rem;
        left: 2.4rem;
        right: 2.4rem;
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        font-size: 0.58rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--dim);
    }

    /* ── DATA BAR ── */
    .data-bar {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        border-top: 1px solid var(--hairline);
    }

    .datum {
        padding: 1.5rem 2rem;
        border-right: 1px solid var(--hairline);
        font-family: var(--mono);
    }
    .datum:first-child { padding-left: calc(var(--rail-w) + 3rem); }
    .datum:last-child { border-right: none; }

    .d-val {
        display: block;
        font-size: 1.35rem;
        font-weight: 500;
        color: var(--bone);
        letter-spacing: 0.01em;
    }
    .d-val.gold { color: var(--gold); }

    .d-cap {
        display: block;
        margin-top: 0.35rem;
        font-size: 0.58rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--dim);
    }

    /* ── PRACTICE STRIP ── */
    .practice-strip {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        border-bottom: 1px solid var(--hairline);
    }

    .practice-cell {
        position: relative;
        padding: 2.4rem 2.6rem 2.6rem;
        border-right: 1px solid var(--hairline);
        text-decoration: none;
        transition: background var(--t-short);
    }
    .practice-cell:first-child { padding-left: calc(var(--rail-w) + 3rem); }
    .practice-cell:last-child { border-right: none; }
    .practice-cell:hover { background: var(--ink-panel); }

    .p-num {
        font-family: var(--serif);
        font-style: italic;
        font-size: 1.2rem;
        color: var(--gold);
        display: block;
        margin-bottom: 0.7rem;
    }

    .practice-cell h3 { margin-bottom: 0.5rem; font-size: 1.15rem; }
    .practice-cell p { font-size: 0.88rem; line-height: 1.6; color: var(--muted); max-width: 40ch; }

    .p-arrow {
        position: absolute;
        top: 2.4rem;
        right: 2rem;
        font-family: var(--mono);
        color: var(--dim);
        transition: color var(--t-short), transform var(--t-short) var(--ease-enter);
    }
    .practice-cell:hover .p-arrow { color: var(--gold); transform: translateX(4px); }

    /* ── ALLIED (PAPER) ── */
    .allied-grid {
        display: grid;
        grid-template-columns: minmax(0, 5fr) minmax(0, 5fr);
        gap: 4.5rem;
        align-items: start;
    }

    .allied-text h2 { margin-bottom: 1.4rem; }

    .allied-lede {
        font-size: 1.08rem;
        margin-bottom: 1rem;
    }
    .allied-lede::first-letter {
        font-family: var(--serif);
