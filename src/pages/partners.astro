---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import CTASection from '../components/CTASection.astro';
import { nations } from '../data/nations';
---

<BaseLayout title="Partners | Levenhall" description="Levenhall serves allied defense and government technology firms — intelligence, US federal market entry, ventures, and proprietary products built on a shared trust framework.">

    <PageHeader
        label="Our Network"
        title="Who We Serve"
    />

    <!-- ── ALLIANCE OVERVIEW (INK) ── -->
    <section class="section alliance-section texture-grain">
        <div class="container">
            <div class="alliance-grid">
                <div class="alliance-text">
                    <span class="section-label">01 / The Framework</span>
                    <h2>The Allied Framework</h2>
                    <p>The United States maintains deep defense partnerships with a network of allied democracies, built on shared intelligence frameworks, interoperable security clearances, mutual defense procurement agreements, and aligned strategic priorities. For firms based in these nations, this framework creates a structural advantage that no amount of marketing or business development can replicate.</p>
                    <p>Allied-nation firms can integrate into US programs in ways that other international companies cannot. AUKUS, NATO interoperability agreements, and bilateral defense trade treaties create procurement pathways specifically designed for trusted partners. Levenhall's federal market entry and ventures practices are built on this foundation; our market intelligence work feeds them.</p>
                    <p>We serve firms from the United Kingdom, Australia, Canada, New Zealand, NATO allies, and select partner democracies whose technologies address critical US defense and dual-use requirements, particularly in domains where allied capability leads American development.</p>
                </div>
                <aside class="alliance-sidebar">
                    <div class="alliance-block">
                        <span class="ab-head route-line">Allied Nations <span class="live">●</span></span>
                        <div class="ab-flags">
                            <span>🇬🇧</span><span>🇦🇺</span><span>🇨🇦</span><span>🇳🇿</span><span>🌍</span>
                        </div>
                        <p>Trusted democracies with shared security frameworks and aligned strategic interests.</p>
                    </div>
                </aside>
            </div>
        </div>
    </section>

    <!-- ── NATIONS LEDGER (PANEL) ── -->
    <section class="section section-panel nations-section">
        <div class="container">
            <div class="section-header">
                <span class="section-label">02 / Partner Nations</span>
                <h2>Where Our Clients Come From</h2>
            </div>
            <div class="nations-ledger">
                {nations.map((nation, i) => (
                    <div class="nation-row">
                        <span class="nr-idx">0{i + 1}</span>
                        <span class="nr-flag">{nation.flag}</span>
                        <span class="nr-id">
                            <h3>{nation.name}</h3>
                            <span class="nr-tag">{nation.tagline}</span>
                        </span>
                        <p class="nr-desc">{nation.description}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- ── THE ALLIED ADVANTAGE (PAPER — the one light passage) ── -->
    <section class="section section-paper advantage-section">
        <div class="container">
            <div class="section-header">
                <span class="section-label">03 / Why This Matters</span>
                <h2>The Allied Advantage</h2>
            </div>
            <div class="advantage-grid">
                <div class="advantage-cell">
                    <span class="adv-num">I.</span>
                    <h3>Shared Security Frameworks</h3>
                    <p>Allied classification frameworks and interoperable clearances enable firms from partner nations to participate in programs that require security access, a prerequisite for the highest-value US defense contracts.</p>
                </div>
                <div class="advantage-cell">
                    <span class="adv-num">II.</span>
                    <h3>Proven Network</h3>
                    <p>Levenhall's relationships span OTA consortia, government contracting officers, agency program managers, intelligence community partners, and defense industry executives. These are not introductions. They are institutional relationships built over years.</p>
                </div>
                <div class="advantage-cell">
                    <span class="adv-num">III.</span>
                    <h3>Market Intelligence</h3>
                    <p>The core of the firm. We go beyond publicly available solicitations to understand which programs are forming, which agencies are seeking allied capability, where the procurement calendar creates opportunity windows, and how the geopolitical environment is reshaping demand.</p>
                </div>
                <div class="advantage-cell">
                    <span class="adv-num">IV.</span>
                    <h3>Regulatory Navigation</h3>
                    <p>ITAR, EAR, FAR, DFARS: the US regulatory environment is designed to be navigated, not avoided. We structure every engagement to ensure compliance without sacrificing speed or competitive position.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ── RAPID PROCUREMENT (INK) ── -->
    <section class="section rapid-section">
        <div class="container">
            <div class="rapid-grid">
                <div class="rapid-text">
                    <span class="section-label">04 / Rapid Procurement</span>
                    <h2>CSO, OTA &amp; Production Pathways</h2>
                    <p>The Department of Defense has built an alternative procurement ecosystem designed for speed. Commercial Solutions Openings (CSOs) and Other Transaction Authority (OTAs) bypass traditional FAR-based processes, reducing timelines from years to months and lowering the compliance burden that deters international entrants.</p>
                    <p>OTAs are exempt from the FAR entirely, enabling negotiable terms, protected intellectual property, and direct prototype-to-production pipelines. For allied firms, these mechanisms remove the barriers that traditionally required years of US infrastructure to overcome. Your status as a non-traditional defense contractor is not a limitation &mdash; under OTA rules, it is a qualifying advantage.</p>
                    <p>Levenhall identifies which consortia to join, which agencies are active in CSO and OTA solicitations, structures teaming arrangements with US-based partners, and positions your technology for prototype awards that lead directly to production contracts.</p>
                    <a href="/services#rapid-procurement" class="mono-link rapid-link">Explore Rapid Procurement →</a>
                </div>
                <aside class="rapid-metric">
                    <span class="rm-head route-line">Solicitation → Award</span>
                    <span class="rm-value">60&ndash;120</span>
                    <span class="rm-unit">Days</span>
                    <span class="rm-cap">Solicitation to award</span>
                </aside>
            </div>
        </div>
    </section>

    <CTASection />

</BaseLayout>

<style>
    /* ── ALLIANCE (INK) ── */
    .alliance-grid {
        display: grid;
        grid-template-columns: minmax(0, 7fr) minmax(0, 4fr);
        gap: 4rem;
        align-items: start;
    }

    .alliance-text h2 { margin-bottom: 1.4rem; }

    .alliance-text p {
        font-size: 1.02rem;
        line-height: 1.75;
        margin-bottom: 1rem;
        max-width: 66ch;
    }

    .alliance-block {
        border: 1px solid var(--hairline);
    }

    .ab-head {
        display: block;
        padding: 1rem 1.6rem;
        border-bottom: 1px solid var(--hairline);
    }

    .ab-flags {
        display: flex;
        gap: 0.9rem;
        font-size: 1.7rem;
        line-height: 1;
        padding: 1.4rem 1.6rem 0;
    }

    .alliance-block p {
        font-size: 0.9rem;
        line-height: 1.65;
        color: var(--muted);
        padding: 1rem 1.6rem 1.5rem;
    }

    /* ── NATIONS LEDGER (PANEL) ── */
    .nations-ledger {
        border-top: 1px solid var(--hairline);
    }

    .nation-row {
        display: grid;
        grid-template-columns: 40px 44px 240px minmax(0, 1fr);
        gap: 1.6rem;
        align-items: baseline;
        padding: 1.5rem 0.2rem;
        border-bottom: 1px solid var(--hairline);
        transition: background var(--t-short);
    }
    .nation-row:hover { background: var(--ink); }

    .nr-idx {
        font-family: var(--mono);
        font-size: 0.62rem;
        letter-spacing: 0.1em;
        color: var(--gold);
        font-variant-numeric: tabular-nums;
    }

    .nr-flag {
        font-size: 1.5rem;
        line-height: 1;
        align-self: center;
    }

    .nr-id h3 {
        font-size: 1.15rem;
        margin-bottom: 0.3rem;
    }

    .nr-tag {
        display: block;
        font-family: var(--mono);
        font-size: 0.58rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--dim);
    }

    .nr-desc {
        font-size: 0.92rem;
        line-height: 1.65;
        color: var(--muted);
        max-width: 64ch;
    }

    /* ── ADVANTAGE (PAPER) ── */
    .advantage-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        border-top: 1px solid var(--hairline-paper);
        border-left: 1px solid var(--hairline-paper);
    }

    .advantage-cell {
        padding: 2rem 2.2rem 2.4rem;
        border-right: 1px solid var(--hairline-paper);
        border-bottom: 1px solid var(--hairline-paper);
    }

    .adv-num {
        display: block;
        font-family: var(--serif);
        font-style: italic;
        font-weight: 400;
        font-size: 1.3rem;
        color: var(--gold);
        margin-bottom: 0.8rem;
    }

    .advantage-cell h3 {
        font-size: 1.15rem;
        margin-bottom: 0.7rem;
    }

    .advantage-cell p {
        font-size: 0.94rem;
        line-height: 1.65;
    }

    /* ── RAPID PROCUREMENT (INK) ── */
    .rapid-grid {
        display: grid;
        grid-template-columns: minmax(0, 7fr) minmax(0, 4fr);
        gap: 4rem;
        align-items: start;
    }

    .rapid-text h2 { margin-bottom: 1.4rem; }

    .rapid-text p {
        font-size: 1.02rem;
        line-height: 1.75;
        margin-bottom: 1rem;
        max-width: 66ch;
    }

    .rapid-link {
        display: inline-block;
        margin-top: 1rem;
    }

    .rapid-metric {
        border: 1px solid var(--hairline);
        font-family: var(--mono);
    }

    .rm-head {
        display: block;
        padding: 1rem 1.6rem;
        border-bottom: 1px solid var(--hairline);
    }

    .rm-value {
        display: block;
        padding: 1.6rem 1.6rem 0;
        font-size: 2.8rem;
        font-weight: 500;
        color: var(--gold);
        line-height: 1;
        font-variant-numeric: tabular-nums;
    }

    .rm-unit {
        display: block;
        padding: 0.4rem 1.6rem 0;
        font-size: 0.72rem;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--bone);
    }

    .rm-cap {
        display: block;
        padding: 1.2rem 1.6rem 1.5rem;
        font-size: 0.58rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--dim);
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 992px) {
        .alliance-grid { grid-template-columns: 1fr; gap: 2.5rem; }
        .alliance-block { max-width: 420px; }
        .rapid-grid { grid-template-columns: 1fr; gap: 2.5rem; }
        .rapid-metric { max-width: 320px; }
        .nation-row { grid-template-columns: 40px 44px minmax(0, 1fr); }
        .nr-desc { grid-column: 3; }
    }

    @media (max-width: 768px) {
        .advantage-grid { grid-template-columns: 1fr; }
        .nation-row { grid-template-columns: 32px minmax(0, 1fr); gap: 1rem; }
        .nr-flag { grid-column: 2; }
        .nr-id { grid-column: 2; }
        .nr-desc { grid-column: 2; }
    }
</style>
