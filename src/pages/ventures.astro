---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';
---

<BaseLayout title="Ventures | Levenhall" description="Levenhall Ventures backs founders building defense-adjacent and government technology in Allied Nations who are ready to bring their technology into the United States federal market.">

    <!-- ── HERO ── -->
    <section class="v-hero">
        <div class="v-hero-bg"></div>
        <div class="v-hero-inner">
            <span class="v-hero-badge">Investment Arm of Levenhall LLC</span>
            <h1>Levenhall<br/><span class="gold-text">Ventures</span></h1>
            <div class="v-hero-rule"></div>
            <p class="v-hero-sub">We provide US federal market entry services to allied defense and government technology companies in exchange for equity. No capital. No fees. Services for stake.</p>
            <a href="#apply" class="btn btn-gold">Apply for Partnership</a>
        </div>
    </section>

    <!-- ── ABOUT ── -->
    <section class="section v-about">
        <div class="container">
            <div class="v-about-grid reveal">
                <div class="v-about-text">
                    <span class="v-label">About Levenhall Ventures</span>
                    <h2>We Don't Write Checks</h2>
                    <div class="v-rule"></div>
                    <p>Levenhall Ventures is the investment arm of Levenhall LLC. We partner with defense and government technology companies from Allied Nations (NATO, Five Eyes, and key strategic allies) who are ready to enter the US federal market.</p>
                    <p>We are not a fund. We provide our full market entry infrastructure at cost: access to contracting vehicles, BRIDGER intelligence, and federal relationships. In exchange, we take equity. No fees. No retainers. We only win when they win.</p>
                </div>
                <div class="v-about-sidebar">
                    <div class="v-stat-card">
                        <span class="v-stat-value">5</span>
                        <span class="v-stat-label">Companies<br/>Per Year</span>
                    </div>
                    <div class="v-model-card">
                        <span class="v-model-icon">&#9670;</span>
                        <h4>Services for Equity</h4>
                        <p>No capital invested. No advisory fees. We provide services at cost and take equity. Fully aligned.</p>
                    </div>
                    <div class="v-model-card">
                        <span class="v-model-icon">&#9670;</span>
                        <h4>Deliberately Selective</h4>
                        <p>Five companies a year. Every portfolio company gets our full operational commitment.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ── WHAT WE OFFER ── -->
    <section class="section v-offer">
        <div class="v-offer-bg"></div>
        <div class="container" style="position: relative; z-index: 1;">
            <div class="section-header reveal">
                <span class="v-offer-label">What We Offer</span>
                <h2>Your US Market Entry Partner</h2>
            </div>
            <div class="v-offer-grid">
                <div class="v-offer-card reveal">
                    <div class="v-offer-num">01</div>
                    <div class="v-offer-line"></div>
                    <h3>US Market Entry Strategy</h3>
                    <p>We map the federal landscape and build your capture plan from day one.</p>
                </div>
                <div class="v-offer-card reveal">
                    <div class="v-offer-num">02</div>
                    <div class="v-offer-line"></div>
                    <h3>BRIDGER Access</h3>
                    <p>Proprietary government opportunity intelligence and pipeline management.</p>
                </div>
                <div class="v-offer-card reveal">
                    <div class="v-offer-num">03</div>
                    <div class="v-offer-line"></div>
                    <h3>Contracting Vehicle Access</h3>
                    <p>We open doors that take most companies years to reach.</p>
                </div>
                <div class="v-offer-card reveal">
                    <div class="v-offer-num">04</div>
                    <div class="v-offer-line"></div>
                    <h3>Federal Relationship Network</h3>
                    <p>Direct introductions across DoD, IC, and civilian agencies.</p>
                </div>
                <div class="v-offer-card reveal">
                    <div class="v-offer-num">05</div>
                    <div class="v-offer-line"></div>
                    <h3>AI Governance & Compliance</h3>
                    <p>Ensuring your technology meets US federal standards, from IL2 to TS/SCI environments.</p>
                </div>
                <div class="v-offer-card reveal">
                    <div class="v-offer-num">06</div>
                    <div class="v-offer-line"></div>
                    <h3>Equity-for-Services Model</h3>
                    <p>Pay us at cost. Give us equity. We're aligned from day one.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ── WHO WE BACK ── -->
    <section class="section v-criteria">
        <div class="container">
            <div class="v-criteria-grid reveal">
                <div class="v-criteria-text">
                    <span class="v-label">Who We Back</span>
                    <h2>Investment Criteria</h2>
                    <div class="v-rule"></div>
                    <p>Not ideas. Not decks. Companies with traction, product, and founders who understand the operating environment.</p>
                </div>
                <div class="v-criteria-cards">
                    <div class="v-crit-card">
                        <div class="v-crit-icon">&#9670;</div>
                        <h4>Working Product</h4>
                        <p>A working product or platform with a credible US federal application.</p>
                    </div>
                    <div class="v-crit-card">
                        <div class="v-crit-icon">&#9670;</div>
                        <h4>Government Traction</h4>
                        <p>A contract, a pilot, or a customer in your home government.</p>
                    </div>
                    <div class="v-crit-card">
                        <div class="v-crit-icon">&#9670;</div>
                        <h4>Allied Nation Founders</h4>
                        <p>Founders from Allied or Five Eyes nations who understand the defense and intelligence operating environment.</p>
                    </div>
                    <div class="v-crit-card">
                        <div class="v-crit-icon">&#9670;</div>
                        <h4>Target Domains</h4>
                        <p>Artificial intelligence, cybersecurity, dual-use platforms, ISR, logistics, critical infrastructure, or interoperability.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ── WHY LEVENHALL ── -->
    <section class="section v-why">
        <div class="v-why-bg"></div>
        <div class="container" style="position: relative; z-index: 1;">
            <div class="v-why-inner reveal">
                <span class="v-why-label">Why Levenhall</span>
                <h2>Operators, Not Consultants</h2>
                <div class="v-why-rule"></div>
                <p>We have access to contracting vehicles, the relationships across DoD and IC, and direct experience deploying AI systems inside the federal ecosystem.</p>
                <p>Other firms charge fees and hand you a report. We provide services at cost and take equity. Your cap table stays clean. We earn our stake by delivering results.</p>
                <p class="v-why-emphasis">Not a fund. A services-for-equity partnership.</p>
            </div>
        </div>
    </section>

    <!-- ── APPLY CTA ── -->
    <section class="section v-apply" id="apply">
        <div class="v-apply-bg"></div>
        <div class="container" style="position: relative; z-index: 1;">
            <div class="v-apply-inner reveal">
                <div class="v-apply-accent"></div>
                <h2>Apply for Partnership</h2>
                <p>Rolling applications. Five companies per year. If you're building defense or government technology in an Allied nation and ready for the US federal market, we want to hear from you.</p>
                <div class="btn-group" style="justify-content: center;">
                    <a href="mailto:hgad@levenhall.com?subject=Levenhall%20Ventures%20%E2%80%94%20Partnership%20Application" class="btn btn-gold">Apply Now</a>
                    <a href="/contact" class="btn btn-outline-white">Contact Us</a>
                </div>
            </div>
        </div>
    </section>

</BaseLayout>

<style>
    /* ── HERO ── */
    .v-hero {
        background: linear-gradient(160deg, #060b16 0%, #0c1628 30%, var(--deep-navy) 60%, #162d4f 100%);
        padding: 10rem 2rem 6rem;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

    .v-hero-bg {
        position: absolute;
        inset: 0;
        background-image:
            radial-gradient(ellipse at 30% 70%, rgba(201, 169, 97, 0.06) 0%, transparent 50%),
            radial-gradient(ellipse at 70% 30%, rgba(30, 58, 95, 0.15) 0%, transparent 50%),
            radial-gradient(circle at 50% 100%, rgba(201, 169, 97, 0.04) 0%, transparent 40%);
        pointer-events: none;
    }

    .v-hero::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: linear-gradient(90deg, transparent 0%, var(--gold) 50%, transparent 100%);
        opacity: 0.4;
    }

    .v-hero-inner {
        max-width: 750px;
        margin: 0 auto;
        position: relative;
        z-index: 1;
    }

    .v-hero-badge {
        display: inline-block;
        font-family: 'Source Sans Pro', sans-serif;
        font-weight: 600;
        font-size: 0.68rem;
        letter-spacing: 3.5px;
        text-transform: uppercase;
        color: var(--gold);
        background: rgba(201, 169, 97, 0.08);
        border: 1px solid rgba(201, 169, 97, 0.15);
        padding: 0.5rem 1.4rem;
        margin-bottom: 1.8rem;
    }

    .v-hero h1 {
        color: #fff;
        font-size: clamp(2.8rem, 5vw, 4.2rem);
        line-height: 1.1;
        margin-bottom: 1.5rem;
    }

    .v-hero-rule {
        width: 60px;
        height: 2px;
        background: var(--gold);
        margin: 0 auto 2rem;
    }

    .v-hero-sub {
        font-size: 1.15rem;
        color: rgba(255, 255, 255, 0.5);
        line-height: 1.85;
        margin-bottom: 2.5rem;
        max-width: 580px;
        margin-left: auto;
        margin-right: auto;
    }

    /* ── ABOUT ── */
    .v-about {
        background: var(--stone);
    }

    .v-label {
        display: inline-block;
        font-family: 'Source Sans Pro', sans-serif;
        font-weight: 600;
        font-size: 0.72rem;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: var(--burgundy);
        background: var(--burgundy-surface);
        padding: 0.5rem 1.2rem;
        margin-bottom: 1.2rem;
    }

    .v-rule {
        width: 50px;
        height: 2px;
        background: var(--gold);
        margin-bottom: 1.5rem;
    }

    .v-about-grid {
        display: grid;
        grid-template-columns: 1.1fr 0.45fr;
        gap: 3.5rem;
        align-items: start;
    }

    .v-about-text h2 {
        color: var(--deep-navy);
        margin-bottom: 1rem;
    }

    .v-about-text p {
        font-size: 1.02rem;
        line-height: 1.75;
        margin-bottom: 1rem;
        color: var(--text-medium);
    }

    .v-about-sidebar {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        position: sticky;
        top: 100px;
    }

    .v-stat-card {
        background: #fff;
        text-align: center;
        padding: 2rem 1.5rem;
        border: 1px solid var(--border-warm);
        border-top: 3px solid var(--gold);
        box-shadow: var(--shadow-warm-md);
    }

    .v-stat-value {
        display: block;
        font-family: 'Crimson Text', serif;
        font-size: 3.5rem;
        font-weight: 700;
        color: var(--deep-navy);
        line-height: 1;
        margin-bottom: 0.5rem;
    }

    .v-stat-label {
        display: block;
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: var(--text-medium);
        line-height: 1.4;
    }

    .v-model-card {
        background: #fff;
        padding: 1.5rem;
        border: 1px solid var(--border-warm);
        border-left: 3px solid rgba(201, 169, 97, 0.4);
        transition: all 0.3s ease;
    }

    .v-model-card:hover {
        background: #fff;
        border-left-color: var(--gold);
        box-shadow: var(--shadow-warm-md);
        transform: translateX(4px);
    }

    .v-model-icon {
        color: var(--gold);
        font-size: 0.8rem;
        margin-bottom: 0.6rem;
        display: block;
    }

    .v-model-card h4 {
        font-size: 0.95rem;
        color: var(--deep-navy);
        margin-bottom: 0.4rem;
    }

    .v-model-card p {
        font-size: 0.85rem;
        color: var(--text-medium);
        line-height: 1.6;
    }

    /* ── WHAT WE OFFER (DARK) ── */
    .v-offer {
        background: linear-gradient(135deg, #0a1628 0%, var(--navy) 50%, #162d4f 100%);
        overflow: hidden;
    }

    .v-offer-bg {
        position: absolute;
        inset: 0;
        background-image:
            radial-gradient(ellipse at 50% 80%, rgba(201, 169, 97, 0.05) 0%, transparent 50%);
        pointer-events: none;
    }

    .v-offer::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: linear-gradient(90deg, transparent, var(--gold), transparent);
        opacity: 0.4;
    }

    .v-offer-label {
        display: inline-block;
        font-family: 'Source Sans Pro', sans-serif;
        font-weight: 600;
        font-size: 0.72rem;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: var(--gold);
        background: rgba(201, 169, 97, 0.08);
        padding: 0.5rem 1.2rem;
        margin-bottom: 1.2rem;
    }

    .v-offer .section-header h2 { color: #fff; }
    .v-offer .section-header p { color: rgba(255, 255, 255, 0.5); }

    .v-offer-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
        max-width: 1000px;
        margin: 0 auto;
    }

    .v-offer-card {
        padding: 2.2rem 1.8rem;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-top: 3px solid rgba(201, 169, 97, 0.3);
        transition: all 0.4s ease;
    }

    .v-offer-card:hover {
        background: rgba(255, 255, 255, 0.07);
        border-top-color: var(--gold);
        transform: translateY(-4px);
        box-shadow: 0 16px 50px rgba(0, 0, 0, 0.3);
    }

    .v-offer-num {
        font-family: 'Crimson Text', serif;
        font-size: 2rem;
        font-weight: 700;
        color: var(--gold);
        opacity: 0.3;
        line-height: 1;
        margin-bottom: 0.5rem;
    }

    .v-offer-line {
        width: 30px;
        height: 2px;
        background: var(--gold);
        opacity: 0.4;
        margin-bottom: 1rem;
    }

    .v-offer-card h3 {
        font-size: 1.1rem;
        color: #fff;
        margin-bottom: 0.6rem;
    }

    .v-offer-card p {
        font-size: 0.9rem;
        color: rgba(255, 255, 255, 0.5);
        line-height: 1.65;
    }

    /* ── WHO WE BACK ── */
    .v-criteria {
        background: var(--cream);
    }

    .v-criteria-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: start;
    }

    .v-criteria-text h2 {
        color: var(--deep-navy);
        margin-bottom: 1rem;
    }

    .v-criteria-text p {
        font-size: 1.02rem;
        line-height: 1.75;
        color: var(--text-medium);
    }

    .v-criteria-cards {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.2rem;
    }

    .v-crit-card {
        background: #fff;
        padding: 1.5rem;
        border: 1px solid var(--border-subtle);
        border-left: 3px solid rgba(201, 169, 97, 0.4);
        transition: all 0.3s ease;
    }

    .v-crit-card:hover {
        border-left-color: var(--gold);
        box-shadow: var(--shadow-md);
        transform: translateX(4px);
    }

    .v-crit-icon {
        color: var(--gold);
        font-size: 0.8rem;
        margin-bottom: 0.6rem;
    }

    .v-crit-card h4 {
        font-size: 0.95rem;
        color: var(--deep-navy);
        margin-bottom: 0.4rem;
    }

    .v-crit-card p {
        font-size: 0.85rem;
        color: var(--text-medium);
        line-height: 1.6;
    }

    /* ── WHY LEVENHALL (DARK) ── */
    .v-why {
        background: linear-gradient(180deg, var(--deep-navy) 0%, #162d4a 100%);
        overflow: hidden;
    }

    .v-why-bg {
        position: absolute;
        inset: 0;
        background-image:
            radial-gradient(ellipse at 30% 30%, rgba(201, 169, 97, 0.05) 0%, transparent 50%);
        pointer-events: none;
    }

    .v-why::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: linear-gradient(90deg, transparent, var(--gold), transparent);
        opacity: 0.4;
    }

    .v-why-inner {
        max-width: 720px;
        margin: 0 auto;
        text-align: center;
    }

    .v-why-label {
        display: inline-block;
        font-family: 'Source Sans Pro', sans-serif;
        font-weight: 600;
        font-size: 0.72rem;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: var(--gold);
        background: rgba(201, 169, 97, 0.08);
        padding: 0.5rem 1.2rem;
        margin-bottom: 1.2rem;
    }

    .v-why h2 {
        color: #fff;
        margin-bottom: 1rem;
    }

    .v-why-rule {
        width: 50px;
        height: 2px;
        background: var(--gold);
        margin: 0 auto 2rem;
    }

    .v-why p {
        font-size: 1.05rem;
        line-height: 1.8;
        color: rgba(255, 255, 255, 0.55);
        margin-bottom: 1rem;
    }

    .v-why-emphasis {
        font-family: 'Crimson Text', serif;
        font-size: 1.4rem;
        font-weight: 700;
        font-style: italic;
        color: var(--gold);
        margin-top: 1.5rem;
    }

    /* ── APPLY CTA ── */
    .v-apply {
        background: linear-gradient(135deg, var(--burgundy-deep, #5a0f28) 0%, var(--burgundy) 50%, #9e1a3e 100%);
        padding: 5rem 2rem;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

    .v-apply-bg {
        position: absolute;
        inset: 0;
        background-image:
            radial-gradient(ellipse at 50% 50%, rgba(201, 169, 97, 0.08) 0%, transparent 50%);
        pointer-events: none;
    }

    .v-apply::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: linear-gradient(90deg, transparent, var(--gold), transparent);
        opacity: 0.4;
    }

    .v-apply-inner {
        max-width: 680px;
        margin: 0 auto;
    }

    .v-apply-accent {
        width: 40px;
        height: 2px;
        background: var(--gold);
        margin: 0 auto 2rem;
    }

    .v-apply h2 {
        font-size: clamp(1.6rem, 3vw, 2.2rem);
        color: #fff;
        margin-bottom: 1.2rem;
    }

    .v-apply p {
        color: rgba(255, 255, 255, 0.65);
        font-size: 1.05rem;
        line-height: 1.75;
        margin-bottom: 2rem;
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 992px) {
        .v-about-grid { grid-template-columns: 1fr; }
        .v-about-sidebar {
            position: static;
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 1.2rem;
        }
        .v-criteria-grid { grid-template-columns: 1fr; }
        .v-offer-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @media (max-width: 768px) {
        .v-hero { padding: 8rem 2rem 4rem; }
        .v-about-sidebar { grid-template-columns: 1fr; }
        .v-offer-grid { grid-template-columns: 1fr; max-width: 450px; }
        .v-criteria-cards { grid-template-columns: 1fr; }
    }
</style>
