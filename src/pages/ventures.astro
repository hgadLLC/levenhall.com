---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Ventures | Levenhall" description="Levenhall Ventures is the investment arm of Levenhall LLC — services-for-equity partnerships with allied defense and government technology companies, backed by the firm's market intelligence.">

    <!-- ── HERO: THE TERM SHEET ── -->
    <section class="v-hero sweep-field texture-grain">
        <div class="v-hero-inner">
            <span class="route-line v-route">LEVENHALL / VENTURES / SERVICES-FOR-EQUITY <span class="live">●</span></span>
            <span class="section-label">The Investment Arm of Levenhall</span>
            <h1>Levenhall Ventures</h1>
            <p class="v-hero-sub">Levenhall Ventures is the investment arm of our market intelligence consulting firm. We provide US federal market entry services to allied defense and government technology companies in exchange for equity. No capital. No fees. Services for stake.</p>
            <div class="btn-group v-hero-cta">
                <a href="#apply" class="btn btn-primary">Apply for Partnership</a>
            </div>
        </div>

        <!-- Evidence bar -->
        <div class="v-data-bar">
            <div class="v-datum">
                <span class="v-d-val">5</span>
                <span class="v-d-cap">Companies Per Year</span>
            </div>
            <div class="v-datum">
                <span class="v-d-val">$1.5T+</span>
                <span class="v-d-cap">US Defense Market</span>
            </div>
            <div class="v-datum">
                <span class="v-d-val gold">100%</span>
                <span class="v-d-cap">Aligned Incentives</span>
            </div>
        </div>
    </section>

    <!-- ── MODEL STRIP ── -->
    <section class="v-model-strip">
        <div class="v-strip-item">
            <span class="v-strip-num">01</span>
            <span class="v-strip-text">Services at Cost</span>
        </div>
        <span class="v-strip-arrow" aria-hidden="true">→</span>
        <div class="v-strip-item">
            <span class="v-strip-num">02</span>
            <span class="v-strip-text">Equity in Return</span>
        </div>
        <span class="v-strip-arrow" aria-hidden="true">→</span>
        <div class="v-strip-item">
            <span class="v-strip-num">03</span>
            <span class="v-strip-text">We Win Together</span>
        </div>
    </section>

    <!-- ── ABOUT (PAPER — the one editorial passage) ── -->
    <section class="section section-paper v-about">
        <div class="container">
            <div class="v-about-grid">
                <div class="v-about-text">
                    <span class="section-label">About Levenhall Ventures</span>
                    <h2>We Don&rsquo;t Write Checks</h2>
                    <p>Levenhall Ventures is the investment arm of Levenhall &mdash; the market intelligence consulting firm. We partner with defense and government technology companies from Allied Nations (NATO, Five Eyes, and key strategic allies) who are ready to enter the US federal market.</p>
                    <p>We are not a fund. We provide our full market entry infrastructure at cost: market intelligence, access to contracting vehicles, BRIDGER, and federal relationships. In exchange, we take equity. No fees. No retainers. We only win when they win.</p>
                </div>
                <div class="v-terms">
                    <div class="v-terms-head">
                        <span>Our Model</span>
                        <span>Terms</span>
                    </div>
                    <div class="v-term-row">
                        <span class="v-term-clause">§ 1</span>
                        <span class="v-term-body">
                            <h4>Services for Equity</h4>
                            <p>No capital. No advisory fees. Full operational partnership.</p>
                        </span>
                    </div>
                    <div class="v-term-row">
                        <span class="v-term-clause">§ 2</span>
                        <span class="v-term-body">
                            <h4>Deliberately Selective</h4>
                            <p>Five companies a year. Full commitment to each.</p>
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ── WHAT WE OFFER (INK LEDGER) ── -->
    <section class="section v-offer">
        <div class="container">
            <div class="section-header">
                <span class="section-label">What We Offer</span>
                <h2>Your US Market Entry Partner</h2>
            </div>
            <div class="v-offer-ledger">
                <div class="v-offer-row">
                    <span class="vo-num">01</span>
                    <span class="vo-body">
                        <h3>Market Intelligence</h3>
                        <p>The firm&rsquo;s core practice, applied to your sector. Program, agency, competitor, and geopolitical tracking that feeds every other decision.</p>
                    </span>
                </div>
                <div class="v-offer-row">
                    <span class="vo-num">02</span>
                    <span class="vo-body">
                        <h3>US Market Entry Strategy</h3>
                        <p>We map the federal landscape and build your capture plan from day one.</p>
                    </span>
                </div>
                <div class="v-offer-row">
                    <span class="vo-num">03</span>
                    <span class="vo-body">
                        <h3>BRIDGER Access</h3>
                        <p>Our allied defense dealmaking platform. Curated, high-signal introductions to active buyers and primes.</p>
                    </span>
                </div>
                <div class="v-offer-row">
                    <span class="vo-num">04</span>
                    <span class="vo-body">
                        <h3>Contracting Vehicle Access</h3>
                        <p>We open CSO, OTA, and consortium doors that take most companies years to reach.</p>
                    </span>
                </div>
                <div class="v-offer-row">
                    <span class="vo-num">05</span>
                    <span class="vo-body">
                        <h3>Federal Relationship Network</h3>
                        <p>Direct introductions across DoD, IC, and civilian agencies.</p>
                    </span>
                </div>
                <div class="v-offer-row">
                    <span class="vo-num">06</span>
                    <span class="vo-body">
                        <h3>Equity-for-Services</h3>
                        <p>Pay us at cost. Give us equity. Aligned from day one.</p>
                    </span>
                </div>
            </div>
        </div>
    </section>

    <!-- ── WHO WE BACK (PANEL) ── -->
    <section class="section section-panel v-criteria">
        <div class="container">
            <div class="section-header">
                <span class="section-label">Who We Back</span>
                <h2>Investment Criteria</h2>
                <p>Not ideas. Not decks. Companies with traction, product, and founders who understand the operating environment.</p>
            </div>
            <div class="v-criteria-grid">
                <div class="v-crit-cell">
                    <span class="v-crit-num">01</span>
                    <h4>Working Product</h4>
                    <p>A product or platform with a credible US federal application.</p>
                </div>
                <div class="v-crit-cell">
                    <span class="v-crit-num">02</span>
                    <h4>Government Traction</h4>
                    <p>A contract, pilot, or customer in your home government.</p>
                </div>
                <div class="v-crit-cell">
                    <span class="v-crit-num">03</span>
                    <h4>Allied Nation Founders</h4>
                    <p>From Five Eyes or Allied nations. You understand the operating environment.</p>
                </div>
                <div class="v-crit-cell">
                    <span class="v-crit-num">04</span>
                    <h4>Target Domains</h4>
                    <p>AI, cybersecurity, dual-use platforms, ISR, logistics, critical infrastructure, interoperability.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ── WHY LEVENHALL (INK) ── -->
    <section class="section v-why">
        <div class="container">
            <div class="section-header">
                <span class="section-label">Why Levenhall</span>
                <h2>Operators, Not Consultants</h2>
            </div>
            <div class="v-why-columns">
                <div class="v-why-col">
                    <p>We run a working market intelligence practice. We have access to contracting vehicles, the relationships across DoD and IC, and direct experience deploying AI systems inside the federal ecosystem.</p>
                </div>
                <div class="v-why-col">
                    <p>Other firms charge fees and hand you a report. We provide services at cost and take equity. Your cap table stays clean. We earn our stake by delivering results.</p>
                </div>
            </div>
            <p class="v-why-emphasis editorial-italic">Not a fund. A services-for-equity partnership.</p>
        </div>
    </section>

    <!-- ── APPLY (PANEL) ── -->
    <section class="section section-panel v-apply" id="apply">
        <div class="container">
            <span class="route-line v-apply-route">LEVENHALL / VENTURES / APPLICATIONS <span class="live">● OPEN</span></span>
            <h2>Apply for Partnership</h2>
            <p class="v-apply-lede">Rolling applications. Five companies per year. If you&rsquo;re building defense or government technology in an Allied nation and ready for the US federal market, we want to hear from you.</p>
            <div class="btn-group">
                <a href="mailto:hgad@levenhall.com?subject=Levenhall%20Ventures%20%E2%80%94%20Partnership%20Application" class="btn btn-gold">Apply Now</a>
                <a href="/contact" class="btn btn-outline-white">Contact Us</a>
            </div>
        </div>
    </section>

</BaseLayout>

<style>
    /* ── HERO ── */
    .v-hero {
        position: relative;
        background: var(--ink);
        padding-top: 72px; /* nav clearance */
        border-bottom: 1px solid var(--hairline);
    }

    .v-hero-inner {
        max-width: var(--col-wide);
        margin: 0 auto;
        padding: 6rem 2rem 4.5rem;
    }

    .v-route {
        display: block;
        margin-bottom: 2.2rem;
    }

    .v-hero h1 {
        font-size: clamp(2.8rem, 5.4vw, 4.6rem);
        max-width: 12ch;
    }

    .v-hero-sub {
        margin-top: 1.8rem;
        max-width: 56ch;
        font-size: 1.02rem;
        color: var(--muted);
    }

    .v-hero-cta { margin-top: 2.4rem; }

    /* Evidence bar — hairline ledger, not floating stat cards */
    .v-data-bar {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        border-top: 1px solid var(--hairline);
    }

    .v-datum {
        padding: 1.5rem 2rem;
        border-right: 1px solid var(--hairline);
        font-family: var(--mono);
    }
    .v-datum:last-child { border-right: none; }

    .v-d-val {
        display: block;
        font-size: 1.35rem;
        font-weight: 500;
        color: var(--bone);
        letter-spacing: 0.01em;
        font-variant-numeric: tabular-nums;
    }
    .v-d-val.gold { color: var(--gold); }

    .v-d-cap {
        display: block;
        margin-top: 0.35rem;
        font-size: 0.58rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--dim);
    }

    /* ── MODEL STRIP — the deal, in one hairline row ── */
    .v-model-strip {
        display: flex;
        align-items: center;
        gap: 0;
        background: var(--ink-panel);
        border-bottom: 1px solid var(--hairline);
        max-width: none;
        padding: 0 2rem;
    }

    .v-strip-item {
        flex: 1;
        display: flex;
        align-items: baseline;
        gap: 1rem;
        padding: 1.6rem 1.5rem;
    }

    .v-strip-num {
        font-family: var(--mono);
        font-size: 0.62rem;
        font-weight: 500;
        letter-spacing: 0.18em;
        color: var(--gold);
    }

    .v-strip-text {
        font-family: var(--mono);
        font-size: 0.68rem;
        font-weight: 500;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--bone);
    }

    .v-strip-arrow {
        font-family: var(--mono);
        color: var(--dim);
        flex-shrink: 0;
    }

    /* ── ABOUT (PAPER) ── */
    .v-about-grid {
        display: grid;
        grid-template-columns: minmax(0, 6fr) minmax(0, 4fr);
        gap: 4.5rem;
        align-items: start;
    }

    .v-about-text h2 { margin-bottom: 1.4rem; }
    .v-about-text p { margin-bottom: 1rem; }

    /* Term-sheet panel — hairline-ruled, paper */
    .v-terms {
        border: 1px solid var(--hairline-paper);
        padding: 1.6rem 1.8rem 0.4rem;
    }

    .v-terms-head {
        display: flex;
        justify-content: space-between;
        font-family: var(--mono);
        font-size: 0.58rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--text-medium);
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--hairline-paper);
    }

    .v-term-row {
        display: grid;
        grid-template-columns: 48px minmax(0, 1fr);
        gap: 1.2rem;
        padding: 1.4rem 0;
        border-bottom: 1px solid var(--hairline-paper);
    }
    .v-term-row:last-child { border-bottom: none; }

    .v-term-clause {
        font-family: var(--serif);
        font-style: italic;
        font-size: 1.1rem;
        color: var(--gold);
        line-height: 1.3;
    }

    .v-term-body h4 {
        color: var(--deep-navy);
        margin-bottom: 0.4rem;
    }

    .v-term-body p {
        font-size: 0.9rem;
        line-height: 1.6;
    }

    /* ── OFFER LEDGER (INK) ── */
    .v-offer { background: var(--ink); }

    .v-offer-ledger {
        border-top: 1px solid var(--hairline);
    }

    .v-offer-row {
        display: grid;
        grid-template-columns: 72px minmax(0, 1fr);
        gap: 2rem;
        align-items: baseline;
        padding: 1.9rem 0.5rem;
        border-bottom: 1px solid var(--hairline);
        transition: background var(--t-short);
    }
    .v-offer-row:hover { background: var(--ink-panel); }

    .vo-num {
        font-family: var(--mono);
        font-size: 0.68rem;
        font-weight: 500;
        letter-spacing: 0.18em;
        color: var(--gold);
        font-variant-numeric: tabular-nums;
    }

    .vo-body h3 { font-size: 1.2rem; margin-bottom: 0.4rem; }
    .vo-body p { font-size: 0.92rem; line-height: 1.65; color: var(--muted); max-width: 66ch; }

    /* ── CRITERIA GRID (PANEL) ── */
    .v-criteria-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        border: 1px solid var(--hairline);
    }

    .v-crit-cell {
        padding: 2rem 1.8rem 2.2rem;
        border-right: 1px solid var(--hairline);
        background: var(--ink);
        transition: background var(--t-short);
    }
    .v-crit-cell:last-child { border-right: none; }
    .v-crit-cell:hover { background: var(--ink-panel); }

    .v-crit-num {
        display: block;
        font-family: var(--mono);
        font-size: 0.62rem;
        font-weight: 500;
        letter-spacing: 0.18em;
        color: var(--gold);
        margin-bottom: 1rem;
    }

    .v-crit-cell h4 {
        color: var(--bone);
        margin-bottom: 0.6rem;
    }

    .v-crit-cell p {
        font-size: 0.88rem;
        line-height: 1.6;
        color: var(--muted);
    }

    /* ── WHY (INK) ── */
    .v-why { background: var(--ink); }

    .v-why-columns {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 3rem;
        max-width: 960px;
        border-top: 1px solid var(--hairline);
        padding-top: 2.4rem;
    }

    .v-why-col p {
        font-size: 1rem;
        line-height: 1.75;
        color: var(--muted);
    }

    .v-why-emphasis {
        margin-top: 2.4rem;
        font-size: 1.4rem;
    }

    /* ── APPLY (PANEL) ── */
    .v-apply-route {
        display: block;
        margin-bottom: 2rem;
    }

    .v-apply h2 { margin-bottom: 1.2rem; }

    .v-apply-lede {
        max-width: 58ch;
        margin-bottom: 2.2rem;
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 992px) {
        .v-about-grid { grid-template-columns: 1fr; gap: 3rem; }
        .v-criteria-grid { grid-template-columns: repeat(2, 1fr); }
        .v-crit-cell:nth-child(2) { border-right: none; }
        .v-crit-cell:nth-child(-n+2) { border-bottom: 1px solid var(--hairline); }
        .v-why-columns { grid-template-columns: 1fr; gap: 1.5rem; }
    }

    @media (max-width: 768px) {
        .v-hero-inner { padding: 4.5rem 2rem 3.5rem; }
        .v-data-bar { grid-template-columns: 1fr; }
        .v-datum { border-right: none; border-bottom: 1px solid var(--hairline); }
        .v-datum:last-child { border-bottom: none; }
        .v-model-strip { flex-direction: column; align-items: stretch; padding: 0; }
        .v-strip-item { padding: 1.2rem 2rem; border-bottom: 1px solid var(--hairline); }
        .v-strip-item:last-child { border-bottom: none; }
        .v-strip-arrow { display: none; }
        .v-offer-row { grid-template-columns: 48px minmax(0, 1fr); gap: 1.2rem; }
        .v-criteria-grid { grid-template-columns: 1fr; }
        .v-crit-cell { border-right: none; border-bottom: 1px solid var(--hairline); }
        .v-crit-cell:last-child { border-bottom: none; }
    }
</style>
