---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTASection from '../../components/CTASection.astro';
---

<BaseLayout title="Bridger | Levenhall" description="Bridger is Levenhall's pre-RFP intelligence platform for US federal contracting — built first for allied technology firms.">

    <!-- ── HERO ── -->
    <section class="b-hero">
        <div class="b-hero-bg"></div>
        <div class="b-hero-inner">
            <p class="b-tag">A Levenhall Product</p>
            <img src="/images/products/bridger-logo-cropped.jpg" alt="Bridger" class="b-logo">
            <p class="b-tagline">Market Entry Intelligence for US Federal Contracting</p>
            <div class="b-rule"></div>
            <p class="b-desc">A pre-RFP intelligence platform with a marketplace and capture workflow built on top. Built first for allied technology firms entering the US federal market.</p>
            <div class="b-cta">
                <a href="https://bridger.levenhall.com" class="btn btn-gold" target="_blank" rel="noopener noreferrer">Open Bridger</a>
                <a href="https://bridger.levenhall.com/brief" class="btn btn-outline-white" target="_blank" rel="noopener noreferrer">Daily Brief</a>
            </div>
        </div>
    </section>

    <!-- ── STAT STRIP ── -->
    <section class="b-stats-section">
        <div class="container">
            <div class="b-stats reveal">
                <div class="b-stat">
                    <span class="b-stat-val">$750B</span>
                    <span class="b-stat-lbl">Annual US Federal Procurement</span>
                </div>
                <div class="b-stat">
                    <span class="b-stat-val">6&ndash;12mo</span>
                    <span class="b-stat-lbl">Lead Time Before the RFP</span>
                </div>
                <div class="b-stat">
                    <span class="b-stat-val">2,300+</span>
                    <span class="b-stat-lbl">Signals Indexed Each Week</span>
                </div>
                <div class="b-stat">
                    <span class="b-stat-val">1,400+</span>
                    <span class="b-stat-lbl">Allied Firms in the Network</span>
                </div>
            </div>
        </div>
    </section>

    <!-- ── PROBLEM ── -->
    <section class="b-section b-problem">
        <div class="container">
            <div class="b-narrow reveal">
                <span class="b-label">The Problem</span>
                <h2>Federal procurement runs on signal that doesn't live on SAM.gov.</h2>
                <div class="b-gold-rule"></div>
                <p>Appropriations bills, agency forecasts, committee markups, GAO protests, OFAC updates &mdash; these move months before the RFP and decide who wins. Incumbents pay $50K a year for that signal. Everyone else sees the RFP on SAM.gov and competes blind.</p>
                <p>For allied firms it's worse. They arrive cold into a regulatory landscape they don't speak &mdash; ITAR, FOCI, CFIUS, DSGL, DISP &mdash; and the partners who could shorten the path are invisible without a local network.</p>
            </div>
        </div>
    </section>

    <!-- ── THE STACK (DARK) ── -->
    <section class="b-section b-stack" id="stack">
        <div class="b-dark-bg"></div>
        <div class="container" style="position: relative; z-index: 1;">
            <div class="b-header reveal">
                <span class="b-dark-label">What Bridger Is</span>
                <h2>Three Layers. One Data Spine.</h2>
            </div>
            <div class="b-stack-grid reveal">
                <div class="b-stack-card">
                    <span class="b-stack-num">01</span>
                    <span class="b-stack-tag">The Spine</span>
                    <h3>Intelligence</h3>
                    <p>2,300+ procurement signals indexed each week from SAM.gov, FPDS, GAO, OFAC, Congress, agency forecasts, allied MoDs, and more.</p>
                    <p>LLM-clustered assessments. A Country Instability Index. Five-signal opportunity matching with cited rationales. A free daily brief at 6 AM Eastern.</p>
                </div>
                <div class="b-stack-card">
                    <span class="b-stack-num">02</span>
                    <span class="b-stack-tag">The Network</span>
                    <h3>Marketplace</h3>
                    <p>A two-sided directory of the people who close federal deals &mdash; providers, lobbyists, and 1,400+ allied tech firms across 60+ countries.</p>
                    <p>One fit-scoring engine across all three surfaces. Warm intros at the point of intent, not a separate CRM.</p>
                </div>
                <div class="b-stack-card">
                    <span class="b-stack-num">03</span>
                    <span class="b-stack-tag">The Workflow</span>
                    <h3>Capture</h3>
                    <p>Pipeline kanban, AI-generated capture briefs, capability statement, past performance, and teaming &mdash; all running off one canonical company record.</p>
                    <p>From "I'm watching" to "I'm submitted" without leaving the platform.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ── COMPLIANCE MOAT ── -->
    <section class="b-section b-moat">
        <div class="container">
            <div class="b-header reveal">
                <span class="b-label">The Allied Moat</span>
                <h2>Cross-Border Compliance, Indexed Together</h2>
                <p class="b-header-sub">No other procurement tool tracks these regimes side by side. That's what makes allied entry tractable.</p>
            </div>
            <div class="b-moat-grid reveal">
                <div class="b-moat-card">
                    <span class="b-moat-flag">🇺🇸</span>
                    <h4>ITAR &amp; AUKUS</h4>
                    <p>22 CFR §§ 121&ndash;130 with AUKUS Final Rule (§ 126.7) eligibility tracking.</p>
                </div>
                <div class="b-moat-card">
                    <span class="b-moat-flag">🇺🇸</span>
                    <h4>FOCI &amp; CFIUS</h4>
                    <p>NISPOM / DCSA mitigation flows plus 50 U.S.C. § 4565 review.</p>
                </div>
                <div class="b-moat-card">
                    <span class="b-moat-flag">🇺🇸</span>
                    <h4>ECCN &amp; BIS</h4>
                    <p>Export classification and license tracking through the BIS regime.</p>
                </div>
                <div class="b-moat-card">
                    <span class="b-moat-flag">🇦🇺</span>
                    <h4>DSGL &amp; DISP</h4>
                    <p>Australian Defence and Strategic Goods List, plus Defence Industry Security Program.</p>
                </div>
                <div class="b-moat-card">
                    <span class="b-moat-flag">🇬🇧</span>
                    <h4>UK List X</h4>
                    <p>Security Cleared status and the UK industry security framework.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ── PORTALS (DARK) ── -->
    <section class="b-section b-portals">
        <div class="b-dark-bg"></div>
        <div class="container" style="position: relative; z-index: 1;">
            <div class="b-header reveal">
                <span class="b-dark-label">Who Uses It</span>
                <h2>Three Portals. One Platform.</h2>
            </div>
            <div class="b-portals-grid reveal">
                <div class="b-portal-card">
                    <span class="b-portal-num">01</span>
                    <h3>Contractors</h3>
                    <p>Allied-entry firms and US capture-side teams. Pipeline, capture briefs, cap statements, past performance, teaming.</p>
                </div>
                <div class="b-portal-card">
                    <span class="b-portal-num">02</span>
                    <h3>Providers</h3>
                    <p>C3PAOs, proposal writers, incorporation specialists, manufacturers. Inbound leads, services, billing.</p>
                </div>
                <div class="b-portal-card">
                    <span class="b-portal-num">03</span>
                    <h3>Lobbyists</h3>
                    <p>Government-relations firms by specialty. Engagements, intel, appropriations tracking, billing.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ── DIFFERENTIATION ── -->
    <section class="b-section b-diff">
        <div class="container">
            <div class="b-header reveal">
                <span class="b-label">Why It's Different</span>
                <h2>Bridger vs. Most Procurement Tools</h2>
            </div>
            <div class="b-diff-table reveal">
                <div class="b-diff-row b-diff-head">
                    <span>Capability</span>
                    <span class="b-diff-mark">Bridger</span>
                    <span class="b-diff-other">Most tools</span>
                </div>
                <div class="b-diff-row">
                    <span class="b-diff-cap">Signal timing</span>
                    <span class="b-diff-mark">Pre-RFP signal, forecasts, appropriations</span>
                    <span class="b-diff-other">RFP listings after SAM.gov publishes</span>
                </div>
                <div class="b-diff-row">
                    <span class="b-diff-cap">Matching</span>
                    <span class="b-diff-mark">5-signal scoring with cited rationales</span>
                    <span class="b-diff-other">Keyword search</span>
                </div>
                <div class="b-diff-row">
                    <span class="b-diff-cap">Cross-border</span>
                    <span class="b-diff-mark">ITAR / FOCI / CFIUS / DSGL / DISP together</span>
                    <span class="b-diff-other">US-only</span>
                </div>
                <div class="b-diff-row">
                    <span class="b-diff-cap">Marketplace</span>
                    <span class="b-diff-mark">Warm intros inside the intelligence</span>
                    <span class="b-diff-other">Standalone directory or separate CRM</span>
                </div>
                <div class="b-diff-row">
                    <span class="b-diff-cap">Primary audience</span>
                    <span class="b-diff-mark">Allied technology firms entering the US</span>
                    <span class="b-diff-other">US-only contractors</span>
                </div>
            </div>
        </div>
    </section>

    <!-- ── CTA ── -->
    <CTASection
        heading="Open Bridger"
        description="Production at bridger.levenhall.com. Free daily brief at 6 AM Eastern. Scout tier is free."
        primaryLabel="Open Bridger"
        primaryHref="https://bridger.levenhall.com"
        secondaryLabel="Daily Brief"
        secondaryHref="https://bridger.levenhall.com/brief"
    />

</BaseLayout>

<style>
    /* ── HERO ── */
    .b-hero {
        background: linear-gradient(160deg, #060c18 0%, #0c1628 40%, #0a1224 100%);
        padding: 9rem 2rem 5.5rem;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

    .b-hero-bg {
        position: absolute;
        inset: 0;
        background-image:
            radial-gradient(ellipse at 50% 80%, rgba(201, 169, 97, 0.06) 0%, transparent 55%);
        pointer-events: none;
    }

    .b-hero::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: linear-gradient(90deg, transparent, var(--gold), transparent);
        opacity: 0.45;
    }

    .b-hero-inner {
        max-width: 680px;
        margin: 0 auto;
        position: relative;
        z-index: 1;
    }

    .b-tag {
        display: inline-block;
        font-family: 'Source Sans Pro', sans-serif;
        font-weight: 600;
        font-size: 0.68rem;
        letter-spacing: 3.5px;
        text-transform: uppercase;
        color: var(--gold);
        background: rgba(201, 169, 97, 0.08);
        border: 1px solid rgba(201, 169, 97, 0.18);
        padding: 0.5rem 1.4rem;
        margin-bottom: 2rem;
    }

    .b-logo {
        max-width: 380px;
        width: 100%;
        height: auto;
        display: block;
        margin: 0 auto 1.8rem;
    }

    .b-tagline {
        font-family: 'Source Sans Pro', sans-serif;
        font-size: 0.78rem;
        font-weight: 600;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: var(--gold);
        margin-bottom: 1.6rem;
    }

    .b-rule {
        width: 50px;
        height: 2px;
        background: var(--gold);
        margin: 0 auto 1.6rem;
    }

    .b-desc {
        font-size: 1.08rem;
        color: rgba(255, 255, 255, 0.65);
        line-height: 1.8;
        margin: 0 auto 2.2rem;
        max-width: 560px;
    }

    .b-cta {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
    }

    /* ── STATS STRIP ── */
    .b-stats-section {
        background: var(--cream);
        padding: 3.5rem 0;
    }

    .b-stats {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 0;
        max-width: 1100px;
        margin: 0 auto;
        background: #fff;
        border: 1px solid var(--border-warm);
        border-top: 3px solid var(--gold);
    }

    .b-stat {
        padding: 2rem 1.4rem;
        text-align: center;
        border-right: 1px solid var(--border-warm);
    }

    .b-stat:last-child {
        border-right: none;
    }

    .b-stat-val {
        display: block;
        font-family: 'Crimson Text', serif;
        font-size: 2.4rem;
        font-weight: 700;
        color: var(--deep-navy);
        line-height: 1;
        margin-bottom: 0.6rem;
    }

    .b-stat-lbl {
        display: block;
        font-family: 'Source Sans Pro', sans-serif;
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 1.4px;
        text-transform: uppercase;
        color: var(--text-medium);
        line-height: 1.45;
    }

    /* ── SHARED SECTION ── */
    .b-section {
        padding: 5.5rem 0;
    }

    .b-label {
        display: inline-block;
        font-family: 'Source Sans Pro', sans-serif;
        font-weight: 600;
        font-size: 0.68rem;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: var(--burgundy);
        background: var(--burgundy-surface);
        padding: 0.5rem 1.2rem;
        margin-bottom: 1.2rem;
    }

    .b-dark-label {
        display: inline-block;
        font-family: 'Source Sans Pro', sans-serif;
        font-weight: 600;
        font-size: 0.72rem;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: var(--gold);
        background: rgba(201, 169, 97, 0.08);
        border: 1px solid rgba(201, 169, 97, 0.15);
        padding: 0.5rem 1.2rem;
        margin-bottom: 1.2rem;
    }

    .b-gold-rule {
        width: 50px;
        height: 2px;
        background: var(--gold);
        margin-bottom: 1.5rem;
    }

    .b-header {
        max-width: 720px;
        margin: 0 auto 3rem;
        text-align: center;
    }

    .b-header h2 {
        margin-bottom: 0.8rem;
    }

    .b-header-sub {
        font-size: 1.02rem;
        line-height: 1.75;
        color: var(--text-medium);
    }

    .b-narrow {
        max-width: 720px;
        margin: 0 auto;
        text-align: center;
    }

    .b-narrow h2 {
        color: var(--deep-navy);
        margin-bottom: 1.2rem;
        font-size: clamp(1.7rem, 3.2vw, 2.3rem);
        line-height: 1.25;
    }

    .b-narrow .b-gold-rule {
        margin-left: auto;
        margin-right: auto;
    }

    .b-narrow p {
        font-size: 1.05rem;
        line-height: 1.8;
        color: var(--text-medium);
        margin-bottom: 1rem;
    }

    /* ── DARK SECTIONS ── */
    .b-stack,
    .b-portals {
        background: linear-gradient(135deg, #0a1628 0%, var(--navy) 50%, #162d4f 100%);
        position: relative;
        overflow: hidden;
    }

    .b-dark-bg {
        position: absolute;
        inset: 0;
        background-image: radial-gradient(ellipse at 50% 80%, rgba(201, 169, 97, 0.05) 0%, transparent 50%);
        pointer-events: none;
    }

    .b-stack::before,
    .b-portals::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: linear-gradient(90deg, transparent, var(--gold), transparent);
        opacity: 0.4;
    }

    .b-stack h2,
    .b-portals h2 { color: #fff; }
    .b-stack .b-header-sub,
    .b-portals .b-header-sub { color: rgba(255, 255, 255, 0.55); }

    /* ── THE STACK ── */
    .b-stack-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        grid-auto-rows: 1fr;
        gap: 1.2rem;
        max-width: 1100px;
        margin: 0 auto;
    }

    .b-stack-card {
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-top: 3px solid var(--gold);
        padding: 2rem 1.8rem;
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
        transition: all 0.3s ease;
    }

    .b-stack-card:hover {
        background: rgba(255, 255, 255, 0.07);
        transform: translateY(-3px);
        box-shadow: 0 14px 40px rgba(0, 0, 0, 0.25);
    }

    .b-stack-num {
        font-family: 'Crimson Text', serif;
        font-size: 1.3rem;
        font-weight: 700;
        color: var(--gold);
        opacity: 0.5;
        line-height: 1;
    }

    .b-stack-tag {
        font-family: 'Source Sans Pro', sans-serif;
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 2.5px;
        text-transform: uppercase;
        color: var(--gold);
    }

    .b-stack-card h3 {
        font-size: 1.5rem;
        color: #fff;
        margin: 0.2rem 0 0.6rem;
    }

    .b-stack-card p {
        font-size: 0.94rem;
        line-height: 1.7;
        color: rgba(255, 255, 255, 0.6);
        margin: 0;
    }

    /* ── COMPLIANCE MOAT ── */
    .b-moat {
        background: var(--stone);
    }

    .b-moat h2 {
        color: var(--deep-navy);
    }

    .b-moat-grid {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        grid-auto-rows: 1fr;
        gap: 1rem;
        max-width: 1100px;
        margin: 0 auto;
    }

    .b-moat-card {
        background: #fff;
        border: 1px solid var(--border-warm);
        border-top: 3px solid var(--gold);
        padding: 1.6rem 1.4rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        text-align: left;
        transition: all 0.3s ease;
    }

    .b-moat-card:hover {
        transform: translateY(-3px);
        box-shadow: var(--shadow-warm-md);
    }

    .b-moat-flag {
        font-size: 1.8rem;
        line-height: 1;
        margin-bottom: 0.4rem;
    }

    .b-moat-card h4 {
        font-family: 'Source Sans Pro', sans-serif;
        font-size: 0.92rem;
        font-weight: 700;
        color: var(--deep-navy);
        margin: 0;
        letter-spacing: 0.5px;
    }

    .b-moat-card p {
        font-size: 0.84rem;
        line-height: 1.55;
        color: var(--text-medium);
        margin: 0;
    }

    /* ── PORTALS ── */
    .b-portals-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        grid-auto-rows: 1fr;
        gap: 1.2rem;
        max-width: 1000px;
        margin: 0 auto;
    }

    .b-portal-card {
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-left: 3px solid var(--gold);
        padding: 1.8rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        transition: all 0.3s ease;
    }

    .b-portal-card:hover {
        background: rgba(255, 255, 255, 0.07);
        transform: translateY(-3px);
    }

    .b-portal-num {
        font-family: 'Crimson Text', serif;
        font-size: 1.3rem;
        font-weight: 700;
        color: var(--gold);
        opacity: 0.5;
        line-height: 1;
    }

    .b-portal-card h3 {
        font-size: 1.3rem;
        color: #fff;
        margin: 0.2rem 0 0.4rem;
    }

    .b-portal-card p {
        font-size: 0.94rem;
        line-height: 1.7;
        color: rgba(255, 255, 255, 0.6);
        margin: 0;
    }

    /* ── DIFFERENTIATION ── */
    .b-diff {
        background: var(--cream);
    }

    .b-diff h2 {
        color: var(--deep-navy);
    }

    .b-diff-table {
        max-width: 1000px;
        margin: 0 auto;
        background: #fff;
        border: 1px solid var(--border-warm);
        border-top: 3px solid var(--gold);
    }

    .b-diff-row {
        display: grid;
        grid-template-columns: 0.8fr 1.4fr 1fr;
        gap: 1.5rem;
        padding: 1.1rem 1.5rem;
        border-bottom: 1px solid var(--border-warm);
        align-items: center;
        font-size: 0.95rem;
        line-height: 1.55;
    }

    .b-diff-row:last-child {
        border-bottom: none;
    }

    .b-diff-head {
        background: var(--stone);
        font-family: 'Source Sans Pro', sans-serif;
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 2px;
        text-transform: uppercase;
    }

    .b-diff-head span:first-child { color: var(--text-medium); }
    .b-diff-head .b-diff-mark { color: var(--burgundy); }
    .b-diff-head .b-diff-other { color: var(--text-medium); }

    .b-diff-cap {
        font-weight: 600;
        color: var(--deep-navy);
    }

    .b-diff-mark {
        color: var(--deep-navy);
    }

    .b-diff-other {
        color: var(--text-medium);
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 1100px) {
        .b-moat-grid { grid-template-columns: repeat(3, 1fr); }
    }

    @media (max-width: 992px) {
        .b-stats { grid-template-columns: repeat(2, 1fr); }
        .b-stat { border-right: none; border-bottom: 1px solid var(--border-warm); }
        .b-stat:nth-child(2) { border-right: 1px solid var(--border-warm); }
        .b-stat:nth-child(odd) { border-right: 1px solid var(--border-warm); }
        .b-stack-grid { grid-template-columns: 1fr; }
        .b-portals-grid { grid-template-columns: 1fr; max-width: 480px; }
    }

    @media (max-width: 768px) {
        .b-hero { padding: 7rem 2rem 4rem; }
        .b-logo { max-width: 280px; }
        .b-stats { grid-template-columns: 1fr; }
        .b-stat { border-right: none !important; }
        .b-moat-grid { grid-template-columns: 1fr; max-width: 420px; margin: 0 auto; }
        .b-diff-row { grid-template-columns: 1fr; gap: 0.4rem; padding: 1rem 1.2rem; }
        .b-diff-head { display: none; }
        .b-diff-cap { font-size: 0.72rem; letter-spacing: 1.5px; text-transform: uppercase; color: var(--burgundy); }
    }
</style>
