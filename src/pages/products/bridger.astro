---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTASection from '../../components/CTASection.astro';
---

<BaseLayout title="Bridger | Levenhall" description="Bridger is Levenhall's market entry intelligence platform for US federal contracting — pre-RFP signal, opportunity scoring, primes, partners, and a capture workflow, built first for allied technology firms.">

    <!-- ── HERO ── -->
    <section class="bridger-hero">
        <div class="hero-bg"></div>
        <div class="hero-inner">
            <p class="bridger-product-tag">A Levenhall Product</p>
            <img src="/images/products/bridger-logo-cropped.jpg" alt="Bridger by Levenhall" class="bridger-logo">
            <p class="hero-tagline">Market Entry Intelligence for US Federal Contracting</p>
            <div class="hero-rule"></div>
            <p class="hero-description">A pre-RFP intelligence platform &mdash; appropriations signal, opportunity scoring, primes, partners &mdash; with a marketplace and capture workflow built on top. Built first for allied technology firms entering the US federal market (AUKUS, Five Eyes, NATO), and for US contractors capturing federal work.</p>
            <div class="hero-cta">
                <a href="https://bridger.levenhall.com" class="btn btn-gold" target="_blank" rel="noopener noreferrer">Open Bridger</a>
                <a href="https://bridger.levenhall.com/brief" class="btn btn-outline-white" target="_blank" rel="noopener noreferrer">Read the Daily Brief</a>
            </div>
        </div>
    </section>

    <!-- ── PROBLEM (LIGHT) ── -->
    <section class="section problem-section">
        <div class="container">
            <div class="problem-grid reveal">
                <div class="problem-text">
                    <span class="section-label">The Problem</span>
                    <h2>Federal Procurement Runs on Signal That Doesn't Live on SAM.gov</h2>
                    <div class="gold-rule"></div>
                    <p>The US federal procurement market is $750B a year, and almost all of it operates on signal that publishes <em>outside</em> SAM.gov. Appropriations bills, agency forecasts, committee markups, GAO bid protests, OFAC entity-list updates, allied-nation defense reorganizations, FOCI and CFIUS adjudications &mdash; these move 6 to 12 months before the RFP and decide who wins.</p>
                    <p>Incumbents have $50K-a-year intel subscriptions, ex-government bizdev staff, and lobbyist relationships. Everyone else sees the RFP on SAM.gov and competes blind.</p>
                    <p>For allied technology firms the problem is worse. They arrive cold into a regulatory landscape they don't speak &mdash; ITAR, FOCI, CFIUS, DSGL, DISP &mdash; and the partners who could shorten the entry path are illegible without a local network.</p>
                </div>
                <div class="problem-stats">
                    <div class="problem-stat">
                        <span class="problem-stat-value">$750B</span>
                        <span class="problem-stat-label">Annual US federal procurement</span>
                    </div>
                    <div class="problem-stat">
                        <span class="problem-stat-value">6&ndash;12<span class="unit">mo</span></span>
                        <span class="problem-stat-label">Signal lead time before the RFP</span>
                    </div>
                    <div class="problem-stat">
                        <span class="problem-stat-value">2,300+</span>
                        <span class="problem-stat-label">Signals indexed each week</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ── THREE LAYERS (DARK) ── -->
    <section class="section layers-section">
        <div class="layers-bg"></div>
        <div class="container" style="position: relative; z-index: 1;">
            <div class="section-header reveal">
                <span class="dark-label">What Bridger Is</span>
                <h2>Three Layers, One Data Spine</h2>
                <p>Intelligence first. Marketplace second. Capture workflow on top.</p>
            </div>
            <div class="layers-grid">
                <div class="layer-card reveal">
                    <div class="layer-head">
                        <span class="layer-num">01</span>
                        <span class="layer-tag">The Spine</span>
                    </div>
                    <h3>Intelligence</h3>
                    <p class="layer-lead">SAM.gov, FPDS, GAO, OFAC, Congress.gov, agency forecasts, CISA, NIST, GDELT, allied defense MoDs, ReliefWeb, USGS, FIRMS, OpenSky, ACLED, Polymarket, Federal Register, executive orders, congressional hearings &mdash; 2,300+ procurement-relevant signals indexed every week.</p>
                    <ul class="layer-list">
                        <li><strong>Editorial Assessments.</strong> Claude Haiku 4.5 clusters raw signals into situation reports, CII deltas, forecasts, and briefs. Confidence-rated, source-cited, country-tagged. ~1,080 assessments in the index.</li>
                        <li><strong>Country Instability Index.</strong> A custom composite per country, driving risk overlays on the opportunity panel and the allied-supplier directory.</li>
                        <li><strong>Opportunity Matching.</strong> Every new opportunity is scored against the user's profile across five signals (NAICS overlap, tech-keyword overlap, certifications vs. set-aside, agency history, past-performance keywords). LLM-generated rationale must cite at least two signals that actually fired.</li>
                        <li><strong>Daily Brief.</strong> Free, public, 6 AM Eastern.</li>
                    </ul>
                </div>
                <div class="layer-card reveal">
                    <div class="layer-head">
                        <span class="layer-num">02</span>
                        <span class="layer-tag">The Network</span>
                    </div>
                    <h3>Marketplace</h3>
                    <p class="layer-lead">A two-sided directory of the people who close federal deals. All three search surfaces share the same fit-scoring engine &mdash; same algorithm, per-entity filter chips.</p>
                    <div class="marketplace-table">
                        <div class="marketplace-row marketplace-head-row">
                            <span>Surface</span>
                            <span>Who's listed</span>
                            <span>Mechanics</span>
                        </div>
                        <div class="marketplace-row">
                            <span class="m-surface">Provider Search</span>
                            <span class="m-cell">C3PAOs, proposal writers, US incorporation specialists, 8(a) JV partners, contract manufacturers, channel sales firms</span>
                            <span class="m-cell">Fit-ranked, Stripe Connect lead routing, 10% provider commission</span>
                        </div>
                        <div class="marketplace-row">
                            <span class="m-surface">Lobbyist Search</span>
                            <span class="m-cell">Government-relations firms by specialty: appropriations, defense policy, technology policy, trade</span>
                            <span class="m-cell">Fit-ranked engagements, warm intros, 15% platform fee</span>
                        </div>
                        <div class="marketplace-row">
                            <span class="m-surface">Tech Scout</span>
                            <span class="m-cell">1,400+ allied-defense-tech firms across 60+ countries (AUKUS, Five Eyes, NATO)</span>
                            <span class="m-cell">Provider-side outreach, cross-border vendor discovery</span>
                        </div>
                    </div>
                </div>
                <div class="layer-card reveal">
                    <div class="layer-head">
                        <span class="layer-num">03</span>
                        <span class="layer-tag">The Workflow</span>
                    </div>
                    <h3>Capture</h3>
                    <p class="layer-lead">When a contractor moves from "I'm watching" to "I'm pursuing", the workflow takes over.</p>
                    <ul class="layer-list">
                        <li><strong>Pipeline.</strong> Drag-and-drop kanban &mdash; Identified, Qualified, Capture, Proposal, Submitted &mdash; with optimistic mutations and rollback.</li>
                        <li><strong>Capture Brief.</strong> AI-generated bid/no-bid analysis pulling from the opportunity, the company's profile, and the match intelligence.</li>
                        <li><strong>Capability Statement.</strong> Auto-fills from a canonical CompanyMasterData entity &mdash; single source of truth across profile, past performance, and cap statement.</li>
                        <li><strong>Past Performance.</strong> Structured contract records that auto-sync into the profile summary feeding the match scorer.</li>
                        <li><strong>Engagements.</strong> Provider leads and lobbyist engagements, both linked back to active opportunities.</li>
                        <li><strong>Teaming &amp; Subcontracting.</strong> Four-signal match (complementary NAICS, size-standard pair, shared agency, complementary tech). Subcontracting auto-detects role and shows the opposite side.</li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- ── COMPLIANCE MOAT (LIGHT) ── -->
    <section class="section moat-section">
        <div class="container">
            <div class="moat-grid reveal">
                <div class="moat-text">
                    <span class="section-label">Cross-Border Compliance Moat</span>
                    <h2>The Layer Nobody Else Indexes</h2>
                    <div class="gold-rule"></div>
                    <p>Allied entry is regulated by a stack of overlapping regimes &mdash; US, UK, Australia, NATO &mdash; that no general procurement tool tracks together. Bridger does.</p>
                    <p>This is the layer that makes allied entry tractable. It is also the structural reason "built first for allied technology firms" leads every audience-facing surface.</p>
                </div>
                <div class="moat-list">
                    <div class="moat-item">
                        <span class="moat-tag">US</span>
                        <div class="moat-body">
                            <span class="moat-name">ITAR · 22 CFR §§ 121&ndash;130</span>
                            <span class="moat-detail">AUKUS Final Rule (§ 126.7) eligibility tracking</span>
                        </div>
                    </div>
                    <div class="moat-item">
                        <span class="moat-tag">US</span>
                        <div class="moat-body">
                            <span class="moat-name">FOCI Mitigation</span>
                            <span class="moat-detail">NISPOM / DCSA</span>
                        </div>
                    </div>
                    <div class="moat-item">
                        <span class="moat-tag">US</span>
                        <div class="moat-body">
                            <span class="moat-name">CFIUS Review</span>
                            <span class="moat-detail">50 U.S.C. § 4565</span>
                        </div>
                    </div>
                    <div class="moat-item">
                        <span class="moat-tag">US</span>
                        <div class="moat-body">
                            <span class="moat-name">ECCN &amp; BIS Licenses</span>
                            <span class="moat-detail">Classification &amp; license tracking</span>
                        </div>
                    </div>
                    <div class="moat-item">
                        <span class="moat-tag">AU</span>
                        <div class="moat-body">
                            <span class="moat-name">DSGL</span>
                            <span class="moat-detail">Australian Defence and Strategic Goods List</span>
                        </div>
                    </div>
                    <div class="moat-item">
                        <span class="moat-tag">AU</span>
                        <div class="moat-body">
                            <span class="moat-name">DISP</span>
                            <span class="moat-detail">Defence Industry Security Program</span>
                        </div>
                    </div>
                    <div class="moat-item">
                        <span class="moat-tag">UK</span>
                        <div class="moat-body">
                            <span class="moat-name">Security Cleared / List X</span>
                            <span class="moat-detail">UK industry security framework</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ── AUDIENCES (DARK) ── -->
    <section class="section audiences-section">
        <div class="audiences-bg"></div>
        <div class="container" style="position: relative; z-index: 1;">
            <div class="section-header reveal">
                <span class="dark-label">Who Uses It</span>
                <h2>Three Portals, One Platform</h2>
                <p>Each portal has its own auth subsystem and onboarding wizard. They share the same intelligence stack.</p>
            </div>
            <div class="audiences-grid">
                <div class="audience-card reveal">
                    <span class="audience-num">01</span>
                    <h3>Contractors</h3>
                    <p>Allied-entry firms (priority track) and US capture-side contractors. Pipeline, capture briefs, cap statements, past performance, teaming, and the full intelligence layer.</p>
                    <span class="audience-meta">~50 product surfaces</span>
                </div>
                <div class="audience-card reveal">
                    <span class="audience-num">02</span>
                    <h3>Providers</h3>
                    <p>C3PAOs, proposal writers, incorporation specialists, manufacturers, channel sales. Inbound leads, services, pipeline, billing, plus the contractor and tech-scout directories.</p>
                    <span class="audience-meta">~25 product surfaces</span>
                </div>
                <div class="audience-card reveal">
                    <span class="audience-num">03</span>
                    <h3>Lobbyists</h3>
                    <p>Government-relations firms by specialty. Engagements, intel, appropriations, providers, contractors, billing.</p>
                    <span class="audience-meta">~20 product surfaces</span>
                </div>
            </div>
        </div>
    </section>

    <!-- ── DIFFERENTIATION (LIGHT) ── -->
    <section class="section diff-section">
        <div class="container">
            <div class="section-header reveal">
                <span class="section-label">What Differentiates Bridger</span>
                <h2>Bridger vs. Most Procurement Tools</h2>
            </div>
            <div class="diff-table reveal">
                <div class="diff-row diff-head">
                    <span class="diff-col-label">Capability</span>
                    <span class="diff-col-bridger">Bridger</span>
                    <span class="diff-col-other">Most procurement tools</span>
                </div>
                <div class="diff-row">
                    <span class="diff-col-label">Signal timing</span>
                    <span class="diff-col-bridger">Pre-RFP signal &mdash; assessments, forecasts, appropriations markups</span>
                    <span class="diff-col-other">RFP listings after SAM.gov publishes</span>
                </div>
                <div class="diff-row">
                    <span class="diff-col-label">Matching</span>
                    <span class="diff-col-bridger">5-signal scoring with cited rationales</span>
                    <span class="diff-col-other">Keyword search</span>
                </div>
                <div class="diff-row">
                    <span class="diff-col-label">Cross-border</span>
                    <span class="diff-col-bridger">ITAR / FOCI / CFIUS / DSGL / DISP indexed together</span>
                    <span class="diff-col-other">US-only</span>
                </div>
                <div class="diff-row">
                    <span class="diff-col-label">Marketplace</span>
                    <span class="diff-col-bridger">Warm intros at the point of intent, inside the intelligence</span>
                    <span class="diff-col-other">Standalone directory or separate CRM</span>
                </div>
                <div class="diff-row">
                    <span class="diff-col-label">Search</span>
                    <span class="diff-col-bridger">Shared fit-scoring engine across three surfaces</span>
                    <span class="diff-col-other">Per-surface bespoke ranking</span>
                </div>
                <div class="diff-row">
                    <span class="diff-col-label">Primary audience</span>
                    <span class="diff-col-bridger">Allied technology firms entering the US</span>
                    <span class="diff-col-other">US-only contractors</span>
                </div>
            </div>
        </div>
    </section>

    <!-- ── CTA ── -->
    <CTASection
        heading="Open Bridger"
        description="Production at bridger.levenhall.com. Free daily brief at 6 AM Eastern. Scout tier free; Pathfinder, Pathfinder Pro, and Enterprise unlock proposal-tier reasoning and the full intelligence stack."
        primaryLabel="Open Bridger"
        primaryHref="https://bridger.levenhall.com"
        secondaryLabel="Daily Brief"
        secondaryHref="https://bridger.levenhall.com/brief"
    />

</BaseLayout>

<style>
    /* ── HERO ── */
    .bridger-hero {
        background: #090f1d;
        padding: 10rem 2rem 5.5rem;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

    .hero-bg {
        position: absolute;
        inset: 0;
        background-image:
            radial-gradient(ellipse at 50% 80%, rgba(201, 169, 97, 0.03) 0%, transparent 50%);
        pointer-events: none;
    }

    .bridger-hero::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: linear-gradient(90deg, transparent 0%, var(--gold) 50%, transparent 100%);
        opacity: 0.4;
    }

    .hero-inner {
        max-width: 760px;
        margin: 0 auto;
        position: relative;
        z-index: 1;
    }

    .bridger-product-tag {
        display: inline-block;
        font-family: 'Source Sans Pro', sans-serif;
        font-weight: 600;
        font-size: 0.68rem;
        letter-spacing: 3.5px;
        text-transform: uppercase;
        color: var(--gold);
        background: rgba(201, 169, 97, 0.08);
        border: 1px solid rgba(201, 169, 97, 0.15);
        padding: 0.5rem 1.4rem;
        margin-bottom: 1.8rem;
    }

    .bridger-logo {
        max-width: 420px;
        width: 100%;
        height: auto;
        display: block;
        margin: 0 auto 2rem;
    }

    .hero-tagline {
        font-family: 'Source Sans Pro', sans-serif;
        font-size: 0.78rem;
        font-weight: 600;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: var(--gold);
        margin-bottom: 1.8rem;
    }

    .hero-rule {
        width: 50px;
        height: 2px;
        background: var(--gold);
        margin: 0 auto 1.8rem;
    }

    .hero-description {
        font-size: 1.1rem;
        color: rgba(255, 255, 255, 0.6);
        line-height: 1.85;
        margin: 0 auto 2.5rem;
        max-width: 620px;
    }

    .hero-cta {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
    }

    /* ── SHARED ── */
    .section-label {
        display: inline-block;
        font-family: 'Source Sans Pro', sans-serif;
        font-weight: 600;
        font-size: 0.68rem;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: var(--burgundy);
        background: var(--burgundy-surface);
        padding: 0.5rem 1.2rem;
        margin-bottom: 1.2rem;
    }

    .dark-label {
        display: inline-block;
        font-family: 'Source Sans Pro', sans-serif;
        font-weight: 600;
        font-size: 0.72rem;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: var(--gold);
        background: rgba(201, 169, 97, 0.08);
        padding: 0.5rem 1.2rem;
        margin-bottom: 1.2rem;
    }

    .gold-rule {
        width: 50px;
        height: 2px;
        background: var(--gold);
        margin-bottom: 1.5rem;
    }

    .section-header {
        text-align: center;
        max-width: 720px;
        margin: 0 auto 3rem;
    }

    .section-header h2 {
        margin-bottom: 0.8rem;
    }

    .section-header p {
        font-size: 1.02rem;
        line-height: 1.75;
    }

    /* ── PROBLEM ── */
    .problem-section {
        background: var(--cream);
        padding: 5.5rem 0;
    }

    .problem-grid {
        display: grid;
        grid-template-columns: 1.15fr 0.85fr;
        gap: 3.5rem;
        align-items: start;
    }

    .problem-text h2 {
        color: var(--deep-navy);
        margin-bottom: 1rem;
    }

    .problem-text p {
        font-size: 1.02rem;
        line-height: 1.75;
        color: var(--text-medium);
        margin-bottom: 0.9rem;
    }

    .problem-text em {
        font-style: italic;
        color: var(--burgundy);
    }

    .problem-stats {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .problem-stat {
        background: #fff;
        padding: 1.8rem 1.6rem;
        border: 1px solid var(--border-warm);
        border-left: 3px solid var(--gold);
        transition: all 0.3s ease;
    }

    .problem-stat:hover {
        transform: translateX(4px);
        box-shadow: var(--shadow-warm-md);
    }

    .problem-stat-value {
        display: block;
        font-family: 'Crimson Text', serif;
        font-size: 2.6rem;
        font-weight: 700;
        color: var(--deep-navy);
        line-height: 1;
        margin-bottom: 0.5rem;
    }

    .problem-stat-value .unit {
        font-size: 1.2rem;
        font-weight: 600;
        color: var(--gold);
        margin-left: 0.1rem;
    }

    .problem-stat-label {
        display: block;
        font-size: 0.78rem;
        font-weight: 600;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: var(--text-medium);
        line-height: 1.5;
    }

    /* ── LAYERS (DARK) ── */
    .layers-section {
        background: linear-gradient(135deg, #0a1628 0%, var(--navy) 50%, #162d4f 100%);
        padding: 6rem 0;
        position: relative;
        overflow: hidden;
    }

    .layers-bg {
        position: absolute;
        inset: 0;
        background-image:
            radial-gradient(ellipse at 50% 80%, rgba(201, 169, 97, 0.05) 0%, transparent 50%);
        pointer-events: none;
    }

    .layers-section::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: linear-gradient(90deg, transparent, var(--gold), transparent);
        opacity: 0.4;
    }

    .layers-section h2 { color: #fff; }
    .layers-section .section-header p { color: rgba(255, 255, 255, 0.55); }

    .layers-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
        max-width: 1000px;
        margin: 0 auto;
    }

    .layer-card {
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-left: 3px solid var(--gold);
        padding: 2.2rem 2.4rem;
        transition: all 0.3s ease;
    }

    .layer-card:hover {
        background: rgba(255, 255, 255, 0.06);
        box-shadow: 0 16px 40px rgba(0, 0, 0, 0.25);
    }

    .layer-head {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 0.6rem;
    }

    .layer-num {
        font-family: 'Crimson Text', serif;
        font-size: 1.4rem;
        font-weight: 700;
        color: var(--gold);
        opacity: 0.5;
        line-height: 1;
    }

    .layer-tag {
        font-family: 'Source Sans Pro', sans-serif;
        font-size: 0.68rem;
        font-weight: 600;
        letter-spacing: 2.5px;
        text-transform: uppercase;
        color: var(--gold);
    }

    .layer-card h3 {
        font-size: 1.6rem;
        color: #fff;
        margin-bottom: 1rem;
    }

    .layer-lead {
        font-size: 1rem;
        line-height: 1.75;
        color: rgba(255, 255, 255, 0.6);
        margin-bottom: 1.3rem;
    }

    .layer-list {
        list-style: none;
        margin: 0;
        padding: 0;
    }

    .layer-list li {
        font-size: 0.95rem;
        line-height: 1.7;
        color: rgba(255, 255, 255, 0.55);
        padding: 0.55rem 0 0.55rem 1.2rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        position: relative;
    }

    .layer-list li:last-child {
        border-bottom: none;
    }

    .layer-list li::before {
        content: '';
        position: absolute;
        left: 0;
        top: 1.05rem;
        width: 5px;
        height: 5px;
        background: var(--gold);
        border-radius: 50%;
    }

    .layer-list strong {
        color: #fff;
        font-weight: 600;
    }

    /* ── MARKETPLACE TABLE ── */
    .marketplace-table {
        background: rgba(0, 0, 0, 0.15);
        border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .marketplace-row {
        display: grid;
        grid-template-columns: 0.7fr 1.4fr 1fr;
        gap: 1.5rem;
        padding: 1rem 1.2rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.04);
        font-size: 0.88rem;
        line-height: 1.55;
    }

    .marketplace-row:last-child {
        border-bottom: none;
    }

    .marketplace-head-row {
        background: rgba(201, 169, 97, 0.06);
        font-family: 'Source Sans Pro', sans-serif;
        font-size: 0.68rem;
        font-weight: 700;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: var(--gold);
    }

    .m-surface {
        font-family: 'Crimson Text', serif;
        font-size: 1.02rem;
        font-weight: 700;
        color: #fff;
    }

    .m-cell {
        color: rgba(255, 255, 255, 0.55);
    }

    /* ── COMPLIANCE MOAT (LIGHT) ── */
    .moat-section {
        background: var(--stone);
        padding: 6rem 0;
    }

    .moat-grid {
        display: grid;
        grid-template-columns: 0.85fr 1.15fr;
        gap: 3.5rem;
        align-items: start;
    }

    .moat-text h2 {
        color: var(--deep-navy);
