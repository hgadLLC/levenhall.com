---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTASection from '../../components/CTASection.astro';
---

<BaseLayout title="Bridger | Levenhall" description="Bridger by Levenhall connects allied defense innovators with the U.S. national security ecosystem through curated introductions and structured deal flow.">

    <!-- ── HERO ── -->
    <section class="bridger-hero">
        <div class="hero-bg"></div>
        <div class="hero-inner">
            <img src="/images/products/bridger-logo-cropped.jpg" alt="Bridger by Levenhall" class="bridger-logo">
            <p class="hero-tagline">The allied defense dealmaking platform</p>
            <div class="hero-rule"></div>
            <p class="hero-description">Bridger connects vetted international defense firms from allied nations with U.S. government buyers, defense primes, and strategic partners. One platform. Curated introductions. Structured deal flow.</p>
            <div class="hero-cta">
                <a href="https://bridger.levenhall.com/join" class="btn btn-gold" target="_blank" rel="noopener noreferrer">Join Bridger</a>
                <a href="#how-it-works" class="btn btn-outline-white">How It Works</a>
            </div>
        </div>
    </section>

    <!-- ── HOW IT WORKS ── -->
    <section class="section value-section" id="how-it-works">
        <div class="container">
            <div class="section-header reveal">
                <span class="section-label">How It Works</span>
                <h2>From Introduction to Contract</h2>
                <p>Bridger eliminates cold outreach, conference chasing, and wasted travel. Every connection is curated. Every introduction is warm.</p>
            </div>
            <div class="steps-row">
                <div class="step-card reveal">
                    <div class="step-head">
                        <span class="step-number">01</span>
                        <div class="step-connector"></div>
                    </div>
                    <h3>Apply &amp; Get Vetted</h3>
                    <p>Submit your firm's capabilities. Levenhall validates your fit based on technology readiness, allied nation status, and procurement alignment.</p>
                </div>
                <div class="step-card reveal">
                    <div class="step-head">
                        <span class="step-number">02</span>
                        <div class="step-connector"></div>
                    </div>
                    <h3>Get Matched</h3>
                    <p>We identify the right buyers, primes, and program offices for your capability. Every introduction is targeted to an active requirement.</p>
                </div>
                <div class="step-card reveal">
                    <div class="step-head">
                        <span class="step-number">03</span>
                    </div>
                    <h3>Close Deals</h3>
                    <p>Bridger supports you through procurement navigation, teaming arrangements, and contract structuring. From CSO to OTA award.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ── WHY BRIDGER ── -->
    <section class="section features-section">
        <div class="features-bg"></div>
        <div class="container features-inner">
            <div class="features-grid">
                <div class="feature-text reveal">
                    <span class="feature-label">Built for Allied Defense Firms</span>
                    <h2>Why Bridger?</h2>
                    <div class="feature-rule"></div>
                    <p>The U.S. defense market awards over $400B annually, yet allied firms capture a fraction of their potential. The barrier isn't capability &mdash; it's access.</p>
                    <p>Bridger removes that barrier. Designed for Five Eyes and NATO-allied firms, it delivers curated, high-signal introductions backed by Levenhall's Washington, DC network. No generic matchmaking. No outdated databases.</p>
                </div>
                <div class="feature-cards reveal">
                    <div class="f-card">
                        <h4>Curated Network</h4>
                        <p>Every participant is vetted. Buyers are real. Requirements are active.</p>
                    </div>
                    <div class="f-card">
                        <h4>Warm Introductions</h4>
                        <p>Levenhall brokers every connection. No cold emails. No booth-side pitches.</p>
                    </div>
                    <div class="f-card">
                        <h4>Deal Support</h4>
                        <p>From NDA to contract award, our team supports the full lifecycle.</p>
                    </div>
                    <div class="f-card">
                        <h4>Allied Nations Only</h4>
                        <p>Restricted to firms from trusted democracies with compatible security frameworks.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ── CTA ── -->
    <CTASection
        heading="Ready to Access the U.S. Defense Market?"
        description="Join Bridger and connect with buyers, primes, and program offices actively seeking allied technology."
        primaryLabel="Join Bridger"
        primaryHref="https://bridger.levenhall.com/join"
        secondaryLabel="Contact Us"
        secondaryHref="/contact"
    />

</BaseLayout>

<style>
    /* ── HERO ── */
    .bridger-hero {
        background: #090f1d;
        padding: 10rem 2rem 5.5rem;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

    .hero-bg {
        position: absolute;
        inset: 0;
        background-image:
            radial-gradient(ellipse at 50% 80%, rgba(201, 169, 97, 0.03) 0%, transparent 50%);
        pointer-events: none;
    }

    .bridger-hero::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: linear-gradient(90deg, transparent 0%, var(--gold) 50%, transparent 100%);
        opacity: 0.4;
    }

    .hero-inner {
        max-width: 720px;
        margin: 0 auto;
        position: relative;
        z-index: 1;
    }

    /* ── Bridger logo ── */
    .bridger-logo {
        max-width: 420px;
        width: 100%;
        height: auto;
        display: block;
        margin: 0 auto 2rem;
    }

    .hero-tagline {
        font-family: 'Source Sans Pro', sans-serif;
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 3.5px;
        text-transform: uppercase;
        color: var(--gold);
        margin-bottom: 1.8rem;
    }

    .hero-rule {
        width: 50px;
        height: 2px;
        background: var(--gold);
        margin: 0 auto 1.8rem;
    }

    .hero-description {
        font-size: 1.1rem;
        color: rgba(255, 255, 255, 0.5);
        line-height: 1.85;
        margin-bottom: 2.5rem;
        max-width: 560px;
        margin-left: auto;
        margin-right: auto;
    }

    .hero-cta {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
    }

    /* ── HOW IT WORKS ── */
    .value-section {
        background: var(--cream);
        padding: 5.5rem 0;
    }

    .section-header {
        text-align: center;
        max-width: 600px;
        margin: 0 auto 3.5rem;
    }

    .section-label {
        display: inline-block;
        font-family: 'Source Sans Pro', sans-serif;
        font-weight: 600;
        font-size: 0.68rem;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: var(--burgundy);
        background: var(--burgundy-surface);
        padding: 0.5rem 1.2rem;
        margin-bottom: 1.2rem;
    }

    .section-header h2 {
        color: var(--deep-navy);
        margin-bottom: 0.8rem;
    }

    .section-header p {
        color: var(--text-medium);
        font-size: 1rem;
        line-height: 1.75;
    }

    .steps-row {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 0;
        max-width: 960px;
        margin: 0 auto;
    }

    .step-card {
        padding: 2.2rem 2rem;
        position: relative;
        border-left: 1px solid rgba(30, 58, 95, 0.08);
    }

    .step-card:first-child { border-left: none; }

    .step-head {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.2rem;
    }

    .step-number {
        font-family: 'Crimson Text', serif;
        font-size: 2.4rem;
        font-weight: 700;
        color: var(--gold);
        line-height: 1;
        flex-shrink: 0;
    }

    .step-connector {
        flex: 1;
        height: 1px;
        background: linear-gradient(90deg, var(--gold), transparent);
        opacity: 0.3;
    }

    .step-card h3 {
        font-size: 1.1rem;
        color: var(--deep-navy);
        margin-bottom: 0.7rem;
    }

    .step-card p {
        font-size: 0.9rem;
        color: var(--text-medium);
        line-height: 1.7;
    }

    /* ── FEATURES ── */
    .features-section {
        background: var(--stone);
        padding: 5.5rem 0;
        position: relative;
        overflow: hidden;
    }

    .features-bg {
        position: absolute;
        inset: 0;
        background-image: radial-gradient(ellipse at 80% 50%, rgba(201, 169, 97, 0.05) 0%, transparent 50%);
        pointer-events: none;
    }

    .features-inner { position: relative; z-index: 1; }

    .features-grid {
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        gap: 3.5rem;
        align-items: start;
    }

    .feature-label {
        display: inline-block;
        font-family: 'Source Sans Pro', sans-serif;
        font-weight: 600;
        font-size: 0.68rem;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: var(--burgundy);
        background: var(--burgundy-surface);
        padding: 0.5rem 1.2rem;
        margin-bottom: 1.2rem;
    }

    .feature-text h2 {
        color: var(--deep-navy);
        margin-bottom: 0.8rem;
    }

    .feature-rule {
        width: 40px;
        height: 2px;
        background: var(--gold);
        margin-bottom: 1.4rem;
    }

    .feature-text p {
        color: var(--text-medium);
        font-size: 0.98rem;
        line-height: 1.75;
        margin-bottom: 0.8rem;
    }

    .feature-cards {
        display: grid;
        gap: 0.8rem;
    }

    .f-card {
        background: #fff;
        padding: 1.3rem 1.5rem;
        border-left: 3px solid rgba(201, 169, 97, 0.3);
        transition: all 0.3s ease;
    }

    .f-card:hover {
        border-left-color: var(--gold);
        box-shadow: 0 8px 30px rgba(30, 58, 95, 0.08);
        transform: translateX(4px);
    }

    .f-card h4 {
        font-family: 'Source Sans Pro', sans-serif;
        font-size: 0.9rem;
        font-weight: 700;
        color: var(--deep-navy);
        margin-bottom: 0.25rem;
        letter-spacing: 0.3px;
    }

    .f-card p {
        font-size: 0.85rem;
        color: var(--text-medium);
        line-height: 1.55;
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 992px) {
        .features-grid { grid-template-columns: 1fr; }
    }

    @media (max-width: 768px) {
        .bridger-hero { padding: 8rem 2rem 4rem; }
        .bridger-logo { max-width: 320px; }
        .steps-row { grid-template-columns: 1fr; }
        .step-card { border-left: none; border-top: 1px solid rgba(30, 58, 95, 0.08); }
        .step-card:first-child { border-top: none; }
        .step-connector { display: none; }
    }
</style>
