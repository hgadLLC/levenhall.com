---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
---

<BaseLayout title="Bridger by Levenhall — Market Entry Intelligence for US Federal Contracting" description="$760B in federal contracts a year. Bridger surfaces the work before the RFP, scores it against your profile, and stands watch after — built first for allied technology firms entering the US and for US tech companies capturing federal work.">

    <PageHeader
        label="Systems / Bridger / A Levenhall Product"
        index="01"
        title="Market Entry Intelligence for US Federal Contracting."
    />

    <!-- ── CONSOLE: STATEMENT + INDEX INSTRUMENT ── -->
    <section class="console sweep-field texture-grain">
        <div class="console-grid">
            <div class="console-statement">
                <div class="brand-row">
                    <img src="/images/products/bridger-mark.png" alt="" class="brand-mark" aria-hidden="true" />
                    <span class="brand-word">Bridger</span>
                </div>
                <p class="console-lede">$760B in federal contracts a year. Bridger surfaces the work before the RFP, scores it against your profile, and stands watch after &mdash; built first for allied technology firms entering the US and for US tech companies capturing federal work.</p>
                <div class="btn-group console-cta">
                    <a href="https://bridger.levenhall.com/get-started" class="btn btn-primary" target="_blank" rel="noopener noreferrer">Request Access</a>
                    <a href="https://bridger.levenhall.com/brief" class="mono-link" target="_blank" rel="noopener noreferrer">Read Today's Intel Brief →</a>
                </div>
                <p class="console-meta">Live at <a href="https://bridger.levenhall.com" target="_blank" rel="noopener noreferrer">bridger.levenhall.com</a></p>
            </div>

            <div class="console-instrument" aria-hidden="true">
                <div class="inst-head">
                    <span>Procurement Signal / Bridger Index</span>
                    <span class="inst-live">● 40+ Live Sources</span>
                </div>
                <svg class="inst-svg" viewBox="0 0 560 320" xmlns="http://www.w3.org/2000/svg">
                    <!-- axis frame -->
                    <g class="ax">
                        <line x1="52" y1="40" x2="536" y2="40" />
                        <line x1="52" y1="100" x2="536" y2="100" />
                        <line x1="52" y1="160" x2="536" y2="160" />
                        <line x1="52" y1="220" x2="536" y2="220" />
                        <line x1="52" y1="280" x2="536" y2="280" class="ax-base" />
                        <line x1="52" y1="40" x2="52" y2="280" />
                    </g>
                    <!-- x ticks -->
                    <g class="ax">
                        <line x1="52" y1="280" x2="52" y2="286" />
                        <line x1="173" y1="280" x2="173" y2="286" />
                        <line x1="294" y1="280" x2="294" y2="286" />
                        <line x1="415" y1="280" x2="415" y2="286" />
                        <line x1="536" y1="280" x2="536" y2="286" />
                    </g>
                    <text class="ax-note" x="52" y="302">T-12MO</text>
                    <text class="ax-note" x="173" y="302">T-9</text>
                    <text class="ax-note" x="294" y="302">T-6</text>
                    <text class="ax-note" x="415" y="302">T-3</text>
                    <text class="ax-note ax-note-end" x="536" y="302">RFP</text>
                    <!-- RFP marker -->
                    <line class="rfp-line" x1="536" y1="40" x2="536" y2="280" />
                    <!-- index line -->
                    <path class="idx-area" d="M52 236 L88 228 L124 232 L160 214 L196 220 L232 198 L268 204 L304 178 L340 186 L376 156 L412 164 L448 122 L484 132 L520 84 L536 76 L536 280 L52 280 Z" />
                    <path class="idx-line" d="M52 236 L88 228 L124 232 L160 214 L196 220 L232 198 L268 204 L304 178 L340 186 L376 156 L412 164 L448 122 L484 132 L520 84 L536 76" />
                    <circle class="idx-dot" cx="536" cy="76" r="3" />
                    <!-- annotations -->
                    <text class="ann" x="52" y="28">$760B/YR INDEXED</text>
                    <text class="ann ann-dim" x="232" y="150">SIGNAL · 6–12 MO AHEAD OF THE RFP</text>
                </svg>
                <div class="inst-foot">
                    <span>Representative signal</span>
                    <span class="inst-verdict">Scored: GO / MONITOR / NO-GO</span>
                </div>
            </div>
        </div>

        <!-- Right now on Bridger — evidence bar -->
        <div class="data-bar">
            <div class="datum datum-label"><span class="d-cap d-cap-gold">Right now on Bridger</span></div>
            <div class="datum"><span class="d-val">$760<span class="d-u">B</span></span><span class="d-cap">Annual federal contracts</span></div>
            <div class="datum"><span class="d-val">2,300<span class="d-u">+</span></span><span class="d-cap">Signals indexed this week</span></div>
            <div class="datum"><span class="d-val">1,400<span class="d-u">+</span></span><span class="d-cap">Allied tech firms</span></div>
            <div class="datum"><span class="d-val">60<span class="d-u">+</span></span><span class="d-cap">Countries represented</span></div>
            <div class="datum"><span class="d-val">40<span class="d-u">+</span></span><span class="d-cap">Live sources</span></div>
        </div>
    </section>

    <!-- ── OPENING (PAPER — the one light passage) ── -->
    <section class="section section-paper">
        <div class="container">
            <div class="opening-prose">
                <span class="route-line opening-route">Bridger / Doctrine</span>
                <p class="opening-lede">Most platforms tell you what already happened. Bridger sees the work before SAM.gov publishes it.</p>
                <p>Appropriations bills, committee markups, agency forecasts, GAO bid protests, OFAC entity-list updates &mdash; the signal that decides who wins moves six to twelve months ahead of the RFP. Bridger indexes the signal, scores every opportunity against your profile, and gives a <strong class="mono-strong">GO / MONITOR / NO-GO</strong> verdict overnight.</p>
                <p>Then it stands watch: forty automated jobs a day, running while you sleep.</p>
            </div>
        </div>
    </section>

    <!-- ── WHO IT'S FOR (LEDGER) ── -->
    <section class="section">
        <div class="container">
            <div class="section-header">
                <span class="section-label">§ Who Bridger is for</span>
                <h2>Three sides. One platform.</h2>
            </div>
            <div class="ledger">
                <a href="https://bridger.levenhall.com/for-tech-companies" class="ledger-row" target="_blank" rel="noopener noreferrer">
                    <span class="lg-num">01</span>
                    <span class="lg-body">
                        <h3>Tech Companies</h3>
                        <p>Allied firms from AUKUS, Five Eyes, and NATO nations entering the US. US tech companies capturing federal work. Appropriations signal, pre-RFP scoring, competitor reconstruction, and the compliance layer &mdash; ITAR, FOCI, CFIUS, DSGL, DISP &mdash; that no other platform touches.</p>
                    </span>
                    <span class="lg-cta">How tech companies use Bridger →</span>
                </a>
                <a href="https://bridger.levenhall.com/for-providers" class="ledger-row" target="_blank" rel="noopener noreferrer">
                    <span class="lg-num">02</span>
                    <span class="lg-body">
                        <h3>Service Providers</h3>
                        <p>Compliance advisors, proposal writers, US incorporation specialists, 8(a) JV partners, contract manufacturers. Free listing. Inbound leads at the point of intent. 10% commission on completed engagements via Stripe Connect.</p>
                    </span>
                    <span class="lg-cta">How providers use Bridger →</span>
                </a>
                <a href="https://bridger.levenhall.com/for-lobbyists" class="ledger-row" target="_blank" rel="noopener noreferrer">
                    <span class="lg-num">03</span>
                    <span class="lg-body">
                        <h3>Lobbyists</h3>
                        <p>Government-relations firms writing policy briefings on appropriations, defense, and tech trade. Free listing. 15% commission on engagements.</p>
                    </span>
                    <span class="lg-cta">How lobbyists use Bridger →</span>
                </a>
            </div>
        </div>
    </section>

    <!-- ── STANDING WATCH (PANEL) ── -->
    <section class="section section-panel">
        <div class="container">
            <div class="watch-grid">
                <aside class="watch-rail">
                    <span class="section-label">§ Standing Watch</span>
                    <h2>Forty automated jobs a day.<br/>You get one page.</h2>
                    <p class="watch-lede">Watches run in the background across appropriations, awards, deadlines, competitors, programs, and countries. What lands in your morning brief is what actually moved.</p>
                </aside>
                <div class="watch-body">
                    <article class="watch-item">
                        <span class="lg-num">01</span>
                        <div>
                            <h3>Morning Intelligence Brief</h3>
                            <p>Tailored to your profile, delivered at 6 AM Eastern. Overnight signal condensed into what deserves the first hour of your day.</p>
                        </div>
                    </article>
                    <article class="watch-item">
                        <span class="lg-num">02</span>
                        <div>
                            <h3>Deadline Watch</h3>
                            <p>14, 7, 3, 1 days. The pipeline you are actually pursuing, held against the clock.</p>
                        </div>
                    </article>
                    <article class="watch-item">
                        <span class="lg-num">03</span>
                        <div>
                            <h3>Competitor Watch</h3>
                            <p>Awards, value jumps, recompetes, agency moves. Every incumbent, reconstructed from public records and watched for movement.</p>
                        </div>
                    </article>
                    <article class="watch-item">
                        <span class="lg-num">04</span>
                        <div>
                            <h3>Program Watch</h3>
                            <p>Funding moves, forecast shifts, new solicitations against the programs of record you care about.</p>
                        </div>
                    </article>
                    <article class="watch-item">
                        <span class="lg-num">05</span>
                        <div>
                            <h3>Country Watch</h3>
                            <p>Instability tracking on the countries where your supply chain, partners, or opportunities sit.</p>
                        </div>
                    </article>
                    <article class="watch-item">
                        <span class="lg-num">06</span>
                        <div>
                            <h3>Analyst Desk</h3>
                            <p>Instant AI response or human analyst, on demand. Ask, and get the answer inside the platform.</p>
                        </div>
                    </article>
                </div>
            </div>
        </div>
    </section>

    <!-- ── BRIDGER STAFF ── -->
    <section class="section">
        <div class="container">
            <div class="section-header">
                <span class="section-label">§ Bridger Staff</span>
                <h2>Six officers on the cycle.</h2>
                <p class="staff-lede">On <strong class="mono-strong mono-strong-gold">Pathfinder Agentic ($1,499/mo)</strong> Bridger runs a six-officer staff against your pipeline &mdash; briefing, capture, entry, profile, marketplace, and briefing officers, drafting the work you would draft. Nothing submits, sends, or files without your click.</p>
            </div>
            <div class="officer-grid">
                <div class="officer">
                    <span class="officer-role">Intelligence Officer</span>
                    <p>Assembles the 6 AM briefing.</p>
                </div>
                <div class="officer">
                    <span class="officer-role">Capture Officer</span>
                    <p>Drafts bid / no-bid analysis.</p>
                </div>
                <div class="officer">
                    <span class="officer-role">Allied-Entry Officer</span>
                    <p>Maps US-entry pathways for allied firms.</p>
                </div>
                <div class="officer">
                    <span class="officer-role">Profile Officer</span>
                    <p>Watches SAM, FPDS, CMMC posture.</p>
                </div>
                <div class="officer">
                    <span class="officer-role">Marketplace Officer</span>
                    <p>Drafts replies to inbound demand.</p>
                </div>
                <div class="officer">
                    <span class="officer-role">Briefing Officer</span>
                    <p>Drafts policy and program briefings.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ── CTA (PANEL) ── -->
    <section class="section section-panel">
        <div class="container">
            <div class="cta-block">
                <span class="route-line">Live Now &middot; v2026.06 <span class="live">●</span></span>
                <h2>Open Bridger.</h2>
                <p>Production at bridger.levenhall.com. The daily brief is free and public. Scout tier free; Pathfinder Agentic unlocks the officer stack and the full watch cycle.</p>
                <div class="btn-group">
                    <a href="https://bridger.levenhall.com/get-started" class="btn btn-primary" target="_blank" rel="noopener noreferrer">Request Access</a>
                    <a href="https://bridger.levenhall.com/brief" class="btn btn-outline-white" target="_blank" rel="noopener noreferrer">Daily Brief</a>
                </div>
            </div>
        </div>
    </section>

</BaseLayout>

<style>
    /* ── CONSOLE ── */
    .console {
        border-bottom: 1px solid var(--hairline);
        position: relative;
    }

    .console-grid {
        display: grid;
        grid-template-columns: minmax(0, 52fr) minmax(0, 48fr);
        max-width: var(--col-wide);
        margin: 0 auto;
    }

    .console-statement {
        padding: 3.5rem 3rem 3.5rem 2rem;
        border-right: 1px solid var(--hairline);
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 1.8rem;
    }

    .brand-row {
        display: flex;
        align-items: center;
        gap: 0.9rem;
    }

    .brand-mark {
        width: 40px;
        height: 40px;
    }

    .brand-word {
        font-family: var(--serif);
        font-weight: 600;
        font-size: 2rem;
        letter-spacing: -0.03em;
        color: var(--bone);
        line-height: 1;
    }

    .console-lede {
        max-width: 50ch;
        font-size: 1.02rem;
        color: var(--muted);
    }

    .console-cta { margin-top: 0.4rem; }

    .console-meta {
        font-family: var(--mono);
        font-size: 0.62rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--dim);
    }
    .console-meta a { color: var(--gold); text-decoration: none; }
    .console-meta a:hover { border-bottom: 1px solid var(--gold); }

    /* ── INSTRUMENT: BRIDGER INDEX ── */
    .console-instrument {
        padding: 2.4rem 2rem 1.6rem 2.4rem;
        font-family: var(--mono);
        display: flex;
        flex-direction: column;
        justify-content: center;
        background-image:
            linear-gradient(var(--hairline-soft) 1px, transparent 1px),
            linear-gradient(90deg, var(--hairline-soft) 1px, transparent 1px);
        background-size: 28px 28px;
    }

    .inst-head, .inst-foot {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        font-size: 0.6rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--dim);
    }

    .inst-head {
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--hairline);
        margin-bottom: 1.2rem;
    }

    .inst-foot {
        padding-top: 1rem;
        border-top: 1px solid var(--hairline);
        margin-top: 1.2rem;
        font-size: 0.56rem;
    }

    .inst-live { color: var(--gold); animation: pulse-live 2.4s ease-in-out infinite; }
    .inst-verdict { color: var(--gold); }

    .inst-svg { width: 100%; height: auto; display: block; }

    .ax line { stroke: var(--hairline-soft); stroke-width: 1; }
    .ax .ax-base { stroke: var(--hairline); }

    .ax-note {
        font-family: var(--mono);
        font-size: 9px;
        letter-spacing: 0.12em;
        fill: var(--dim);
    }
    .ax-note-end { text-anchor: end; fill: var(--gold); }

    .rfp-line {
        stroke: var(--gold);
        stroke-width: 1;
        stroke-dasharray: 3 5;
        opacity: 0.6;
    }

    .idx-line { fill: none; stroke: var(--gold); stroke-width: 1.2; }
    .idx-area { fill: rgba(201, 169, 97, 0.07); stroke: none; }
    .idx-dot { fill: var(--gold); animation: pulse-live 3s ease-in-out infinite; }

    .ann {
        font-family: var(--mono);
        font-size: 9px;
        letter-spacing: 0.14em;
        fill: var(--gold);
    }
    .ann-dim { fill: var(--dim); }

    @keyframes pulse-live {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.35; }
    }

    /* ── DATA BAR ── */
    .data-bar {
        display: grid;
        grid-template-columns: 200px repeat(5, 1fr);
        border-top: 1px solid var(--hairline);
        max-width: var(--col-wide);
        margin: 0 auto;
    }

    .datum {
        padding: 1.4rem 1.6rem;
        border-right: 1px solid var(--hairline);
        font-family: var(--mono);
    }
    .datum:first-child { padding-left: 2rem; }
    .datum:last-child { border-right: none; }

    .datum-label { display: flex; align-items: center; }

    .d-val {
        display: block;
        font-size: 1.25rem;
        font-weight: 500;
        color: var(--bone);
        font-variant-numeric: tabular-nums;
    }
    .d-u { font-size: 0.8rem; color: var(--gold); }

    .d-cap {
        display: block;
        margin-top: 0.35rem;
        font-size: 0.56rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--dim);
    }
    .d-cap-gold { color: var(--gold); margin-top: 0; }

    /* ── OPENING (PAPER) ── */
    .opening-prose { max-width: 680px; }

    .opening-route {
        display: block;
        margin-bottom: 2rem;
        color: var(--text-medium);
    }

    .opening-lede {
        font-family: var(--serif);
        font-weight: 600;
        font-size: clamp(1.5rem, 2.6vw, 2.1rem);
        line-height: 1.25;
        letter-spacing: -0.02em;
        color: var(--deep-navy);
        margin-bottom: 1.6rem;
    }

    .opening-prose p:not(.opening-lede) {
        margin-bottom: 1rem;
        font-size: 1.05rem;
        line-height: 1.85;
    }

    .mono-strong {
        font-family: var(--mono);
        font-size: 0.88em;
        font-weight: 700;
        letter-spacing: 0.06em;
        color: var(--deep-navy);
    }
    .mono-strong-gold { color: var(--gold); }

    /* ── LEDGER (WHO) ── */
    .ledger { border-top: 1px solid var(--hairline); }

    .ledger-row {
        display: grid;
        grid-template-columns: 64px minmax(0, 1fr) 280px;
        gap: 2rem;
        align-items: start;
        padding: 2rem 0.5rem;
        border-bottom: 1px solid var(--hairline);
        text-decoration: none;
        transition: background var(--t-short);
    }
    .ledger-row:hover { background: var(--ink-panel); }

    .lg-num {
        font-family: var(--serif);
        font-style: italic;
        font-weight: 400;
        font-size: 1.5rem;
        color: var(--gold);
        line-height: 1.2;
    }

    .lg-body h3 { margin-bottom: 0.5rem; }
    .lg-body p { font-size: 0.94rem; line-height: 1.7; color: var(--muted); max-width: 68ch; }

    .lg-cta {
        font-family: var(--mono);
        font-size: 0.62rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--dim);
        text-align: right;
        padding-top: 0.4rem;
        transition: color var(--t-short);
    }
    .ledger-row:hover .lg-cta { color: var(--gold); }

    /* ── STANDING WATCH ── */
    .watch-grid {
        display: grid;
        grid-template-columns: minmax(0, 4fr) minmax(0, 6fr);
        gap: 4rem;
        align-items: start;
    }

    .watch-rail { position: sticky; top: 100px; }
    .watch-rail h2 { margin-bottom: 1.2rem; }
    .watch-lede { font-size: 1rem; max-width: 42ch; }

    .watch-body { border-top: 1px solid var(--hairline); }

    .watch-item {
        display: grid;
        grid-template-columns: 64px 1fr;
        gap: 1.6rem;
        padding: 1.6rem 0.5rem;
        border-bottom: 1px solid var(--hairline);
    }

    .watch-item h3 { font-size: 1.2rem; margin-bottom: 0.4rem; }
    .watch-item p { font-size: 0.94rem; line-height: 1.7; color: var(--muted); max-width: 60ch; }

    /* ── STAFF ── */
    .staff-lede { max-width: 66ch; }

    .officer-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        border: 1px solid var(--hairline);
    }

    .officer {
        padding: 1.8rem 1.8rem 2rem;
        border-right: 1px solid var(--hairline);
        border-bottom: 1px solid var(--hairline);
        transition: background var(--t-short);
    }
    .officer:nth-child(3n) { border-right: none; }
    .officer:nth-child(n+4) { border-bottom: none; }
    .officer:hover { background: var(--ink-panel); }

    .officer-role {
        display: block;
        font-family: var(--mono);
        font-size: 0.62rem;
        font-weight: 500;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--gold);
        margin-bottom: 0.6rem;
    }

    .officer p { font-size: 0.9rem; line-height: 1.65; color: var(--muted); }

    /* ── CTA ── */
    .cta-block { max-width: 680px; }
    .cta-block .route-line { display: block; margin-bottom: 1.6rem; }
    .cta-block h2 { margin-bottom: 1.2rem; }
    .cta-block p { margin-bottom: 2rem; max-width: 58ch; }

    /* ── REDUCED MOTION ── */
    @media (prefers-reduced-motion: reduce) {
        .idx-dot, .inst-live { animation: none; }
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 1100px) {
        .data-bar { grid-template-columns: repeat(3, 1fr); }
        .datum-label { grid-column: 1 / -1; border-right: none; border-bottom: 1px solid var(--hairline); padding: 1rem 2rem; }
        .datum:nth-child(4) { border-right: none; }
        .datum:nth-child(-n+4) { border-bottom: 1px solid var(--hairline); }
    }

    @media (max-width: 992px) {
        .console-grid { grid-template-columns: 1fr; }
        .console-statement { border-right: none; border-bottom: 1px solid var(--hairline); padding: 3rem 2rem; }
        .console-instrument { padding: 2rem 2rem 1.4rem; }
        .watch-grid { grid-template-columns: 1fr; gap: 2.5rem; }
        .watch-rail { position: static; }
        .ledger-row { grid-template-columns: 48px 1fr; }
        .lg-cta { grid-column: 2; text-align: left; padding-top: 0; }
        .officer-grid { grid-template-columns: repeat(2, 1fr); }
        .officer:nth-child(3n) { border-right: 1px solid var(--hairline); }
        .officer:nth-child(2n) { border-right: none; }
        .officer:nth-child(n+4) { border-bottom: 1px solid var(--hairline); }
        .officer:nth-child(n+5) { border-bottom: none; }
    }

    @media (max-width: 700px) {
        .data-bar { grid-template-columns: repeat(2, 1fr); }
        .datum { border-bottom: 1px solid var(--hairline); }
        .datum:nth-child(2n+1) { border-right: none; }
        .datum:nth-child(2n) { border-right: 1px solid var(--hairline); }
        .datum:nth-last-child(-n+2) { border-bottom: none; }
        .officer-grid { grid-template-columns: 1fr; }
        .officer, .officer:nth-child(3n), .officer:nth-child(2n) { border-right: none; border-bottom: 1px solid var(--hairline); }
        .officer:last-child { border-bottom: none; }
        .watch-item { grid-template-columns: 40px 1fr; gap: 1rem; }
    }
</style>
