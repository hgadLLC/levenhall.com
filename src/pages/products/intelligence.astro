---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
---

<BaseLayout title="Levenhall Intelligence — Defense &amp; Alliance Advisory Dashboard" description="Real-time defense intelligence dashboard for allied defense advisory. Procurement tracking, alliance dynamics, Indo-Pacific strategy, and government contracting intel. Live at intel.levenhall.com.">

    <PageHeader
        label="Systems / Intelligence / A Levenhall Product"
        index="03"
        title="Intelligence"
    />

    <!-- ── CONSOLE: STATEMENT + RADAR INSTRUMENT ── -->
    <section class="console sweep-field texture-grain">
        <div class="console-grid">
            <div class="console-statement">
                <div class="brand-row">
                    <img src="/images/products/intelligence-mark.png" alt="" class="brand-mark" aria-hidden="true" />
                    <span class="brand-word">Levenhall Intelligence</span>
                </div>
                <p class="console-tagline editorial-italic">Defense &amp; Alliance Advisory Dashboard.</p>
                <div class="btn-group console-cta">
                    <a href="https://intel.levenhall.com" class="btn btn-primary" target="_blank" rel="noopener noreferrer">Enter Portal</a>
                    <a href="#coverage" class="mono-link">See what it covers →</a>
                </div>
                <p class="console-meta"><span class="live-dot">●</span> Live at <a href="https://intel.levenhall.com" target="_blank" rel="noopener noreferrer">intel.levenhall.com</a></p>
            </div>

            <div class="console-instrument" aria-hidden="true">
                <div class="inst-head">
                    <span>Operating Picture / Four Watches</span>
                    <span class="inst-live">● 100+ Sources</span>
                </div>
                <svg class="inst-svg" viewBox="0 0 480 420" xmlns="http://www.w3.org/2000/svg">
                    <!-- range rings -->
                    <g class="rr">
                        <circle cx="240" cy="210" r="52" />
                        <circle cx="240" cy="210" r="104" />
                        <circle cx="240" cy="210" r="156" />
                        <circle cx="240" cy="210" r="196" />
                        <line x1="240" y1="14" x2="240" y2="406" />
                        <line x1="44" y1="210" x2="436" y2="210" />
                        <line x1="101.4" y1="71.4" x2="378.6" y2="348.6" class="rr-soft" />
                        <line x1="378.6" y1="71.4" x2="101.4" y2="348.6" class="rr-soft" />
                    </g>
                    <!-- azimuth annotations -->
                    <text class="az-note" x="240" y="10" text-anchor="middle">000</text>
                    <text class="az-note" x="446" y="213">090</text>
                    <text class="az-note" x="240" y="418" text-anchor="middle">180</text>
                    <text class="az-note" x="34" y="213" text-anchor="end">270</text>
                    <!-- sweep -->
                    <g class="sweep-g">
                        <path class="sweep-wedge" d="M240 210 L240 14 A196 196 0 0 1 320 31.1 Z" />
                        <line class="sweep-line" x1="240" y1="210" x2="240" y2="14" />
                    </g>
                    <!-- contacts: the four watches -->
                    <g class="contact">
                        <circle class="ct-dot" cx="168" cy="128" r="2.6" />
                        <text class="ct-note" x="178" y="124">Procurement</text>
                    </g>
                    <g class="contact">
                        <circle class="ct-dot ct-2" cx="330" cy="160" r="2.6" />
                        <text class="ct-note" x="340" y="156">Alliance</text>
                    </g>
                    <g class="contact">
                        <circle class="ct-dot ct-3" cx="186" cy="298" r="2.6" />
                        <text class="ct-note" x="196" y="294">Indo-Pacific</text>
                    </g>
                    <g class="contact">
                        <circle class="ct-dot ct-4" cx="308" cy="272" r="2.6" />
                        <text class="ct-note" x="318" y="268">Contracting</text>
                    </g>
                </svg>
                <div class="inst-foot">
                    <span>Representative picture</span>
                    <span class="inst-gold">On-device ML · Nothing leaves the browser</span>
                </div>
            </div>
        </div>
    </section>

    <!-- ── WHAT IT IS (PAPER — the one light passage) ── -->
    <section class="section section-paper">
        <div class="container">
            <div class="opening-prose">
                <span class="route-line opening-route">Intelligence / Doctrine</span>
                <p class="opening-lede">Real-time defense intelligence, on one screen, for the allied defense advisor.</p>
                <p>Levenhall Intelligence is the situational-awareness layer of the Levenhall stack. Live signal &mdash; procurement moves, alliance dynamics, Indo-Pacific posture, government-contracting activity &mdash; visualised on a WebGL globe, with the machine learning that fuses it running in your own browser. Nothing sensitive leaves the tab.</p>
                <p class="opening-close editorial-italic">Situational awareness, not finished intelligence. For the assessed, sourced version, that's <a href="/products/bridger">Bridger</a>.</p>
            </div>
        </div>
    </section>

    <!-- ── WHAT'S ON THE DASHBOARD ── -->
    <section class="section" id="coverage">
        <div class="container">
            <div class="cov-grid">
                <aside class="cov-rail">
                    <span class="section-label">§ On the dashboard</span>
                    <h2>Four watches. One operating picture.</h2>
                    <p>Each watch runs its own signal stream, layered together on the globe. Toggle what you're tracking, expand what changes.</p>
                </aside>
                <div class="cov-body">
                    <article class="watch-item">
                        <span class="lg-num">01</span>
                        <div>
                            <h3>Procurement Tracking</h3>
                            <p>Live view of US federal procurement activity &mdash; solicitations, awards, contract movements. Where the dollars are landing and where they're about to.</p>
                        </div>
                    </article>
                    <article class="watch-item">
                        <span class="lg-num">02</span>
                        <div>
                            <h3>Alliance Dynamics</h3>
                            <p>AUKUS, Five Eyes, NATO, and the wider allied ecosystem. Force posture, joint exercises, capability announcements, allied procurement flows.</p>
                        </div>
                    </article>
                    <article class="watch-item">
                        <span class="lg-num">03</span>
                        <div>
                            <h3>Indo-Pacific Strategy</h3>
                            <p>The theatre that drives allied planning. Movements, statements, exercises, and instability signals across the Indo-Pacific, with country-level drill-down.</p>
                        </div>
                    </article>
                    <article class="watch-item">
                        <span class="lg-num">04</span>
                        <div>
                            <h3>Government Contracting Intel</h3>
                            <p>Federal programs of record, agency forecasts, incumbent watch. The activity behind the awards, not just the awards themselves.</p>
                        </div>
                    </article>
                </div>
            </div>
        </div>
    </section>

    <!-- ── HOW IT WORKS (PANEL) ── -->
    <section class="section section-panel">
        <div class="container">
            <div class="section-header">
                <span class="section-label">§ How it works</span>
                <h2>WebGL globe. On-device ML.<br/>Nothing leaves the browser.</h2>
            </div>
            <div class="how-grid">
                <div class="how-cell">
                    <span class="how-tag">Rendering</span>
                    <p>Multi-layer WebGL globe with 30+ intelligence layers &mdash; toggle what you need, hide what you don't.</p>
                </div>
                <div class="how-cell">
                    <span class="how-tag">Signal</span>
                    <p>Over one hundred continuously-refreshed sources, aggregated into a single event stream and scored for salience.</p>
                </div>
                <div class="how-cell">
                    <span class="how-tag">Analysis</span>
                    <p>Four ONNX models running client-side in a Web Worker &mdash; embeddings, sentiment, summarisation, named-entity extraction &mdash; so heavy inference never leaves the tab.</p>
                </div>
                <div class="how-cell">
                    <span class="how-tag">Access</span>
                    <p>Email-gated portal. No password. Access and activity may be monitored per Levenhall's terms of use.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ── WHERE IT FITS ── -->
    <section class="section">
        <div class="container">
            <div class="section-header">
                <span class="section-label">§ Where it fits</span>
                <h2>Situational awareness sits above Bridger.<br/>Bridger closes the loop.</h2>
            </div>
            <div class="stack-grid">
                <a href="/products/intelligence" class="stack-cell">
                    <span class="stack-tag stack-tag-current">This product</span>
                    <h3>Intelligence</h3>
                    <p>Situational awareness. Live signal, on a globe, filtered to what allied defense advisors need to see.</p>
                </a>
                <a href="/products/bridger" class="stack-cell">
                    <span class="stack-tag">Sibling product</span>
                    <h3>Bridger</h3>
                    <p>Finished intelligence. Assessed, sourced, and scored against your profile. The next step when situational awareness turns into a pursuit.</p>
                    <span class="stack-arrow">→</span>
                </a>
            </div>
        </div>
    </section>

    <!-- ── CTA (PANEL) ── -->
    <section class="section section-panel">
        <div class="container">
            <div class="cta-block">
                <span class="route-line">Live Now <span class="live">●</span></span>
                <h2>Enter the portal.</h2>
                <p>Email-gated. No password. Enterprise deployments and bespoke defense-advisory briefings available through Levenhall.</p>
                <div class="btn-group">
                    <a href="https://intel.levenhall.com" class="btn btn-primary" target="_blank" rel="noopener noreferrer">intel.levenhall.com</a>
                    <a href="/contact" class="btn btn-outline-white">Contact Levenhall</a>
                </div>
            </div>
        </div>
    </section>

</BaseLayout>

<style>
    /* ── CONSOLE ── */
    .console {
        border-bottom: 1px solid var(--hairline);
        position: relative;
    }

    .console-grid {
        display: grid;
        grid-template-columns: minmax(0, 52fr) minmax(0, 48fr);
        max-width: var(--col-wide);
        margin: 0 auto;
    }

    .console-statement {
        padding: 3.5rem 3rem 3.5rem 2rem;
        border-right: 1px solid var(--hairline);
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 1.8rem;
    }

    .brand-row {
        display: flex;
        align-items: center;
        gap: 0.9rem;
    }

    .brand-mark {
        width: 40px;
        height: 40px;
    }

    .brand-word {
        font-family: var(--serif);
        font-weight: 600;
        font-size: 1.7rem;
        letter-spacing: -0.02em;
        color: var(--bone);
        line-height: 1.1;
    }

    .console-tagline {
        font-size: 1.35rem;
        line-height: 1.4;
    }

    .console-cta { margin-top: 0.4rem; }

    .console-meta {
        font-family: var(--mono);
        font-size: 0.62rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--dim);
    }
    .console-meta a { color: var(--gold); text-decoration: none; }
    .console-meta a:hover { border-bottom: 1px solid var(--gold); }

    .live-dot { color: var(--gold); animation: pulse-live 2.4s ease-in-out infinite; }

    /* ── INSTRUMENT: RADAR ── */
    .console-instrument {
        padding: 2.4rem 2rem 1.6rem 2.4rem;
        font-family: var(--mono);
        display: flex;
        flex-direction: column;
        justify-content: center;
        background-image:
            linear-gradient(var(--hairline-soft) 1px, transparent 1px),
            linear-gradient(90deg, var(--hairline-soft) 1px, transparent 1px);
        background-size: 28px 28px;
    }

    .inst-head, .inst-foot {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        font-size: 0.6rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--dim);
    }

    .inst-head {
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--hairline);
        margin-bottom: 1.2rem;
    }

    .inst-foot {
        padding-top: 1rem;
        border-top: 1px solid var(--hairline);
        margin-top: 1.2rem;
        font-size: 0.56rem;
    }

    .inst-live { color: var(--gold); animation: pulse-live 2.4s ease-in-out infinite; }
    .inst-gold { color: var(--gold); }

    .inst-svg {
        width: min(100%, 420px);
        height: auto;
        display: block;
        margin: 0 auto;
    }

    .rr circle, .rr line {
        fill: none;
        stroke: var(--hairline);
        stroke-width: 1;
    }
    .rr .rr-soft { stroke: var(--hairline-soft); }

    .az-note {
        font-family: var(--mono);
        font-size: 9px;
        letter-spacing: 0.14em;
        fill: var(--dim);
    }

    .sweep-g {
        transform-origin: 240px 210px;
        animation: radar-rotate 8s linear infinite;
    }
    .sweep-wedge { fill: rgba(201, 169, 97, 0.1); stroke: none; }
    .sweep-line { stroke: var(--gold); stroke-width: 0.8; opacity: 0.7; }

    @keyframes radar-rotate {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    .ct-dot { fill: var(--gold); animation: pulse-live 3s ease-in-out infinite; }
    .ct-2 { animation-delay: -0.8s; }
    .ct-3 { animation-delay: -1.6s; }
    .ct-4 { animation-delay: -2.4s; }

    .ct-note {
        font-family: var(--mono);
        font-size: 9px;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        fill: var(--muted);
    }

    @keyframes pulse-live {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.35; }
    }

    /* ── OPENING (PAPER) ── */
    .opening-prose { max-width: 680px; }

    .opening-route {
        display: block;
        margin-bottom: 2rem;
        color: var(--text-medium);
    }

    .opening-lede {
        font-family: var(--serif);
        font-weight: 600;
        font-size: clamp(1.5rem, 2.6vw, 2.1rem);
        line-height: 1.25;
        letter-spacing: -0.02em;
        color: var(--deep-navy);
        margin-bottom: 1.6rem;
    }

    .opening-prose p:not(.opening-lede) {
        margin-bottom: 1rem;
        font-size: 1.05rem;
        line-height: 1.85;
    }

    .opening-close {
        font-size: 1.15rem;
        border-top: 1px solid var(--hairline-paper);
        padding-top: 1.4rem;
        margin-top: 1.6rem;
        max-width: 52ch;
    }
    .opening-close a {
        color: inherit;
        text-decoration: underline;
        text-decoration-color: rgba(139, 21, 56, 0.4);
    }

    /* ── COVERAGE ── */
    .cov-grid {
        display: grid;
        grid-template-columns: minmax(0, 4fr) minmax(0, 6fr);
        gap: 4rem;
        align-items: start;
    }

    .cov-rail { position: sticky; top: 100px; }
    .cov-rail h2 { margin-bottom: 1.2rem; }
    .cov-rail p { font-size: 1rem; max-width: 42ch; }

    .cov-body { border-top: 1px solid var(--hairline); }

    .watch-item {
        display: grid;
        grid-template-columns: 64px 1fr;
        gap: 1.6rem;
        padding: 1.7rem 0.5rem;
        border-bottom: 1px solid var(--hairline);
    }

    .lg-num {
        font-family: var(--serif);
        font-style: italic;
        font-weight: 400;
        font-size: 1.6rem;
        color: var(--gold);
        line-height: 1.2;
    }

    .watch-item h3 { font-size: 1.25rem; margin-bottom: 0.4rem; }
    .watch-item p { font-size: 0.95rem; line-height: 1.7; color: var(--muted); max-width: 60ch; }

    /* ── HOW ── */
    .how-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        border: 1px solid var(--hairline);
    }

    .how-cell {
        padding: 1.8rem 1.8rem 2rem;
        border-right: 1px solid var(--hairline);
        background: var(--ink);
        transition: background var(--t-short);
    }
    .how-cell:last-child { border-right: none; }
    .how-cell:hover { background: var(--ink-panel); }

    .how-tag {
        display: block;
        font-family: var(--mono);
        font-size: 0.6rem;
        font-weight: 500;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--gold);
        margin-bottom: 0.7rem;
    }

    .how-cell p { font-size: 0.9rem; line-height: 1.68; color: var(--muted); }

    /* ── STACK ── */
    .stack-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        border: 1px solid var(--hairline);
    }

    .stack-cell {
        position: relative;
        padding: 2.2rem 2.4rem 2.4rem;
        border-right: 1px solid var(--hairline);
        text-decoration: none;
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
        background: var(--ink);
        transition: background var(--t-short);
    }
    .stack-cell:last-child { border-right: none; }
    .stack-cell:hover { background: var(--ink-panel); }

    .stack-tag {
        font-family: var(--mono);
        font-size: 0.58rem;
        font-weight: 500;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--dim);
    }
    .stack-tag-current { color: var(--gold); }

    .stack-cell h3 { font-size: 1.4rem; }
    .stack-cell p { font-size: 0.93rem; line-height: 1.7; color: var(--muted); max-width: 48ch; }

    .stack-arrow {
        position: absolute;
        top: 2.2rem;
        right: 2rem;
        font-family: var(--mono);
        color: var(--dim);
        transition: color var(--t-short), transform var(--t-short) var(--ease-enter);
    }
    .stack-cell:hover .stack-arrow { color: var(--gold); transform: translateX(4px); }

    /* ── CTA ── */
    .cta-block { max-width: 680px; }
    .cta-block .route-line { display: block; margin-bottom: 1.6rem; }
    .cta-block h2 { margin-bottom: 1.2rem; }
    .cta-block p { margin-bottom: 2rem; max-width: 58ch; }

    /* ── REDUCED MOTION ── */
    @media (prefers-reduced-motion: reduce) {
        .sweep-g, .ct-dot, .inst-live, .live-dot { animation: none; }
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 992px) {
        .console-grid { grid-template-columns: 1fr; }
        .console-statement { border-right: none; border-bottom: 1px solid var(--hairline); padding: 3rem 2rem; }
        .console-instrument { padding: 2rem 2rem 1.4rem; }
        .cov-grid { grid-template-columns: 1fr; gap: 2.5rem; }
        .cov-rail { position: static; }
        .how-grid { grid-template-columns: repeat(2, 1fr); }
        .how-cell:nth-child(2n) { border-right: none; }
        .how-cell:nth-child(-n+2) { border-bottom: 1px solid var(--hairline); }
        .stack-grid { grid-template-columns: 1fr; }
        .stack-cell { border-right: none; }
        .stack-cell:first-child { border-bottom: 1px solid var(--hairline); }
    }

    @media (max-width: 700px) {
        .how-grid { grid-template-columns: 1fr; }
        .how-cell, .how-cell:nth-child(2n) { border-right: none; border-bottom: 1px solid var(--hairline); }
        .how-cell:last-child { border-bottom: none; }
        .watch-item { grid-template-columns: 40px 1fr; gap: 1rem; }
    }
</style>
