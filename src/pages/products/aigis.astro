---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="AIGIS | Levenhall" description="AIGIS is Levenhall's modular, containerized AI evaluation and governance platform — designed to run from unclassified through TS/SCI air-gapped on the same container images.">

    <!-- ── HERO ── -->
    <section class="a-hero">
        <div class="a-hero-bg"></div>
        <div class="a-hero-grid"></div>
        <div class="a-hero-inner">
            <div class="a-tag">A Levenhall Product</div>
            <div class="a-wordmark">AIGIS</div>
            <p class="a-sub">AI Evaluation &amp; Governance &middot; UNCLASS to TS/SCI</p>
            <div class="a-rule"></div>
            <p class="a-desc">A modular, containerized platform for continuous AI model assessment. Vendor-agnostic. Identical container images at every classification level.</p>
            <div class="a-cta">
                <a href="/contact" class="btn btn-gold">Request Early Access</a>
                <a href="#capabilities" class="btn btn-outline-white">See Capabilities</a>
            </div>
        </div>
    </section>

    <!-- ── QUICK FACTS STRIP ── -->
    <section class="a-facts-section">
        <div class="container">
            <div class="a-facts reveal">
                <div class="a-fact">
                    <span class="a-fact-val">4</span>
                    <span class="a-fact-lbl">Classification Tiers Supported</span>
                </div>
                <div class="a-fact">
                    <span class="a-fact-val">6</span>
                    <span class="a-fact-lbl">Compliance Frameworks Tracked</span>
                </div>
                <div class="a-fact">
                    <span class="a-fact-val">9</span>
                    <span class="a-fact-lbl">Evaluation Capabilities</span>
                </div>
                <div class="a-fact">
                    <span class="a-fact-val">∞</span>
                    <span class="a-fact-lbl">Vendor Lock-In</span>
                </div>
            </div>
        </div>
    </section>

    <!-- ── THE SHIELD ── -->
    <section class="a-section a-shield">
        <div class="container">
            <div class="a-narrow reveal">
                <span class="a-label">The Shield</span>
                <h2>One question, asked continuously: is this model safe and mission-ready?</h2>
                <div class="a-gold-rule"></div>
                <p>AIGIS takes its name from the mythological <em>aegis</em>. The function follows the name: determine whether an AI model is safe and mission-ready for <em>this</em> user, <em>this</em> network, <em>this</em> mission &mdash; not in the abstract.</p>
                <p>Built for the operational evaluator, not the research scientist. AI assessment as continuous infrastructure, not a one-time benchmark.</p>
            </div>
        </div>
    </section>

    <!-- ── THE GAP (DARK) ── -->
    <section class="a-section a-gap">
        <div class="a-dark-bg"></div>
        <div class="container" style="position: relative; z-index: 1;">
            <div class="a-header reveal">
                <span class="a-dark-label">Why AIGIS Exists</span>
                <h2>The Gap Between Research Tools and Program Tools</h2>
                <p class="a-header-sub">Existing tools fall into two categories. Neither is sufficient for the operational evaluator.</p>
            </div>
            <div class="a-gap-grid reveal">
                <div class="a-gap-card">
                    <span class="a-gap-tag">Category 1</span>
                    <h3>Research-Grade</h3>
                    <p class="a-gap-examples">HELM &middot; Inspect &middot; lm-evaluation-harness</p>
                    <p>Built for ML researchers. Not deployable to classified networks. No operational context.</p>
                </div>
                <div class="a-gap-card">
                    <span class="a-gap-tag">Category 2</span>
                    <h3>Program-Proprietary</h3>
                    <p class="a-gap-examples">One program, one mission</p>
                    <p>Reflects a single program's profile. Dies when the program does. Not reusable.</p>
                </div>
                <div class="a-gap-card a-gap-card-on">
                    <span class="a-gap-tag a-gap-tag-on">AIGIS</span>
                    <h3>Operational Infrastructure</h3>
                    <p class="a-gap-examples">Vendor-agnostic &middot; Cross-classification &middot; Continuous</p>
                    <p>One platform across DoD, IC, and commercial deployments &mdash; air-gapped TS/SCI to managed cloud.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ── DUAL-USE ── -->
    <section class="a-section a-dual">
        <div class="container">
            <div class="a-header reveal">
                <span class="a-label">Dual-Use</span>
                <h2>Two Markets. One Platform.</h2>
                <p class="a-header-sub">Government users benefit from continuous commercial R&amp;D. Commercial users benefit from defense-grade rigor.</p>
            </div>
            <div class="a-dual-grid reveal">
                <div class="a-dual-card">
                    <span class="a-dual-tag">Defense</span>
                    <h3>DoD &amp; IC</h3>
                    <p>Model evaluation across classification levels. DDIL degradation profiling. Adversarial red-teaming aligned to MITRE ATLAS. Mission-specific benchmarks.</p>
                </div>
                <div class="a-dual-card">
                    <span class="a-dual-tag a-dual-tag-c">Commercial</span>
                    <h3>Enterprise Governance</h3>
                    <p>Continuous compliance for the EU AI Act, NIST AI RMF, and ISO 42001. Risk assessment for regulated industries and insurance counterparties.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ── CAPABILITIES (DARK) ── -->
    <section class="a-section a-caps" id="capabilities">
        <div class="a-dark-bg"></div>
        <div class="container" style="position: relative; z-index: 1;">
            <div class="a-header reveal">
                <span class="a-dark-label">Capabilities</span>
                <h2>Nine Evaluation Surfaces. One Harness.</h2>
            </div>
            <div class="a-caps-grid reveal">
                <div class="a-cap">
                    <span class="a-cap-num">01</span>
                    <h4>Model Interface Layer</h4>
                    <p>Adapters for OpenAI, HuggingFace, Ollama, Bedrock, and gRPC. New adapters via a documented SDK.</p>
                </div>
                <div class="a-cap">
                    <span class="a-cap-num">02</span>
                    <h4>Execution Engine</h4>
                    <p>Distributed task orchestration with full environment snapshots, parallel runs, and reproducibility.</p>
                </div>
                <div class="a-cap">
                    <span class="a-cap-num">03</span>
                    <h4>Scoring Engine</h4>
                    <p>Pluggable scorers &mdash; exact match, contains, similarity, classification, human routing.</p>
                </div>
                <div class="a-cap">
                    <span class="a-cap-num">04</span>
                    <h4>DDIL Simulator</h4>
                    <p>Injects latency, jitter, throttling, and intermittent connectivity. Evaluates degradation curves.</p>
                </div>
                <div class="a-cap">
                    <span class="a-cap-num">05</span>
                    <h4>Agentic Evaluation</h4>
                    <p>Full execution-trace capture aligned with OWASP Agentic AI Top 10 and the MAESTRO framework.</p>
                </div>
                <div class="a-cap">
                    <span class="a-cap-num">06</span>
                    <h4>Adversarial Red-Teaming</h4>
                    <p>Prompt injection, jailbreak generation, data-poisoning probes. Mapped to MITRE ATLAS technique IDs.</p>
                </div>
                <div class="a-cap">
                    <span class="a-cap-num">07</span>
                    <h4>Human Evaluation</h4>
                    <p>Likert, pairwise, best-of-N. Inter-rater reliability via Krippendorff's alpha and Fleiss' kappa.</p>
                </div>
                <div class="a-cap">
                    <span class="a-cap-num">08</span>
                    <h4>Multimodal</h4>
                    <p>Text, image, audio, and video pipelines with modality-specific metrics.</p>
                </div>
                <div class="a-cap">
                    <span class="a-cap-num">09</span>
                    <h4>Governance &amp; Risk</h4>
                    <p>Live framework coverage, risk scoring, incident tracking, and insurance monitoring.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ── CLASSIFICATION DEPLOYMENT ── -->
    <section class="a-section a-class">
        <div class="container">
            <div class="a-header reveal">
                <span class="a-label">Classification Deployment</span>
                <h2>Same container. Every network.</h2>
                <p class="a-header-sub">Identical images at every level. Only Helm values change. Air-gapped deployments bundle weights and benchmarks as container volumes.</p>
            </div>
            <div class="a-class-table reveal">
                <div class="a-class-row a-class-head">
                    <span>Environment</span>
                    <span>LLM Provider</span>
                    <span>Vector DB</span>
                    <span>External APIs</span>
                </div>
                <div class="a-class-row">
                    <span class="a-class-env">Unclassified</span>
                    <span>OpenAI API</span>
                    <span>Managed cloud</span>
                    <span>Full</span>
                </div>
                <div class="a-class-row">
                    <span class="a-class-env">IL5 Cloud</span>
                    <span>OpenAI (FedRAMP) / Ollama</span>
                    <span>pgvector</span>
                    <span>Restricted</span>
                </div>
                <div class="a-class-row">
                    <span class="a-class-env">IL6 / SECRET</span>
                    <span>Ollama (local)</span>
                    <span>pgvector</span>
                    <span>None</span>
                </div>
                <div class="a-class-row">
                    <span class="a-class-env">TS/SCI &middot; JWICS</span>
                    <span>Ollama (quantized, local)</span>
                    <span>pgvector</span>
                    <span>None</span>
                </div>
            </div>
        </div>
    </section>

    <!-- ── CTA ── -->
    <section class="a-cta-section">
        <div class="a-cta-bg"></div>
        <div class="a-cta-inner">
            <div class="a-cta-accent"></div>
            <div class="a-cta-badge">Levenhall Proprietary</div>
            <h2>AIGIS is active. Early access is selective.</h2>
            <p>We work with DoD, IC, regulated commercial customers, and insurance counterparties on early access deployments.</p>
            <div class="btn-group" style="justify-content: center;">
                <a href="/contact" class="btn btn-gold">Request Early Access</a>
                <a href="/services#market-intelligence" class="btn btn-outline-white">Intelligence Practice</a>
            </div>
        </div>
    </section>

</BaseLayout>

<style>
    /* ── HERO ── */
    .a-hero {
        background: linear-gradient(160deg, #04070e 0%, #080e1c 25%, #0f1f3a 60%, #0c1628 100%);
        padding: 9rem 2rem 5.5rem;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

    .a-hero-bg {
        position: absolute;
        inset: 0;
        background-image:
            radial-gradient(ellipse at 50% 50%, rgba(56, 217, 201, 0.04) 0%, transparent 50%),
            radial-gradient(ellipse at 80% 20%, rgba(201, 169, 97, 0.06) 0%, transparent 50%);
        pointer-events: none;
    }

    .a-hero-grid {
        position: absolute;
        inset: 0;
        background-image:
            linear-gradient(rgba(255,255,255,0.015) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255,255,255,0.015) 1px, transparent 1px);
        background-size: 60px 60px;
        pointer-events: none;
        mask-image: radial-gradient(ellipse at center, black 30%, transparent 70%);
        -webkit-mask-image: radial-gradient(ellipse at center, black 30%, transparent 70%);
    }

    .a-hero::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: linear-gradient(90deg, transparent, rgba(56, 217, 201, 0.5), transparent);
        opacity: 0.5;
    }

    .a-hero-inner {
        max-width: 680px;
        margin: 0 auto;
        position: relative;
        z-index: 1;
    }

    .a-tag {
        display: inline-block;
        font-family: 'Source Sans Pro', sans-serif;
        font-weight: 600;
        font-size: 0.68rem;
        letter-spacing: 3.5px;
        text-transform: uppercase;
        color: var(--gold);
        background: rgba(201, 169, 97, 0.08);
        border: 1px solid rgba(201, 169, 97, 0.18);
        padding: 0.5rem 1.4rem;
        margin-bottom: 2rem;
    }

    .a-wordmark {
        font-family: 'Source Sans Pro', sans-serif;
        font-size: clamp(3.5rem, 9vw, 6rem);
        font-weight: 700;
        letter-spacing: 14px;
        color: #fff;
        line-height: 1;
        margin-bottom: 0.8rem;
        text-indent: 14px;
        background: linear-gradient(180deg, #fff 40%, rgba(56, 217, 201, 0.5) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .a-sub {
        font-family: 'Source Sans Pro', sans-serif;
        font-size: 0.78rem;
        font-weight: 600;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: rgba(56, 217, 201, 0.8);
        margin-bottom: 1.6rem;
    }

    .a-rule {
        width: 50px;
        height: 2px;
        background: linear-gradient(90deg, var(--gold), rgba(56, 217, 201, 0.5));
        margin: 0 auto 1.6rem;
    }

    .a-desc {
        font-size: 1.08rem;
        color: rgba(255, 255, 255, 0.65);
        line-height: 1.8;
        max-width: 560px;
        margin: 0 auto 2.2rem;
    }

    .a-cta {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
    }

    /* ── FACTS STRIP ── */
    .a-facts-section {
        background: var(--cream);
        padding: 3.5rem 0;
    }

    .a-facts {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 0;
        max-width: 1100px;
        margin: 0 auto;
        background: #fff;
        border: 1px solid var(--border-warm);
        border-top: 3px solid var(--gold);
    }

    .a-fact {
        padding: 2rem 1.4rem;
        text-align: center;
        border-right: 1px solid var(--border-warm);
    }

    .a-fact:last-child {
        border-right: none;
    }

    .a-fact-val {
        display: block;
        font-family: 'Crimson Text', serif;
        font-size: 2.6rem;
        font-weight: 700;
        color: var(--deep-navy);
        line-height: 1;
        margin-bottom: 0.6rem;
    }

    .a-fact-lbl {
        display: block;
        font-family: 'Source Sans Pro', sans-serif;
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 1.4px;
        text-transform: uppercase;
        color: var(--text-medium);
        line-height: 1.45;
    }

    /* ── SHARED ── */
    .a-section {
        padding: 5.5rem 0;
    }

    .a-label {
        display: inline-block;
        font-family: 'Source Sans Pro', sans-serif;
        font-weight: 600;
        font-size: 0.68rem;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: var(--burgundy);
        background: var(--burgundy-surface);
        padding: 0.5rem 1.2rem;
        margin-bottom: 1.2rem;
    }

    .a-dark-label {
        display: inline-block;
        font-family: 'Source Sans Pro', sans-serif;
        font-weight: 600;
        font-size: 0.72rem;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: rgba(56, 217, 201, 0.85);
        background: rgba(56, 217, 201, 0.08);
        border: 1px solid rgba(56, 217, 201, 0.2);
        padding: 0.5rem 1.2rem;
        margin-bottom: 1.2rem;
    }

    .a-gold-rule {
        width: 50px;
        height: 2px;
        background: var(--gold);
        margin-bottom: 1.5rem;
    }

    .a-header {
        max-width: 720px;
        margin: 0 auto 3rem;
        text-align: center;
    }

    .a-header h2 { margin-bottom: 0.8rem; }
    .a-header-sub { font-size: 1.02rem; line-height: 1.75; color: var(--text-medium); }

    .a-narrow {
        max-width: 720px;
        margin: 0 auto;
        text-align: center;
    }

    .a-narrow h2 {
        color: var(--deep-navy);
        margin-bottom: 1.2rem;
        font-size: clamp(1.7rem, 3.2vw, 2.3rem);
        line-height: 1.25;
    }

    .a-narrow .a-gold-rule { margin-left: auto; margin-right: auto; }

    .a-narrow p {
        font-size: 1.05rem;
        line-height: 1.8;
        color: var(--text-medium);
        margin-bottom: 1rem;
    }

    .a-narrow em {
        font-style: italic;
        color: var(--burgundy);
    }

    .a-shield { background: var(--stone); }

    /* ── DARK ── */
    .a-gap,
    .a-caps {
        background: linear-gradient(135deg, #0a1628 0%, var(--navy) 50%, #162d4f 100%);
        position: relative;
        overflow: hidden;
    }

    .a-dark-bg {
        position: absolute;
        inset: 0;
        background-image: radial-gradient(ellipse at 50% 80%, rgba(56, 217, 201, 0.04) 0%, transparent 50%);
        pointer-events: none;
    }

    .a-gap::before,
    .a-caps::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: linear-gradient(90deg, transparent, rgba(56, 217, 201, 0.5), transparent);
        opacity: 0.5;
    }

    .a-gap h2,
    .a-caps h2 { color: #fff; }
    .a-gap .a-header-sub,
    .a-caps .a-header-sub { color: rgba(255, 255, 255, 0.55); }

    /* ── GAP CARDS ── */
    .a-gap-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        grid-auto-rows: 1fr;
        gap: 1.2rem;
        max-width: 1100px;
        margin: 0 auto;
    }

    .a-gap-card {
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.06);
        padding: 1.8rem 1.6rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        transition: all 0.3s ease;
    }

    .a-gap-card:hover { transform: translateY(-3px); }

    .a-gap-tag {
        font-family: 'Source Sans Pro', sans-serif;
        font-size: 0.62rem;
        font-weight: 700;
        letter-spacing: 2.5px;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.4);
    }

    .a-gap-card h3 {
        font-size: 1.2rem;
        color: #fff;
        margin: 0.2rem 0;
    }

    .a-gap-examples {
        font-family: 'Crimson Text', serif;
        font-style: italic;
        font-size: 0.95rem !important;
        color: rgba(56, 217, 201, 0.7) !important;
        margin: 0 0 0.4rem !important;
    }

    .a-gap-card p {
        font-size: 0.92rem;
        line-height: 1.7;
        color: rgba(255, 255, 255, 0.55);
        margin: 0;
    }

    .a-gap-card-on {
        background: rgba(56, 217, 201, 0.05);
        border-color: rgba(56, 217, 201, 0.25);
        border-top: 3px solid rgba(56, 217, 201, 0.7);
    }

    .a-gap-tag-on { color: rgba(56, 217, 201, 0.85) !important; }

    /* ── DUAL ── */
    .a-dual { background: var(--cream); }
    .a-dual h2 { color: var(--deep-navy); }

    .a-dual-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        grid-auto-rows: 1fr;
        gap: 1.2rem;
        max-width: 1000px;
        margin: 0 auto;
    }

    .a-dual-card {
        background: #fff;
        border: 1px solid var(--border-warm);
        border-left: 3px solid var(--gold);
        padding: 2rem 1.8rem;
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
        transition: all 0.3s ease;
    }

    .a-dual-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-warm-md); }

    .a-dual-tag {
        display: inline-block;
        font-family: 'Source Sans Pro', sans-serif;
        font-size: 0.62rem;
        font-weight: 700;
        letter-spacing: 2.5px;
        text-transform: uppercase;
        color: var(--burgundy);
        background: var(--burgundy-surface);
        padding: 0.3rem 0.7rem;
        align-self: flex-start;
    }

    .a-dual-tag-c {
        color: rgba(56, 217, 201, 0.95);
        background: rgba(56, 217, 201, 0.1);
    }

    .a-dual-card h3 {
        font-size: 1.4rem;
        color: var(--deep-navy);
        margin: 0.3rem 0 0.4rem;
    }

    .a-dual-card p {
        font-size: 0.95rem;
        line-height: 1.7;
        color: var(--text-medium);
        margin: 0;
    }

    /* ── CAPABILITIES (3x3) ── */
    .a-caps-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        grid-auto-rows: 1fr;
        gap: 1rem;
        max-width: 1100px;
        margin: 0 auto;
    }

    .a-cap {
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-top: 2px solid rgba(56, 217, 201, 0.5);
        padding: 1.5rem 1.4rem;
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
        transition: all 0.3s ease;
    }

    .a-cap:hover {
        background: rgba(255, 255, 255, 0.07);
        border-top-color: rgba(56, 217, 201, 0.9);
        transform: translateY(-3px);
    }

    .a-cap-num {
        font-family: 'Crimson Text', serif;
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--gold);
        opacity: 0.5;
        line-height: 1;
    }

    .a-cap h4 {
        font-size: 1rem;
        color: #fff;
        margin: 0.2rem 0;
    }

    .a-cap p {
        font-size: 0.88rem;
        line-height: 1.6;
        color: rgba(255, 255, 255, 0.55);
        margin: 0;
    }

    /* ── CLASSIFICATION TABLE ── */
    .a-class { background: var(--stone); }
    .a-class h2 { color: var(--deep-navy); }

    .a-class-table {
        max-width: 1000px;
        margin: 0 auto;
        background: #fff;
        border: 1px solid var(--border-warm);
        border-top: 3px solid var(--gold);
    }

    .a-class-row {
        display: grid;
        grid-template-columns: 1fr 1.4fr 1fr 0.8fr;
        gap: 1.4rem;
        padding: 1.1rem 1.5rem;
        border-bottom: 1px solid var(--border-warm);
        font-size: 0.95rem;
        color: var(--text-medium);
        align-items: center;
        line-height: 1.5;
    }

    .a-class-row:last-child {
        border-bottom: none;
    }

    .a-class-head {
        background: var(--cream);
        font-family: 'Source Sans Pro', sans-serif;
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: var(--burgundy);
    }

    .a-class-env {
        font-family: 'Crimson Text', serif;
        font-size: 1.02rem;
        font-weight: 700;
        color: var(--deep-navy);
    }

    /* ── CTA ── */
    .a-cta-section {
        background: linear-gradient(135deg, #060b16 0%, var(--deep-navy) 50%, #162d4f 100%);
        padding: 5.5rem 2rem;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

