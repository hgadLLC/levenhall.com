---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';

const frameworks = [
    { region: 'EU', name: 'EU AI Act' },
    { region: 'US', name: 'NIST AI RMF' },
    { region: 'US · CO', name: 'Colorado SB 205' },
    { region: 'US · NYC', name: 'NYC Local Law 144' },
    { region: 'CA', name: 'Canada AIDA' },
    { region: 'UK', name: 'UK AI Principles' },
    { region: 'SG', name: 'Singapore Model AI' },
    { region: 'AU', name: 'Australia AI Ethics' },
];

/* Matrix instrument: rows = the eight frameworks, cols = obligation cells.
   Coverage pattern is illustrative linework, drawn from the product's own concept. */
const matrixRows = frameworks.map(f => f.region + ' — ' + f.name);
const covered = new Set([
    0,1,2,3,4,5,6,8,9,11,
    12,13,14,15,17,18,20,22,
    24,25,26,28,29,31,33,
    36,37,38,39,40,42,44,46,
    48,49,51,52,54,56,
    60,61,62,63,65,67,68,
    72,73,75,77,80,
    84,85,86,88,90,92,94
]);
const pulsing = new Set([5, 17, 29, 42, 56, 68, 90]);
---

<BaseLayout title="AIGIS by Levenhall — The system of record for AI governance" description="Prove your AI is compliant in every jurisdiction you operate in. Inventory, map, test, and prove — audit-ready evidence for the EU AI Act, NIST AI RMF, Colorado SB 205, NYC LL 144, and every framework in between.">

    <PageHeader
        label="Systems / AIGIS / A Levenhall Product"
        index="02"
        title="Prove your AI is compliant. In every jurisdiction you operate in."
    />

    <!-- ── CONSOLE: STATEMENT + COVERAGE MATRIX ── -->
    <section class="console sweep-field texture-grain">
        <div class="console-grid">
            <div class="console-statement">
                <img src="/images/products/aigis-lockup.png" alt="AIGIS by Levenhall" class="brand-lockup" />
                <p class="console-lede">AIGIS is the system of record for AI governance. Inventory your AI systems, map them to the regulations that apply, run the regulator's own tests, and produce audit-ready evidence &mdash; so compliance is defensible, not a spreadsheet.</p>
                <div class="btn-group console-cta">
                    <a href="https://aigis.levenhall.com/register" class="btn btn-primary" target="_blank" rel="noopener noreferrer">Request Access</a>
                    <a href="https://aigis.levenhall.com/demo" class="mono-link" target="_blank" rel="noopener noreferrer">See the Interactive Demo →</a>
                </div>
                <p class="console-meta">Live at <a href="https://aigis.levenhall.com" target="_blank" rel="noopener noreferrer">aigis.levenhall.com</a></p>
            </div>

            <div class="console-instrument" aria-hidden="true">
                <div class="inst-head">
                    <span>Framework Coverage Matrix</span>
                    <span class="inst-live">● Regulatory Graph</span>
                </div>
                <svg class="inst-svg" viewBox="0 0 484 262" xmlns="http://www.w3.org/2000/svg">
                    <text class="mx-col-note" x="168" y="12">OBLIGATIONS · ARTICLE BY ARTICLE, CONTROL BY CONTROL</text>
                    {matrixRows.map((label, r) => (
                        <g>
                            <text class="mx-row" x="158" y={38 + r * 28} text-anchor="end">{label.toUpperCase()}</text>
                            {Array.from({ length: 12 }, (_, c) => {
                                const i = r * 12 + c;
                                const cls = covered.has(i) ? (pulsing.has(i) ? 'mx-cell-on mx-cell-pulse' : 'mx-cell-on') : 'mx-cell';
                                return <rect x={168 + c * 26} y={26 + r * 28} width="18" height="18" class={cls} />;
                            })}
                        </g>
                    ))}
                </svg>
                <div class="inst-foot">
                    <span>Representative mapping</span>
                    <span class="inst-cyan">Classified once · mapping travels</span>
                </div>
            </div>
        </div>
    </section>

    <!-- ── REGISTRY ── -->
    <section class="section">
        <div class="container">
            <div class="reg-grid">
                <div class="reg-copy">
                    <span class="section-label">§ AI System Registry</span>
                    <h2>Every AI system, every jurisdiction, every regulator's test.</h2>
                    <p>The registry is the spine of the platform. Register every AI system in production &mdash; internal models, vendor systems, GenAI &mdash; and AIGIS classifies risk tier, auto-maps the obligations that apply, and runs the tests the regulator would run. When the auditor knocks, the evidence is already there.</p>
                </div>
                <aside class="spec-panel">
                    <div class="spec-head">
                        <div>
                            <span class="spec-name">Loan Underwriting Model</span>
                            <span class="spec-cat">Credit &amp; Lending &middot; EU &middot; NYC &middot; Colorado</span>
                        </div>
                        <span class="spec-tier">Tier: High Risk</span>
                    </div>
                    <div class="spec-block">
                        <span class="spec-block-label">Regulatory mapping</span>
                        <ul class="spec-rows">
                            <li><span class="spec-key">EU AI Act — Art. 9</span><span class="status status-ok">Compliant</span></li>
                            <li><span class="spec-key">EU AI Act — Art. 10</span><span class="status status-warn">In progress</span></li>
                            <li><span class="spec-key">Colorado SB 205</span><span class="status status-ok">Compliant</span></li>
                            <li><span class="spec-key">NYC Local Law 144</span><span class="status status-fail">Non-compliant</span></li>
                        </ul>
                    </div>
                    <div class="spec-block">
                        <span class="spec-block-label">Latest bias test</span>
                        <div class="bias-row">
                            <span class="bias-val">DI 0.66</span>
                            <span class="status status-fail">FAIL</span>
                        </div>
                        <span class="bias-detail">female 41% vs male 62% selection</span>
                    </div>
                </aside>
            </div>
        </div>
    </section>

    <!-- ── ONE PLATFORM · EVERY FRAMEWORK (PANEL) ── -->
    <section class="section section-panel">
        <div class="container">
            <div class="section-header">
                <span class="section-label">§ One platform &middot; every framework</span>
                <h2>The regulations, mapped once.</h2>
                <p>Frameworks are added and updated by Levenhall's regulatory team. You classify the system once. The mapping travels with it.</p>
            </div>
            <div class="fw-grid">
                {frameworks.map(fw => (
                    <div class="fw-cell">
                        <span class="fw-region">{fw.region}</span>
                        <span class="fw-name">{fw.name}</span>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- ── THE PLATFORM (PAPER — the one light passage) ── -->
    <section class="section section-paper">
        <div class="container">
            <div class="plat-grid">
                <aside class="plat-rail">
                    <span class="section-label">§ The platform</span>
                    <h2>Four steps.<br/>Four proofs.</h2>
                    <ol class="plat-toc">
                        <li><span>01</span>Inventory</li>
                        <li><span>02</span>Map</li>
                        <li><span>03</span>Test</li>
                        <li><span>04</span>Prove</li>
                    </ol>
                </aside>
                <div class="plat-body">
                    <article class="plat-step">
                        <span class="lg-num">01</span>
                        <div>
                            <h3>Inventory</h3>
                            <p>Register every AI or ML system in production &mdash; internal, vendor, GenAI. Owner, purpose, data source, deployment context, jurisdiction of use.</p>
                        </div>
                    </article>
                    <article class="plat-step">
                        <span class="lg-num">02</span>
                        <div>
                            <h3>Map</h3>
                            <p>AIGIS classifies risk tier and auto-maps obligations across every market the system touches &mdash; article by article, control by control &mdash; using the regulatory graph maintained by Levenhall.</p>
                        </div>
                    </article>
                    <article class="plat-step">
                        <span class="lg-num">03</span>
                        <div>
                            <h3>Test</h3>
                            <p>Run the tests the regulator runs: bias and disparate impact, robustness, toxicity, hallucination, data provenance. Automated where the regulator accepts automation, routed for human review where it doesn't.</p>
                        </div>
                    </article>
                    <article class="plat-step">
                        <span class="lg-num">04</span>
                        <div>
                            <h3>Prove</h3>
                            <p>Generate the artefacts the board, the underwriter, and the regulator ask for: technical documentation, conformance reports, incident logs, an audit-ready evidence pack that maps to each obligation.</p>
                        </div>
                    </article>
                </div>
            </div>
        </div>
    </section>

    <!-- ── COVERAGE ── -->
    <section class="section">
        <div class="container">
            <div class="section-header">
                <span class="section-label">§ Coverage</span>
                <h2>Every market that regulates AI.</h2>
            </div>
            <div class="cov-grid">
                <div class="cov-cell">
                    <span class="cov-flag">🇺🇸 🇨🇦</span>
                    <h4>North America</h4>
                    <p>EU AI Act readiness for North American exporters, Colorado SB 205, NYC Local Law 144, Canada AIDA, NIST AI RMF.</p>
                </div>
                <div class="cov-cell">
                    <span class="cov-flag">🇪🇺 🇬🇧</span>
                    <h4>Europe</h4>
                    <p>EU AI Act (full title mapping), UK AI Principles and member-state guidance.</p>
                </div>
                <div class="cov-cell">
                    <span class="cov-flag">🇦🇺 🇳🇿</span>
                    <h4>Australia &amp; NZ</h4>
                    <p>Australia AI Ethics Principles, New Zealand Algorithm Charter.</p>
                </div>
                <div class="cov-cell">
                    <span class="cov-flag">🇸🇬 🇯🇵 🇰🇷</span>
                    <h4>Asia</h4>
                    <p>Singapore Model AI Governance, Japan and South Korea guidance, more added continuously.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ── PROTECT YOUR AI (PANEL) ── -->
    <section class="section section-panel">
        <div class="container">
            <div class="ins-grid">
                <div class="ins-copy">
                    <span class="section-label">§ Protect your AI</span>
                    <h2>The AI you can prove is the AI you can insure.</h2>
                    <p>AIGIS matches your evaluation record against the AI insurance market. Twenty-four carriers, four live feeds, eight partner feeds. Get an insurability score based on the same evidence your regulator will see.</p>
                    <p>For underwriters, the record is a continuous signal to price against. For brokers, a defensible file at renewal. For the enterprise, coverage that doesn't require a fire drill every quarter.</p>
                </div>
                <aside class="spec-panel">
                    <div class="spec-head">
                        <span class="ins-score">72<span class="ins-of">/100</span></span>
                        <span class="ins-verdict">Insurable</span>
                    </div>
                    <svg class="ins-gauge" viewBox="0 0 320 34" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <line class="g-track" x1="4" y1="16" x2="316" y2="16" />
                        {Array.from({ length: 11 }, (_, i) => (
                            <line class="g-tick" x1={4 + i * 31.2} y1="12" x2={4 + i * 31.2} y2="20" />
                        ))}
                        <line class="g-fill" x1="4" y1="16" x2="228.6" y2="16" />
                        <circle class="g-marker" cx="228.6" cy="16" r="3" />
                        <text class="g-note" x="4" y="32">0</text>
                        <text class="g-note g-note-end" x="316" y="32">100</text>
                    </svg>
                    <div class="spec-block">
                        <span class="spec-block-label">Coverage categories</span>
                        <ul class="spec-rows">
                            <li><span class="spec-key">AI Liability &amp; E&amp;O</span></li>
                            <li><span class="spec-key">Algorithmic Bias &amp; Discrimination</span></li>
                            <li><span class="spec-key">Regulatory Defense &amp; Penalty</span></li>
                        </ul>
                    </div>
                    <div class="spec-block">
                        <span class="spec-block-label">Matched carriers</span>
                        <ul class="spec-rows">
                            <li><span class="spec-key">Armilla AI</span><span class="carrier-pct">99%</span></li>
                            <li><span class="spec-key">Coalition</span><span class="carrier-pct">99%</span></li>
                            <li><span class="spec-key">Counterpart</span><span class="carrier-pct">99%</span></li>
                            <li><span class="spec-key">Relm Insurance</span><span class="carrier-pct">96%</span></li>
                            <li><span class="spec-key">Resilience</span><span class="carrier-pct">96%</span></li>
                        </ul>
                    </div>
                </aside>
            </div>
        </div>
    </section>

    <!-- ── CTA ── -->
    <section class="section">
        <div class="container">
            <div class="cta-block rule-top">
                <span class="route-line">Live Now &middot; v2026.06 <span class="live-cyan">●</span></span>
                <h2>Built for regulated enterprises.<br/>Financial services, insurance, healthcare.</h2>
                <p>Request access to the platform, or step through an industry-specific walkthrough of the interactive demo.</p>
                <div class="btn-group">
                    <a href="https://aigis.levenhall.com/register" class="btn btn-primary" target="_blank" rel="noopener noreferrer">Request Access</a>
                    <a href="https://aigis.levenhall.com/demo" class="btn btn-outline-white" target="_blank" rel="noopener noreferrer">See the Demo</a>
                </div>
            </div>
        </div>
    </section>

</BaseLayout>

<style>
    /* AIGIS brand exception (DESIGN.md): cyan #38D9C9 is reserved for the AIGIS
       product family — used here for live/data elements in place of gold. */

    /* ── CONSOLE ── */
    .console {
        border-bottom: 1px solid var(--hairline);
        position: relative;
    }

    .console-grid {
        display: grid;
        grid-template-columns: minmax(0, 50fr) minmax(0, 50fr);
        max-width: var(--col-wide);
        margin: 0 auto;
    }

    .console-statement {
        padding: 3.5rem 3rem 3.5rem 2rem;
        border-right: 1px solid var(--hairline);
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: flex-start;
        gap: 1.8rem;
    }

    .brand-lockup {
        width: 220px;
        height: auto;
        filter: brightness(0) invert(1);
    }

    .console-lede {
        max-width: 52ch;
        font-size: 1.02rem;
        color: var(--muted);
    }

    .console-cta { margin-top: 0.4rem; }

    .console-meta {
        font-family: var(--mono);
        font-size: 0.62rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--dim);
    }
    .console-meta a { color: #38d9c9; text-decoration: none; }
    .console-meta a:hover { border-bottom: 1px solid #38d9c9; }

    /* ── INSTRUMENT: COVERAGE MATRIX ── */
    .console-instrument {
        padding: 2.4rem 2rem 1.6rem 2.4rem;
        font-family: var(--mono);
        display: flex;
        flex-direction: column;
        justify-content: center;
        background-image:
            linear-gradient(var(--hairline-soft) 1px, transparent 1px),
            linear-gradient(90deg, var(--hairline-soft) 1px, transparent 1px);
        background-size: 28px 28px;
    }

    .inst-head, .inst-foot {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        font-size: 0.6rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--dim);
    }

    .inst-head {
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--hairline);
        margin-bottom: 1.2rem;
    }

    .inst-foot {
        padding-top: 1rem;
        border-top: 1px solid var(--hairline);
        margin-top: 1.2rem;
        font-size: 0.56rem;
    }

    .inst-live { color: #38d9c9; animation: pulse-cyan 2.4s ease-in-out infinite; }
    .inst-cyan { color: #38d9c9; }

    .inst-svg { width: 100%; height: auto; display: block; }

    .mx-col-note {
        font-family: var(--mono);
        font-size: 8px;
        letter-spacing: 0.14em;
        fill: var(--dim);
    }

    .mx-row {
        font-family: var(--mono);
        font-size: 8.5px;
        letter-spacing: 0.08em;
        fill: var(--muted);
    }

    .mx-cell { fill: none; stroke: var(--hairline); stroke-width: 1; }
    .mx-cell-on { fill: rgba(56, 217, 201, 0.45); stroke: none; }
    .mx-cell-pulse { animation: pulse-cyan 3.2s ease-in-out infinite; }

    @keyframes pulse-cyan {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.3; }
    }

    /* ── REGISTRY / INSURANCE GRIDS ── */
    .reg-grid, .ins-grid {
        display: grid;
        grid-template-columns: minmax(0, 5fr) minmax(0, 5fr);
        gap: 4rem;
        align-items: start;
    }

    .reg-copy h2, .ins-copy h2 { margin-bottom: 1.4rem; }
    .reg-copy p, .ins-copy p { margin-bottom: 1rem; max-width: 56ch; }

    /* ── SPEC PANEL (mono documentation card, hairline only) ── */
    .spec-panel {
        border: 1px solid var(--hairline);
        background: var(--ink);
        padding: 1.8rem 2rem 2rem;
        font-family: var(--mono);
    }

    .spec-head {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 1.5rem;
        padding-bottom: 1.2rem;
        border-bottom: 1px solid var(--hairline);
        margin-bottom: 1.4rem;
    }

    .spec-name {
        display: block;
        font-family: var(--serif);
        font-weight: 600;
        font-size: 1.2rem;
        letter-spacing: -0.01em;
        color: var(--bone);
        margin-bottom: 0.35rem;
    }

    .spec-cat {
        display: block;
        font-size: 0.6rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--dim);
    }

    .spec-tier {
        font-size: 0.6rem;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--burgundy-bright);
        white-space: nowrap;
    }

    .spec-block { margin-bottom: 1.4rem; }
    .spec-block:last-child { margin-bottom: 0; }

    .spec-block-label {
        display: block;
        font-size: 0.58rem;
        font-weight: 500;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: #38d9c9;
        margin-bottom: 0.6rem;
    }

    .spec-rows { list-style: none; margin: 0; padding: 0; }

    .spec-rows li {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 1rem;
        padding: 0.55rem 0;
        border-bottom: 1px solid var(--hairline-soft);
        font-size: 0.74rem;
    }
    .spec-rows li:last-child { border-bottom: none; }

    .spec-key { color: var(--muted); }

    .status {
        font-size: 0.58rem;
        font-weight: 700;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        white-space: nowrap;
    }
    .status-ok { color: #4caf7d; }
    .status-warn { color: var(--gold); }
    .status-fail { color: #d0604f; }

    .bias-row {
        display: flex;
        align-items: baseline;
        gap: 1.2rem;
        margin-bottom: 0.4rem;
    }

    .bias-val {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--bone);
        font-variant-numeric: tabular-nums;
    }

    .bias-detail {
        font-size: 0.68rem;
        color: var(--dim);
        letter-spacing: 0.04em;
    }

    /* ── FRAMEWORKS ── */
    .fw-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        border: 1px solid var(--hairline);
    }

    .fw-cell {
        padding: 1.5rem 1.6rem 1.6rem;
        border-right: 1px solid var(--hairline);
        border-bottom: 1px solid var(--hairline);
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
        background: var(--ink);
        transition: background var(--t-short);
    }
    .fw-cell:nth-child(4n) { border-right: none; }
    .fw-cell:nth-child(n+5) { border-bottom: none; }
    .fw-cell:hover { background: var(--ink-panel); }

    .fw-region {
        font-family: var(--mono);
        font-size: 0.58rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: #38d9c9;
    }

    .fw-name {
        font-weight: 600;
        font-size: 0.95rem;
        color: var(--bone);
    }

    /* ── PLATFORM (PAPER) ── */
    .plat-grid {
        display: grid;
        grid-template-columns: minmax(0, 4fr) minmax(0, 6fr);
        gap: 4rem;
        align-items: start;
    }

    .plat-rail { position: sticky; top: 100px; }
    .plat-rail h2 { margin-bottom: 1.6rem; }

    .plat-toc {
        list-style: none;
        margin: 0;
        padding: 0;
        border-top: 1px solid var(--hairline-paper);
        max-width: 260px;
    }

    .plat-toc li {
        display: grid;
        grid-template-columns: 44px 1fr;
        gap: 0.6rem;
        padding: 0.65rem 0;
        border-bottom: 1px solid var(--hairline-paper);
        font-family: var(--mono);
        font-size: 0.68rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--text-medium);
    }

    .plat-toc li span {
        font-family: var(--serif);
        font-style: italic;
        font-size: 0.95rem;
        color: var(--gold);
        text-transform: none;
        letter-spacing: 0;
    }

    .plat-body { border-top: 1px solid var(--hairline-paper); }

    .plat-step {
        display: grid;
        grid-template-columns: 64px 1fr;
        gap: 1.6rem;
        padding: 1.8rem 0.5rem;
        border-bottom: 1px solid var(--hairline-paper);
    }

    .lg-num {
        font-family: var(--serif);
        font-style: italic;
        font-weight: 400;
        font-size: 1.6rem;
        color: var(--gold);
        line-height: 1.2;
    }

    .plat-step h3 { margin-bottom: 0.5rem; }
    .plat-step p { font-size: 0.98rem; line-height: 1.75; max-width: 60ch; }

    /* ── COVERAGE ── */
    .cov-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        border: 1px solid var(--hairline);
    }

    .cov-cell {
        padding: 1.8rem 1.8rem 2rem;
        border-right: 1px solid var(--hairline);
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
        background: var(--ink);
        transition: background var(--t-short);
    }
    .cov-cell:last-child { border-right: none; }
    .cov-cell:hover { background: var(--ink-panel); }

    .cov-flag { font-size: 1.25rem; line-height: 1; }
    .cov-cell h4 { color: var(--bone); }
    .cov-cell p { font-size: 0.88rem; line-height: 1.65; color: var(--muted); }

    /* ── INSURANCE PANEL ── */
    .ins-score {
        font-family: var(--serif);
        font-weight: 600;
        font-size: 2.8rem;
        line-height: 1;
        color: var(--bone);
        letter-spacing: -0.02em;
    }

    .ins-of {
        font-size: 1.2rem;
        color: var(--dim);
    }

    .ins-verdict {
        font-size: 0.62rem;
        font-weight: 700;
        letter-spacing: 0.2em;
        text-transform: uppercase;
