---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import CTASection from '../components/CTASection.astro';
import { services } from '../data/services';

const romans = ['I', 'II', 'III', 'IV', 'V'];
---

<BaseLayout title="Services | Levenhall" description="Levenhall's services — market intelligence at the core, with US federal market entry, rapid procurement, executive placement, and cross-border tax built on top.">

    <PageHeader
        label="Our Practice"
        title="What We Do"
    />

    <!-- ── INTRO + DOSSIER INDEX (INK) ── -->
    <section class="section intro-section texture-grain">
        <div class="container">
            <div class="intro-grid">
                <div class="intro-content">
                    <span class="section-label">Our Practice</span>
                    <p class="intro-lead">Levenhall is a market intelligence consulting firm. Our services start with intelligence on the markets that matter most &mdash; defense, government, geopolitical, and dual-use &mdash; and extend into the structure required to act on what that intelligence reveals.</p>
                    <p class="intro-sub">US federal market entry is one of our most active practice areas, but it is one avenue, not the whole firm. Every engagement is tailored. We do not sell packaged solutions. Your market, your decision cadence, and your operating posture determine the pathway we recommend.</p>
                </div>
                <nav class="dossier-index" aria-label="Service index">
                    <span class="di-head route-line">Levenhall / Practice / Index</span>
                    {services.map((service, i) => (
                        <a href={`#${service.id}`} class="di-row">
                            <span class="di-num">{romans[i]}.</span>
                            <span class="di-label">{service.label}</span>
                            <span class="di-title">{service.title}</span>
                            <span class="di-arrow">→</span>
                        </a>
                    ))}
                </nav>
            </div>
        </div>
    </section>

    <!-- ── SERVICE DOSSIER ENTRIES (ALTERNATING INK / PANEL) ── -->
    {services.map((service, i) => (
        <section id={service.id} class={`section svc-section ${i % 2 === 1 ? 'section-panel' : 'section-ink'}`}>
            <div class="container">
                <span class="route-line svc-route">File 0{i + 1} / {service.label}</span>
                <div class="svc-head">
                    <span class="svc-roman">{romans[i]}.</span>
                    <h2>{service.title}</h2>
                </div>
                <div class="svc-grid">
                    <div class="svc-body">
                        {service.description.map(para => (
                            <p>{para}</p>
                        ))}
                        {service.externalLink && (
                            <a href={service.externalLink} class="mono-link svc-ext" target="_blank" rel="noopener noreferrer">Learn More →</a>
                        )}
                    </div>
                    <aside class="svc-aside">
                        <div class="svc-metric">
                            <span class="svc-metric-value">{service.highlight.value}</span>
                            <span class="svc-metric-label">{service.highlight.label}</span>
                        </div>
                        <div class="svc-deliverables">
                            <h4>Key Deliverables</h4>
                            <ul>
                                {service.deliverables.map((item, j) => (
                                    <li>
                                        <span class="del-idx">0{j + 1}</span>
                                        <span class="del-text">{item}</span>
                                    </li>
                                ))}
                            </ul>
                        </div>
                    </aside>
                </div>
            </div>
        </section>
    ))}

    <!-- ── ENGAGEMENT PROCESS (STONE — the one light passage) ── -->
    <section class="section section-stone process-section">
        <div class="container">
            <div class="section-header">
                <span class="section-label">How We Work</span>
                <h2>Engagement Process</h2>
                <p>From initial assessment through execution, Levenhall stays engaged. Intelligence informs strategy. Strategy drives structure. Structure produces outcomes.</p>
            </div>
            <div class="process-grid">
                <div class="process-step">
                    <span class="step-number">01</span>
                    <h3>Intelligence &amp; Assessment</h3>
                    <p>Confidential discussion of your market, your decision cadence, and your organizational readiness. We assess the intelligence we already hold against the questions you actually need answered, and tell you honestly whether Levenhall is the right partner.</p>
                </div>
                <div class="process-step">
                    <span class="step-number">02</span>
                    <h3>Strategy Development</h3>
                    <p>Detailed market mapping, competitor and program tracking, procurement vehicle analysis, regulatory pathway identification, and partnership architecture. The intelligence becomes an operational plan.</p>
                </div>
                <div class="process-step">
                    <span class="step-number">03</span>
                    <h3>Execution</h3>
                    <p>Entity formation, consortium membership, executive placement, procurement vehicle selection, and active positioning with target agencies and partners. Levenhall stays engaged through award, close, or whichever outcome the engagement is built around.</p>
                </div>
            </div>
        </div>
    </section>

    <CTASection />

</BaseLayout>

<style>
    /* ── INTRO + DOSSIER INDEX ── */
    .intro-grid {
        display: grid;
        grid-template-columns: minmax(0, 6fr) minmax(0, 5fr);
        gap: 4rem;
        align-items: start;
    }

    .intro-lead {
        font-size: 1.15rem;
        line-height: 1.7;
        color: var(--bone);
        margin-bottom: 1.2rem;
    }

    .intro-sub {
        font-size: 1rem;
        line-height: 1.7;
        color: var(--muted);
        max-width: 58ch;
    }

    .dossier-index {
        display: block;
        border-top: 1px solid var(--hairline);
    }

    .di-head {
        display: block;
        padding: 0.9rem 0.2rem;
        border-bottom: 1px solid var(--hairline);
    }

    .di-row {
        display: grid;
        grid-template-columns: 40px 118px minmax(0, 1fr) 24px;
        gap: 1rem;
        align-items: baseline;
        padding: 1rem 0.2rem;
        border-bottom: 1px solid var(--hairline);
        text-decoration: none;
        transition: background var(--t-short);
    }
    .di-row:hover { background: var(--ink-panel); }

    .di-num {
        font-family: var(--serif);
        font-style: italic;
        font-weight: 400;
        font-size: 1.1rem;
        color: var(--gold);
    }

    .di-label {
        font-family: var(--mono);
        font-size: 0.58rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--dim);
    }

    .di-title {
        font-family: var(--serif);
        font-weight: 600;
        font-size: 1.02rem;
        color: var(--bone);
        line-height: 1.25;
    }

    .di-arrow {
        font-family: var(--mono);
        color: var(--dim);
        transition: color var(--t-short), transform var(--t-short) var(--ease-enter);
    }
    .di-row:hover .di-arrow { color: var(--gold); transform: translateX(4px); }

    /* ── SERVICE DOSSIER ENTRIES ── */
    .svc-route {
        display: block;
        margin-bottom: 1.6rem;
    }

    .svc-head {
        display: flex;
        align-items: baseline;
        gap: 1.4rem;
        padding-bottom: 1.6rem;
        border-bottom: 1px solid var(--hairline);
        margin-bottom: 2.4rem;
    }

    .svc-roman {
        font-family: var(--serif);
        font-style: italic;
        font-weight: 400;
        font-size: clamp(1.8rem, 3vw, 2.6rem);
        color: var(--gold);
        flex-shrink: 0;
    }

    .svc-head h2 {
        font-size: clamp(1.7rem, 3vw, 2.4rem);
    }

    .svc-grid {
        display: grid;
        grid-template-columns: minmax(0, 7fr) minmax(0, 4fr);
        gap: 4rem;
        align-items: start;
    }

    .svc-body p {
        font-size: 1.02rem;
        line-height: 1.75;
        margin-bottom: 1rem;
        color: var(--muted);
        max-width: 66ch;
    }

    .svc-ext {
        display: inline-block;
        margin-top: 1rem;
    }

    /* Metric block — mono figure, hairline frame */
    .svc-aside {
        border: 1px solid var(--hairline);
    }

    .svc-metric {
        padding: 1.6rem 1.6rem 1.4rem;
        border-bottom: 1px solid var(--hairline);
        font-family: var(--mono);
    }

    .svc-metric-value {
        display: block;
        font-size: 2rem;
        font-weight: 500;
        letter-spacing: 0.01em;
        color: var(--gold);
        font-variant-numeric: tabular-nums;
        line-height: 1.1;
    }

    .svc-metric-label {
        display: block;
        margin-top: 0.5rem;
        font-size: 0.6rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--dim);
    }

    /* Deliverables — hairline-ruled mono checklist */
    .svc-deliverables {
        padding: 1.4rem 1.6rem 1.6rem;
    }

    .svc-deliverables h4 {
        margin-bottom: 0.6rem;
    }

    .svc-deliverables ul {
        list-style: none;
        margin: 0;
        padding: 0;
    }

    .svc-deliverables li {
        display: grid;
        grid-template-columns: 28px minmax(0, 1fr);
        gap: 0.9rem;
        align-items: baseline;
        padding: 0.7rem 0;
        border-bottom: 1px solid var(--hairline-soft);
    }
    .svc-deliverables li:last-child { border-bottom: none; }

    .del-idx {
        font-family: var(--mono);
        font-size: 0.6rem;
        letter-spacing: 0.1em;
        color: var(--gold);
        font-variant-numeric: tabular-nums;
    }

    .del-text {
        font-size: 0.92rem;
        line-height: 1.5;
        color: var(--muted);
    }

    /* ── PROCESS (STONE) ── */
    .process-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        border-top: 1px solid var(--hairline-paper);
        border-left: 1px solid var(--hairline-paper);
    }

    .process-step {
        padding: 2rem 2rem 2.2rem;
        border-right: 1px solid var(--hairline-paper);
        border-bottom: 1px solid var(--hairline-paper);
    }

    .step-number {
        display: block;
        font-family: var(--mono);
        font-size: 0.72rem;
        font-weight: 500;
        letter-spacing: 0.2em;
        color: var(--burgundy);
        margin-bottom: 1.1rem;
    }

    .process-step h3 {
        font-size: 1.2rem;
        margin-bottom: 0.8rem;
    }

    .process-step p {
        font-size: 0.92rem;
        line-height: 1.65;
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 992px) {
        .intro-grid { grid-template-columns: 1fr; gap: 2.5rem; }
        .svc-grid { grid-template-columns: 1fr; gap: 2.2rem; }
        .process-grid { grid-template-columns: 1fr; }
    }

    @media (max-width: 768px) {
        .di-row { grid-template-columns: 32px minmax(0, 1fr) 24px; }
        .di-label { display: none; }
        .svc-head { flex-direction: column; gap: 0.6rem; }
    }
</style>
