---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import CTASection from '../components/CTASection.astro';
---

<BaseLayout title="About | Levenhall" description="Levenhall is a Washington, DC-based market intelligence consulting firm serving defense, government, and dual-use markets. Intelligence, market entry, ventures, and proprietary products.">

    <PageHeader
        label="About Levenhall"
        title="Who We Are"
    />

    <!-- ── FIRM OVERVIEW ── -->
    <section class="section firm-section">
        <div class="container">
            <div class="firm-grid reveal">
                <div class="firm-text">
                    <h2>The Firm</h2>
                    <div class="firm-rule"></div>
                    <p>Levenhall is a Washington, DC-based market intelligence consulting firm. We work in the markets where information asymmetry decides outcomes &mdash; defense procurement, allied government programs, regulated dual-use technology, and the geopolitical environment that shapes all three.</p>
                    <p>Our intelligence practice is the core. From it, we run a connected set of avenues: a US federal market entry practice for allied defense and government technology firms, an investment arm (Levenhall Ventures) that takes equity in five companies a year in exchange for hands-on execution, and proprietary products &mdash; BRIDGER and AIGIS &mdash; that operationalize what we know.</p>
                    <p>What unites the work is method. We do not broker introductions or sell off-the-shelf reports. We build a source-grounded picture of the market, identify where a client can act, and architect the structure required to act there. Every engagement is designed to produce a specific outcome, whether that outcome is a contract, an investment thesis, a placed executive, or a decision the client could not have made on their own information.</p>
                </div>
                <div class="firm-sidebar">
                    <div class="sidebar-card">
                        <span class="sidebar-icon">&#9670;</span>
                        <h4>Washington, DC</h4>
                        <p>Headquartered in the capital, where procurement decisions are made and intelligence flows.</p>
                    </div>
                    <div class="sidebar-card">
                        <span class="sidebar-icon">&#9670;</span>
                        <h4>Intelligence-Led</h4>
                        <p>Every engagement begins with a source-grounded picture of the market. Advice, structure, and execution flow from there.</p>
                    </div>
                    <div class="sidebar-card">
                        <span class="sidebar-icon">&#9670;</span>
                        <h4>Allied-Aligned</h4>
                        <p>Serving firms, investors, and program offices in trusted democracies with shared security frameworks and interoperable clearances.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ── WHAT WE DO (LIGHT, NEW) ── -->
    <section class="section avenues-section">
        <div class="container">
            <div class="section-header reveal">
                <span class="avenues-label">What We Do</span>
                <h2>Four Connected Avenues</h2>
                <p>One firm, one method, four ways we put intelligence to work.</p>
            </div>
            <div class="avenues-grid reveal">
                <div class="avenue-detail">
                    <span class="avenue-num">01</span>
                    <h3>Market Intelligence</h3>
                    <p>The core. Decision-grade research, monitoring, and analysis on defense, government, geopolitical, and dual-use markets. One-time assessments and continuous retainers.</p>
                    <a href="/services#market-intelligence" class="avenue-link">Intelligence Practice &rarr;</a>
                </div>
                <div class="avenue-detail">
                    <span class="avenue-num">02</span>
                    <h3>US Federal Market Entry</h3>
                    <p>Strategy, rapid procurement (CSO / OTA), executive placement, and cross-border tax structuring for allied defense and government technology firms entering the US.</p>
                    <a href="/services" class="avenue-link">Market Entry &rarr;</a>
                </div>
                <div class="avenue-detail">
                    <span class="avenue-num">03</span>
                    <h3>Levenhall Ventures</h3>
                    <p>Our investment arm. Services at cost in exchange for equity. Five allied defense and government technology companies a year. No fund-style fees.</p>
                    <a href="/ventures" class="avenue-link">Ventures &rarr;</a>
                </div>
                <div class="avenue-detail">
                    <span class="avenue-num">04</span>
                    <h3>Products: BRIDGER, AIGIS &amp; Intelligence</h3>
                    <p>BRIDGER is our pre-RFP intelligence platform for US federal contracting. AIGIS is our AI evaluation and governance platform for the private sector &mdash; the substrate for AI insurability. Intelligence is our live geopolitical operating picture for corporate risk functions.</p>
                    <a href="/products/bridger" class="avenue-link">Bridger</a>
                    <a href="/products/aigis" class="avenue-link">AIGIS</a>
                    <a href="/products/intelligence" class="avenue-link">Intelligence</a>
                </div>
            </div>
        </div>
    </section>

    <!-- ── APPROACH (DARK) ── -->
    <section class="section approach-section">
        <div class="approach-bg"></div>
        <div class="container approach-inner">
            <div class="approach-grid">
                <div class="approach-text reveal">
                    <span class="approach-label">Our Approach</span>
                    <h2>Intelligence First. Structure, Not Access.</h2>
                    <div class="approach-rule"></div>
                    <p>Most consulting firms sell access or sell reports. Levenhall does neither. We sell a method: build a source-grounded picture of the market, then architect the structure required to act in it.</p>
                    <p>Access is temporary. A meeting, a referral, a conference introduction: these create moments, not positions. Structure is durable. The right intelligence cadence, the right entity formation, the right procurement vehicle, the right consortium membership, the right US-based leadership: these create a foundation that generates opportunities for years.</p>
                    <p>We are selective about the firms we work with. Every engagement undergoes conflict and compliance review. We represent a limited number of clients in any given technology domain, ensuring that our intelligence work and institutional knowledge serve each client without dilution.</p>
                </div>
                <div class="approach-pillars reveal">
                    <div class="pillar">
                        <div class="pillar-number">01</div>
                        <h4>Selectivity</h4>
                        <p>We take on a limited number of engagements. This is by design. Our effectiveness depends on deep commitment, not broad reach.</p>
                    </div>
                    <div class="pillar">
                        <div class="pillar-number">02</div>
                        <h4>Discretion</h4>
                        <p>Defense market positioning involves sensitive information, classified environments, and consequential relationships. We operate accordingly.</p>
                    </div>
                    <div class="pillar">
                        <div class="pillar-number">03</div>
                        <h4>Alignment</h4>
                        <p>Our interests align with yours. We succeed when you win contracts, not when we bill hours. Engagement structures reflect that principle.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ── WHY ALLIED NATIONS (LIGHT) ── -->
    <section class="section allied-section">
        <div class="container">
            <div class="allied-grid reveal">
                <div class="allied-visual">
                    <div class="allied-badge-stack">
                        <div class="allied-badge-item">
                            <span class="badge-flag">🇬🇧</span>
                            <span class="badge-text">United Kingdom</span>
                        </div>
                        <div class="allied-badge-item">
                            <span class="badge-flag">🇦🇺</span>
                            <span class="badge-text">Australia</span>
                        </div>
                        <div class="allied-badge-item">
                            <span class="badge-flag">🇨🇦</span>
                            <span class="badge-text">Canada</span>
                        </div>
                        <div class="allied-badge-item">
                            <span class="badge-flag">🇳🇿</span>
                            <span class="badge-text">New Zealand</span>
                        </div>
                        <div class="allied-badge-item">
                            <span class="badge-flag">🌍</span>
                            <span class="badge-text">NATO & Allied Partners</span>
                        </div>
                    </div>
                </div>
                <div class="allied-text">
                    <span class="section-label">Allied Nations</span>
                    <h2>A Strategic Choice</h2>
                    <div class="allied-rule"></div>
                    <p>Our market entry and ventures work is built around trusted allied democracies: the United Kingdom, Australia, Canada, New Zealand, NATO allies, and select partner nations whose technologies address critical US defense and national security requirements.</p>
                    <p>This is not a limitation. It is the foundation of those practice areas. Shared security frameworks, interoperable clearances, and aligned strategic interests make allied-nation firms uniquely suited for US defense integration. The rapid procurement pathways we navigate, the consortia we access, and the relationships we maintain all depend on this trust framework.</p>
                    <p>Our market intelligence practice serves a broader audience &mdash; allied firms, US prime contractors, investors, and program offices that need a clearer picture of the markets they are operating in. If any of that describes you, we should talk.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ── FLOATING STATS (bridge between allied & CTA) ── -->
    <div class="stats-bridge">
        <div class="stats-float">
            <div class="stat-card">
                <span class="stat-value">$1.5T+</span>
                <span class="stat-desc">US annual defense budget, the largest procurement market on earth</span>
            </div>
            <div class="stat-card">
                <span class="stat-value">60&ndash;120</span>
                <span class="stat-desc">Days from solicitation to award through CSO and OTA procurement pathways</span>
            </div>
            <div class="stat-card">
                <span class="stat-value">$18B+</span>
                <span class="stat-desc">Annual OTA obligations across the Department of Defense</span>
            </div>
        </div>
    </div>

    <CTASection />

</BaseLayout>

<style>
    /* ── FIRM (LIGHT) ── */
    .firm-section {
        background: var(--stone);
    }

    .firm-rule {
        width: 50px;
        height: 2px;
        background: var(--gold);
        margin-bottom: 1.5rem;
    }

    .firm-grid {
        display: grid;
        grid-template-columns: 1.3fr 0.7fr;
        gap: 3.5rem;
        align-items: start;
    }

    .firm-text h2 { margin-bottom: 1rem; }

    .firm-text p {
        margin-bottom: 1rem;
        font-size: 1.02rem;
        line-height: 1.75;
    }

    .firm-sidebar {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .sidebar-card {
        padding: 1.4rem 1.5rem;
        background: #fff;
        border: 1px solid var(--border-warm);
        border-left: 3px solid var(--gold);
        transition: all 0.3s ease;
    }

    .sidebar-card:hover {
        box-shadow: var(--shadow-warm-md);
        transform: translateX(4px);
    }

    .sidebar-icon {
        display: block;
        color: var(--gold);
        font-size: 0.7rem;
        margin-bottom: 0.6rem;
    }

    .sidebar-card h4 {
        font-family: 'Source Sans Pro', sans-serif;
        font-weight: 600;
        font-size: 0.75rem;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: var(--navy);
        margin-bottom: 0.5rem;
    }

    .sidebar-card p {
        font-size: 0.88rem;
        line-height: 1.6;
        color: var(--text-medium);
    }

    /* ── AVENUES (LIGHT, NEW) ── */
    .avenues-section {
        background: var(--cream);
        padding: 6rem 0;
    }

    .avenues-label {
        display: inline-block;
        font-family: 'Source Sans Pro', sans-serif;
        font-weight: 600;
        font-size: 0.72rem;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: var(--burgundy);
        background: var(--burgundy-surface);
        padding: 0.5rem 1.2rem;
        margin-bottom: 1.2rem;
    }

    .avenues-section .section-header {
        text-align: center;
        max-width: 700px;
        margin: 0 auto 3rem;
    }

    .avenues-section .section-header h2 {
        color: var(--deep-navy);
        margin-bottom: 1rem;
    }

    .avenues-section .section-header p {
        color: var(--text-medium);
        font-size: 1.02rem;
        line-height: 1.75;
    }

    .avenues-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
        max-width: 1000px;
        margin: 0 auto;
    }

    .avenue-detail {
        background: #fff;
        padding: 2rem;
        border: 1px solid var(--border-warm);
        border-top: 3px solid var(--gold);
        transition: all 0.3s ease;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .avenue-detail:hover {
        transform: translateY(-4px);
        box-shadow: 0 16px 40px rgba(30, 58, 95, 0.1);
    }

    .avenue-num {
        font-family: 'Fraunces', serif;
        font-size: 1.6rem;
        font-weight: 700;
        color: var(--gold);
        opacity: 0.3;
        line-height: 1;
    }

    .avenue-detail h3 {
        font-size: 1.25rem;
        color: var(--deep-navy);
        margin-bottom: 0.3rem;
    }

    .avenue-detail p {
        font-size: 0.95rem;
        line-height: 1.7;
        color: var(--text-medium);
        flex: 1;
    }

    .avenue-link {
        font-family: 'Source Sans Pro', sans-serif;
        font-size: 0.78rem;
        font-weight: 600;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: var(--burgundy);
        text-decoration: none;
        margin-top: 0.6rem;
        transition: color 0.2s ease;
    }

    .avenue-link + .avenue-link {
        margin-top: 0.2rem;
    }

    .avenue-link:hover {
        color: var(--gold);
    }

    /* ── APPROACH (DARK SECTION) ── */
    .approach-section {
        background: linear-gradient(180deg, var(--deep-navy) 0%, #162d4a 100%);
        padding: 6rem 0;
        overflow: hidden;
    }

    .approach-bg {
        position: absolute;
        inset: 0;
        background-image:
            radial-gradient(ellipse at 70% 30%, rgba(201, 169, 97, 0.05) 0%, transparent 50%),
            radial-gradient(ellipse at 20% 80%, rgba(30, 58, 95, 0.15) 0%, transparent 50%);
        pointer-events: none;
    }

    .approach-inner {
        position: relative;
        z-index: 1;
    }

    .approach-label {
        display: inline-block;
        font-family: 'Source Sans Pro', sans-serif;
        font-weight: 600;
        font-size: 0.72rem;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: var(--gold);
        background: rgba(201, 169, 97, 0.08);
        padding: 0.5rem 1.2rem;
        margin-bottom: 1.2rem;
    }

    .approach-rule {
        width: 50px;
        height: 2px;
        background: var(--gold);
        opacity: 0.5;
        margin-bottom: 1.5rem;
    }

    .approach-grid {
        display: grid;
        grid-template-columns: 1.2fr 0.8fr;
        gap: 3.5rem;
        align-items: start;
    }

    .approach-section h2 {
        color: #fff;
        margin-bottom: 1rem;
    }

    .approach-text p {
        color: rgba(255, 255, 255, 0.55);
        margin-bottom: 0.8rem;
    }

    .approach-pillars {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .pillar {
        padding: 1.4rem 1.5rem;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-left: 3px solid rgba(201, 169, 97, 0.3);
        position: relative;
        transition: all 0.3s ease;
    }

    .pillar:hover {
        background: rgba(255, 255, 255, 0.07);
        border-left-color: var(--gold);
        transform: translateX(4px);
    }

    .pillar-number {
        font-family: 'Fraunces', serif;
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--gold);
        opacity: 0.5;
        margin-bottom: 0.4rem;
    }

    .pillar h4 {
        font-family: 'Source Sans Pro', sans-serif;
        font-weight: 600;
        font-size: 0.75rem;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: #fff;
        margin-bottom: 0.6rem;
    }

    .pillar p {
        font-size: 0.9rem;
        line-height: 1.65;
        color: rgba(255, 255, 255, 0.5);
    }

    /* ── ALLIED (LIGHT) ── */
    .allied-section {
        background: var(--cream);
        padding-bottom: 8rem;
    }

    .allied-rule {
        width: 50px;
        height: 2px;
        background: var(--gold);
        margin-bottom: 1.5rem;
    }

    .allied-grid {
        display: grid;
        grid-template-columns: 0.4fr 1fr;
        gap: 3.5rem;
        align-items: center;
    }

    .allied-badge-stack {
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
    }

    .allied-badge-item {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 0.9rem 1.2rem;
        background: var(--cream);
        border: 1px solid var(--border-subtle);
        border-left: 3px solid var(--navy);
        transition: all 0.3s ease;
    }

    .allied-badge-item:hover {
        border-left-color: var(--gold);
        box-shadow: var(--shadow-md);
        transform: translateX(4px);
    }

    .badge-flag {
        font-size: 1.5rem;
        flex-shrink: 0;
    }

    .badge-text {
        font-weight: 600;
        font-size: 0.9rem;
        color: var(--navy);
    }

    .allied-text h2 { margin-bottom: 1rem; }

    .allied-text p {
        font-size: 1.02rem;
        line-height: 1.75;
        margin-bottom: 1rem;
    }

    /* ── FLOATING STATS BRIDGE ── */
    .stats-bridge {
        position: relative;
        z-index: 10;
        padding: 0 2rem;
        margin-top: -5rem;
        margin-bottom: -5rem;
    }

    .stats-float {
        max-width: 1100px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.2rem;
    }

    .stat-card {
        background: #fff;
        text-align: center;
        padding: 2rem 1.5rem;
        border-top: 3px solid var(--gold);
        box-shadow: 0 12px 40px rgba(0, 0, 0, 0.12);
        transition: all 0.3s ease;
    }

    .stat-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 18px 50px rgba(0, 0, 0, 0.16);
    }

    .stat-value {
        display: block;
        font-family: 'Fraunces', serif;
        font-size: 2.6rem;
        font-weight: 700;
        color: var(--deep-navy);
        line-height: 1;
        margin-bottom: 0.6rem;
    }

    .stat-desc {
        display: block;
        font-size: 0.85rem;
        color: var(--text-medium);
        line-height: 1.6;
    }

    /* CTA top padding override for floating stats overlap */
    .stats-bridge + :global(.cta-section) {
        padding-top: 8rem;
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 992px) {
        .firm-grid { grid-template-columns: 1fr; }
        .approach-grid { grid-template-columns: 1fr; }
        .allied-grid { grid-template-columns: 1fr; }
        .allied-badge-stack { flex-direction: row; flex-wrap: wrap; }
        .allied-badge-item { flex: 1 1 calc(50% - 0.3rem); }
        .avenues-grid { grid-template-columns: 1fr; max-width: 540px; }
    }

    @media (max-width: 768px) {
        .stats-float { grid-template-columns: 1fr; }
        .stats-bridge { margin-top: -3.5rem; margin-bottom: -3.5rem; }
        .allied-section { padding-bottom: 6rem; }
        .stats-bridge + :global(.cta-section) { padding-top: 6rem; }
        .allied-badge-item { flex: 1 1 100%; }
    }
</style>
