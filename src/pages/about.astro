---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import CTASection from '../components/CTASection.astro';
---

<BaseLayout title="About | Levenhall" description="Levenhall is a Washington, DC-based market intelligence consulting firm serving defense, government, and dual-use markets. Intelligence, market entry, ventures, and proprietary products.">

    <PageHeader
        label="About Levenhall"
        title="Who We Are"
        index="01"
    />

    <!-- ── THE FIRM (PAPER — long-form editorial passage) ── -->
    <section class="section section-paper firm-section">
        <div class="container">
            <div class="firm-grid">
                <div class="firm-text">
                    <span class="section-label">01 / The Firm</span>
                    <h2>The Firm</h2>
                    <p class="firm-lede">Levenhall is a Washington, DC-based market intelligence consulting firm. We work in the markets where information asymmetry decides outcomes &mdash; defense procurement, allied government programs, regulated dual-use technology, and the geopolitical environment that shapes all three.</p>
                    <p>Our intelligence practice is the core. From it, we run a connected set of avenues: a US federal market entry practice for allied defense and government technology firms, an investment arm (Levenhall Ventures) that takes equity in five companies a year in exchange for hands-on execution, and proprietary products &mdash; Bridger, AIGIS, and Intelligence &mdash; that operationalize what we know.</p>
                    <p>What unites the work is method. We do not broker introductions or sell off-the-shelf reports. We build a source-grounded picture of the market, identify where a client can act, and architect the structure required to act there. Every engagement is designed to produce a specific outcome, whether that outcome is a contract, an investment thesis, a placed executive, or a decision the client could not have made on their own information.</p>
                </div>
                <div class="firm-ledger">
                    <span class="route-line firm-route">Levenhall / Registry / 2026</span>
                    <div class="firm-fact">
                        <h4>Washington, DC</h4>
                        <p>Headquartered in the capital, where procurement decisions are made and intelligence flows.</p>
                    </div>
                    <div class="firm-fact">
                        <h4>Intelligence-Led</h4>
                        <p>Every engagement begins with a source-grounded picture of the market. Advice, structure, and execution flow from there.</p>
                    </div>
                    <div class="firm-fact">
                        <h4>Allied-Aligned</h4>
                        <p>Serving firms, investors, and program offices in trusted democracies with shared security frameworks and interoperable clearances.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ── WHAT WE DO (INK — avenues ledger) ── -->
    <section class="section avenues-section">
        <div class="container">
            <div class="section-header">
                <span class="section-label">02 / What We Do</span>
                <h2>Four Connected Avenues</h2>
                <p>One firm, one method, four ways we put intelligence to work.</p>
            </div>
            <div class="avenues-ledger">
                <div class="avenue-row">
                    <span class="av-num">I.</span>
                    <span class="av-body">
                        <h3>Market Intelligence</h3>
                        <p>The core. Decision-grade research, monitoring, and analysis on defense, government, geopolitical, and dual-use markets. One-time assessments and continuous retainers.</p>
                    </span>
                    <span class="av-links">
                        <a href="/services#market-intelligence" class="mono-link">Intelligence Practice &rarr;</a>
                    </span>
                </div>
                <div class="avenue-row">
                    <span class="av-num">II.</span>
                    <span class="av-body">
                        <h3>US Federal Market Entry</h3>
                        <p>Strategy, rapid procurement (CSO / OTA), executive placement, and cross-border tax structuring for allied defense and government technology firms entering the US.</p>
                    </span>
                    <span class="av-links">
                        <a href="/services" class="mono-link">Market Entry &rarr;</a>
                    </span>
                </div>
                <div class="avenue-row">
                    <span class="av-num">III.</span>
                    <span class="av-body">
                        <h3>Levenhall Ventures</h3>
                        <p>Our investment arm. Services at cost in exchange for equity. Five allied defense and government technology companies a year. No fund-style fees.</p>
                    </span>
                    <span class="av-links">
                        <a href="/ventures" class="mono-link">Ventures &rarr;</a>
                    </span>
                </div>
                <div class="avenue-row">
                    <span class="av-num">IV.</span>
                    <span class="av-body">
                        <h3>Products: Bridger, AIGIS &amp; Intelligence</h3>
                        <p>Bridger is our pre-RFP intelligence platform for US federal contracting &mdash; $760B a year indexed, scored, and watched. AIGIS is our system of record for AI governance, mapping every regulated AI system to the frameworks it has to answer to. Intelligence is our defense &amp; alliance advisory dashboard &mdash; live situational awareness for allied defense advisors.</p>
                    </span>
                    <span class="av-links">
                        <a href="/products/bridger" class="mono-link">Bridger</a>
                        <a href="/products/aigis" class="mono-link">AIGIS</a>
                        <a href="/products/intelligence" class="mono-link">Intelligence</a>
                    </span>
                </div>
            </div>
        </div>
    </section>

    <!-- ── APPROACH (PANEL) ── -->
    <section class="section section-panel approach-section texture-grain">
        <div class="container">
            <div class="approach-grid">
                <div class="approach-text">
                    <span class="section-label">03 / Our Approach</span>
                    <h2>Intelligence First. <span class="editorial-italic">Structure, Not Access.</span></h2>
                    <p>Most consulting firms sell access or sell reports. Levenhall does neither. We sell a method: build a source-grounded picture of the market, then architect the structure required to act in it.</p>
                    <p>Access is temporary. A meeting, a referral, a conference introduction: these create moments, not positions. Structure is durable. The right intelligence cadence, the right entity formation, the right procurement vehicle, the right consortium membership, the right US-based leadership: these create a foundation that generates opportunities for years.</p>
                    <p>We are selective about the firms we work with. Every engagement undergoes conflict and compliance review. We represent a limited number of clients in any given technology domain, ensuring that our intelligence work and institutional knowledge serve each client without dilution.</p>
                </div>
                <div class="approach-pillars">
                    <span class="route-line pillars-route">Operating Principles / Standing</span>
                    <div class="pillar">
                        <span class="pillar-num">I.</span>
                        <div>
                            <h4>Selectivity</h4>
                            <p>We take on a limited number of engagements. This is by design. Our effectiveness depends on deep commitment, not broad reach.</p>
                        </div>
                    </div>
                    <div class="pillar">
                        <span class="pillar-num">II.</span>
                        <div>
                            <h4>Discretion</h4>
                            <p>Defense market positioning involves sensitive information, classified environments, and consequential relationships. We operate accordingly.</p>
                        </div>
                    </div>
                    <div class="pillar">
                        <span class="pillar-num">III.</span>
                        <div>
                            <h4>Alignment</h4>
                            <p>Our interests align with yours. We succeed when you win contracts, not when we bill hours. Engagement structures reflect that principle.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ── WHY ALLIED NATIONS (INK) ── -->
    <section class="section allied-section">
        <div class="container">
            <div class="allied-grid">
                <div class="allied-text">
                    <span class="section-label">04 / Allied Nations</span>
                    <h2>A Strategic Choice</h2>
                    <p>Our market entry and ventures work is built around trusted allied democracies: the United Kingdom, Australia, Canada, New Zealand, NATO allies, and select partner nations whose technologies address critical US defense and national security requirements.</p>
                    <p>This is not a limitation. It is the foundation of those practice areas. Shared security frameworks, interoperable clearances, and aligned strategic interests make allied-nation firms uniquely suited for US defense integration. The rapid procurement pathways we navigate, the consortia we access, and the relationships we maintain all depend on this trust framework.</p>
                    <p>Our market intelligence practice serves a broader audience &mdash; allied firms, US prime contractors, investors, and program offices that need a clearer picture of the markets they are operating in. If any of that describes you, we should talk.</p>
                </div>
                <div class="allied-ledger">
                    <div class="allied-ledger-head">
                        <span>Coverage / Allied Partners</span>
                    </div>
                    <div class="nation-row">
                        <span class="nation-flag">🇬🇧</span>
                        <span class="nation-name">United Kingdom</span>
                    </div>
                    <div class="nation-row">
                        <span class="nation-flag">🇦🇺</span>
                        <span class="nation-name">Australia</span>
                    </div>
                    <div class="nation-row">
                        <span class="nation-flag">🇨🇦</span>
                        <span class="nation-name">Canada</span>
                    </div>
                    <div class="nation-row">
                        <span class="nation-flag">🇳🇿</span>
                        <span class="nation-name">New Zealand</span>
                    </div>
                    <div class="nation-row">
                        <span class="nation-flag">🌍</span>
                        <span class="nation-name">NATO &amp; Allied Partners</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ── EVIDENCE BAR (replaces floating stat cards) ── -->
    <section class="stats-bar rule-top">
        <div class="datum">
            <span class="d-val">$1.5T+</span>
            <span class="d-cap">US annual defense budget, the largest procurement market on earth</span>
        </div>
        <div class="datum">
            <span class="d-val">60&ndash;120</span>
            <span class="d-cap">Days from solicitation to award through CSO and OTA procurement pathways</span>
        </div>
        <div class="datum">
            <span class="d-val">$18B+</span>
            <span class="d-cap">Annual OTA obligations across the Department of Defense</span>
        </div>
    </section>

    <CTASection />

</BaseLayout>

<style>
    /* ── THE FIRM (PAPER) ── */
    .firm-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.25fr) minmax(0, 0.75fr);
        gap: 4.5rem;
        align-items: start;
    }

    .firm-text h2 { margin-bottom: 1.4rem; }

    .firm-text p {
        margin-bottom: 1rem;
        line-height: 1.75;
        max-width: 62ch;
    }

    .firm-lede {
        font-size: 1.08rem;
    }
    .firm-lede::first-letter {
        font-family: var(--serif);
        font-size: 3.2em;
        float: left;
        line-height: 0.82;
        padding-right: 0.14em;
        color: var(--deep-navy);
    }

    /* Registry ledger — hairline rows, no cards */
    .firm-ledger {
        border-top: 1px solid var(--hairline-paper);
    }

    .firm-route {
        display: block;
        padding: 0.9rem 0.2rem;
        border-bottom: 1px solid var(--hairline-paper);
        color: var(--text-medium);
    }

    .firm-fact {
        padding: 1.3rem 0.2rem 1.4rem;
        border-bottom: 1px solid var(--hairline-paper);
    }

    .firm-fact h4 {
        color: var(--deep-navy);
        margin-bottom: 0.55rem;
    }

    .firm-fact p {
        font-size: 0.88rem;
        line-height: 1.6;
    }

    /* ── AVENUES LEDGER (INK) ── */
    .avenues-ledger {
        border-top: 1px solid var(--hairline);
    }

    .avenue-row {
        display: grid;
        grid-template-columns: 64px minmax(0, 1fr) 220px;
        gap: 2rem;
        align-items: start;
        padding: 2rem 0.5rem 2.2rem;
        border-bottom: 1px solid var(--hairline);
        transition: background var(--t-short);
    }
    .avenue-row:hover { background: var(--ink-panel); }

    .av-num {
        font-family: var(--serif);
        font-style: italic;
        font-size: 1.5rem;
        color: var(--gold);
        line-height: 1.2;
    }

    .av-body h3 { font-size: 1.25rem; margin-bottom: 0.5rem; }
    .av-body p { font-size: 0.95rem; line-height: 1.7; color: var(--muted); max-width: 68ch; }

    .av-links {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 0.9rem;
        padding-top: 0.35rem;
    }

    /* ── APPROACH (PANEL) ── */
    .approach-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr);
        gap: 4.5rem;
        align-items: start;
    }

    .approach-text h2 {
        margin-bottom: 1.4rem;
        max-width: 18ch;
    }

    .approach-text .editorial-italic {
        font-weight: 400;
    }

    .approach-text p {
        margin-bottom: 1rem;
        max-width: 60ch;
    }

    .approach-pillars {
        border-top: 1px solid var(--hairline);
    }

    .pillars-route {
        display: block;
        padding: 0.9rem 0.2rem;
        border-bottom: 1px solid var(--hairline);
    }

    .pillar {
        display: grid;
        grid-template-columns: 44px minmax(0, 1fr);
        gap: 1rem;
        padding: 1.4rem 0.2rem 1.5rem;
        border-bottom: 1px solid var(--hairline);
        transition: background var(--t-short);
    }
    .pillar:hover { background: var(--ink); }

    .pillar-num {
        font-family: var(--serif);
        font-style: italic;
        font-size: 1.2rem;
        color: var(--gold);
        line-height: 1.3;
    }

    .pillar h4 {
        color: var(--bone);
        margin-bottom: 0.5rem;
    }

    .pillar p {
        font-size: 0.9rem;
        line-height: 1.65;
        color: var(--muted);
    }

    /* ── ALLIED NATIONS (INK) ── */
    .allied-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.2fr) minmax(0, 0.8fr);
        gap: 4.5rem;
        align-items: start;
    }

    .allied-text h2 { margin-bottom: 1.4rem; }

    .allied-text p {
        margin-bottom: 1rem;
        line-height: 1.75;
        max-width: 62ch;
    }

    .allied-ledger {
        border: 1px solid var(--hairline);
        padding: 1.4rem 1.6rem 0.4rem;
    }

    .allied-ledger-head {
        font-family: var(--mono);
        font-size: 0.58rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--dim);
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--hairline);
    }

    .nation-row {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 1rem;
        align-items: center;
        padding: 0.85rem 0.2rem;
        border-bottom: 1px solid var(--hairline-soft);
    }
    .nation-row:last-child { border-bottom: none; }

    .nation-flag { font-size: 1.15rem; line-height: 1; }
    .nation-name { font-weight: 600; font-size: 0.9rem; color: var(--bone); }

    /* ── EVIDENCE BAR ── */
    .stats-bar {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
    }

    .datum {
        padding: 1.8rem 2rem 2rem;
        border-right: 1px solid var(--hairline);
        font-family: var(--mono);
    }
    .datum:last-child { border-right: none; }

    .d-val {
        display: block;
        font-size: 1.5rem;
        font-weight: 500;
        color: var(--bone);
        letter-spacing: 0.01em;
        font-variant-numeric: tabular-nums;
    }

    .d-cap {
        display: block;
        margin-top: 0.5rem;
        font-size: 0.58rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--dim);
        line-height: 1.7;
        max-width: 34ch;
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 992px) {
        .firm-grid { grid-template-columns: 1fr; gap: 3rem; }
        .approach-grid { grid-template-columns: 1fr; gap: 3rem; }
        .allied-grid { grid-template-columns: 1fr; gap: 3rem; }
    }

    @media (max-width: 900px) {
        .avenue-row { grid-template-columns: 44px minmax(0, 1fr); }
        .av-links {
            grid-column: 2;
            flex-direction: row;
            flex-wrap: wrap;
            gap: 1.4rem;
            padding-top: 0.9rem;
        }
    }

    @media (max-width: 768px) {
        .stats-bar { grid-template-columns: 1fr; }
        .datum { border-right: none; border-bottom: 1px solid var(--hairline); }
        .datum:last-child { border-bottom: none; }
    }
</style>
