---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import CTASection from '../components/CTASection.astro';
import TeamCard from '../components/TeamCard.astro';
import BioModal from '../components/BioModal.astro';
import NishankBioModal from '../components/NishankBioModal.astro';
import HassanBioModal from '../components/HassanBioModal.astro';
import { team } from '../data/team';
---

<BaseLayout title="Team | Levenhall" description="Former intelligence, military, diplomatic, and government professionals who understand the defense, government, and dual-use markets we cover from inside.">

    <PageHeader
        label="Our Leadership"
        title="The Team"
        index="02"
    />

    <!-- ── ROSTER (STONE — editorial passage for bios) ── -->
    <section class="section section-stone team-section">
        <div class="container">
            <div class="team-intro">
                <span class="route-line team-route">Levenhall / Leadership / Roster</span>
                <p>Levenhall's leadership brings direct experience from the <strong>intelligence community</strong>, <strong>military service</strong>, <strong>diplomatic engagement</strong>, <strong>government contracting</strong>, and <strong>allied defense markets</strong>. Our market intelligence work is built on what they know, who they know, and how they read the markets we operate in.</p>
            </div>
            <div class="team-grid">
                {team.map(member => (
                    <TeamCard
                        name={member.name}
                        title={member.title}
                        photo={member.photo}
                        linkedin={member.linkedin}
                        summary={member.summary}
                        isModalTrigger={member.isModalTrigger}
                        showSummary={true}
                    />
                ))}
            </div>
            <p class="selective-note editorial-italic">Engagements are selective and subject to conflict and compliance review.</p>
        </div>
    </section>

    <CTASection
        heading="Work With Us"
        description="If you need clearer intelligence on the markets that matter most — or you are an allied firm with technology that serves US defense, national security, or dual-use requirements — we should talk."
        primaryLabel="Schedule Consultation"
        primaryHref="https://calendly.com/hgad-levenhall/30min"
    />

    <BioModal />
    <NishankBioModal />
    <HassanBioModal />

</BaseLayout>

<style>
    /* ── ROSTER (STONE) ── */
    .team-intro {
        max-width: 760px;
        margin-bottom: 3rem;
        border-top: 1px solid var(--hairline-paper);
        padding-top: 1.4rem;
    }

    .team-route {
        display: block;
        margin-bottom: 1.4rem;
        color: var(--text-medium);
    }

    .team-intro p {
        font-size: 1.15rem;
        line-height: 1.75;
        color: var(--text-medium);
    }

    .team-intro strong {
        color: var(--deep-navy);
        font-weight: 600;
    }

    .team-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
    }

    .selective-note {
        font-size: 0.95rem;
        margin-top: 3rem;
        padding-top: 1.2rem;
        border-top: 1px solid var(--hairline-paper);
        max-width: 760px;
    }

    @media (max-width: 1024px) {
        .team-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @media (max-width: 768px) {
        .team-grid { grid-template-columns: 1fr; max-width: 420px; }
    }
</style>
