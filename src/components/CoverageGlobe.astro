---
// 3D interactive coverage globe — orthographic projection, real 110m coastlines.
// Drag to rotate (inertia), auto-rotates when idle, gold geodesic arcs from
// Washington to each allied capital. Engraved in the brand palette.
interface Props { class?: string; }
const { class: className = '' } = Astro.props;
---

<div class={`globe-wrap ${className}`}>
    <canvas id="coverageGlobe" aria-label="Interactive globe showing Levenhall's allied network: Washington DC connected to every NATO capital, the Five Eyes capitals, Tokyo, Seoul, and Tel Aviv. Drag to rotate; hover a point for its name."></canvas>
    <span class="globe-legend">37 allied capitals · NATO / FVEY / Strategic Allies · Hub: Washington</span>
</div>

<script>
    import { geoOrthographic, geoPath, geoGraticule10, geoDistance, geoInterpolate } from 'd3-geo';
    import { feature } from 'topojson-client';
    // @ts-ignore — JSON module
    import world from 'world-atlas/land-110m.json';

    const canvas = document.getElementById('coverageGlobe') as HTMLCanvasElement | null;

    if (canvas) {
        const land = feature(world as any, (world as any).objects.land);
        const graticule = geoGraticule10();

        const DC: [number, number] = [-77.0369, 38.9072];
        type Tier = 'home' | 'fvey' | 'nato' | 'partner';
        const capitals: { name: string; coords: [number, number]; tier: Tier }[] = [
            { name: 'WASHINGTON', coords: DC, tier: 'home' },
            // Five Eyes
            { name: 'OTTAWA', coords: [-75.6972, 45.4215], tier: 'fvey' },
            { name: 'LONDON', coords: [-0.1276, 51.5074], tier: 'fvey' },
            { name: 'CANBERRA', coords: [149.13, -35.2809], tier: 'fvey' },
            { name: 'WELLINGTON', coords: [174.7762, -41.2865], tier: 'fvey' },
            // NATO capitals
            { name: 'TIRANA', coords: [19.8187, 41.3275], tier: 'nato' },
            { name: 'BRUSSELS', coords: [4.3517, 50.8503], tier: 'nato' },
            { name: 'SOFIA', coords: [23.3219, 42.6977], tier: 'nato' },
            { name: 'ZAGREB', coords: [15.9819, 45.815], tier: 'nato' },
            { name: 'PRAGUE', coords: [14.4378, 50.0755], tier: 'nato' },
            { name: 'COPENHAGEN', coords: [12.5683, 55.6761], tier: 'nato' },
            { name: 'TALLINN', coords: [24.7536, 59.437], tier: 'nato' },
            { name: 'HELSINKI', coords: [24.9384, 60.1699], tier: 'nato' },
            { name: 'PARIS', coords: [2.3522, 48.8566], tier: 'nato' },
            { name: 'BERLIN', coords: [13.405, 52.52], tier: 'nato' },
            { name: 'ATHENS', coords: [23.7275, 37.9838], tier: 'nato' },
            { name: 'BUDAPEST', coords: [19.0402, 47.4979], tier: 'nato' },
            { name: 'REYKJAVIK', coords: [-21.8174, 64.1265], tier: 'nato' },
            { name: 'ROME', coords: [12.4964, 41.9028], tier: 'nato' },
            { name: 'RIGA', coords: [24.1052, 56.9496], tier: 'nato' },
            { name: 'VILNIUS', coords: [25.2797, 54.6872], tier: 'nato' },
            { name: 'LUXEMBOURG', coords: [6.1296, 49.6116], tier: 'nato' },
            { name: 'PODGORICA', coords: [19.2594, 42.4304], tier: 'nato' },
            { name: 'AMSTERDAM', coords: [4.9041, 52.3676], tier: 'nato' },
            { name: 'SKOPJE', coords: [21.4254, 41.9981], tier: 'nato' },
            { name: 'OSLO', coords: [10.7522, 59.9139], tier: 'nato' },
            { name: 'WARSAW', coords: [21.0122, 52.2297], tier: 'nato' },
            { name: 'LISBON', coords: [-9.1393, 38.7223], tier: 'nato' },
            { name: 'BUCHAREST', coords: [26.1025, 44.4268], tier: 'nato' },
            { name: 'BRATISLAVA', coords: [17.1077, 48.1486], tier: 'nato' },
            { name: 'LJUBLJANA', coords: [14.5058, 46.0569], tier: 'nato' },
            { name: 'MADRID', coords: [-3.7038, 40.4168], tier: 'nato' },
            { name: 'STOCKHOLM', coords: [18.0686, 59.3293], tier: 'nato' },
            { name: 'ANKARA', coords: [32.8597, 39.9334], tier: 'nato' },
            // Key strategic allies
            { name: 'TOKYO', coords: [139.6917, 35.6895], tier: 'partner' },
            { name: 'SEOUL', coords: [126.978, 37.5665], tier: 'partner' },
            { name: 'TEL AVIV', coords: [34.7818, 32.0853], tier: 'partner' },
        ];
        const arcs = capitals.slice(1).map(c => ({
            tier: c.tier,
            interp: geoInterpolate(DC, c.coords),
        }));

        const ctx = canvas.getContext('2d')!;
        const projection = geoOrthographic().clipAngle(90);
        const path = geoPath(projection, ctx);

        const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        // State
        let rotation: [number, number] = [45, -35];   // Atlantic view: DC + Europe both visible
        let hovered: typeof capitals[number] | null = null;
        let autorotate = !reduceMotion;
        let idleTimer: ReturnType<typeof setTimeout> | null = null;
        let dragging = false;
        let lastX = 0, lastY = 0;
        let velocity = 0;
        let width = 0, height = 0, radius = 0;
        let pingT = 0;

        function resize() {
            const rect = canvas.parentElement!.getBoundingClientRect();
            const size = Math.min(rect.width, 520);
            const dpr = Math.min(window.devicePixelRatio || 1, 2);
            width = size; height = size;
            canvas.width = size * dpr;
            canvas.height = size * dpr;
            canvas.style.width = `${size}px`;
            canvas.style.height = `${size}px`;
            ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
            radius = size / 2 - 10;
            projection.translate([size / 2, size / 2]).scale(radius);
        }

        function visible(coords: [number, number]): boolean {
            const r = projection.rotate();
            return geoDistance(coords, [-r[0], -r[1]]) < Math.PI / 2 - 0.05;
        }

        function draw() {
            projection.rotate(rotation);
            ctx.clearRect(0, 0, width, height);

            // Sphere — deep navy ink with a faint rim
            ctx.beginPath();
            path({ type: 'Sphere' });
            ctx.fillStyle = '#0f1f3a';
            ctx.fill();
            ctx.strokeStyle = '#c4bcab';
            ctx.lineWidth = 1;
            ctx.stroke();

            // Graticule
            ctx.beginPath();
            path(graticule);
            ctx.strokeStyle = 'rgba(250, 250, 248, 0.09)';
            ctx.lineWidth = 0.5;
            ctx.stroke();

            // Land — engraved
            ctx.beginPath();
            path(land as any);
            ctx.fillStyle = 'rgba(250, 250, 248, 0.07)';
            ctx.fill();
            ctx.strokeStyle = 'rgba(250, 250, 248, 0.4)';
            ctx.lineWidth = 0.7;
            ctx.stroke();

            // Geodesic arcs DC → every allied capital. NATO/partner web faint;
            // Five Eyes bright and dashed on top.
            for (const a of arcs) {
                if (a.tier === 'fvey') continue;
                ctx.beginPath();
                path({ type: 'LineString', coordinates: Array.from({ length: 41 }, (_, i) => a.interp(i / 40)) });
                ctx.strokeStyle = 'rgba(201, 169, 97, 0.3)';
                ctx.lineWidth = 0.6;
                ctx.stroke();
            }
            ctx.setLineDash([3, 4]);
            for (const a of arcs) {
                if (a.tier !== 'fvey') continue;
                ctx.beginPath();
                path({ type: 'LineString', coordinates: Array.from({ length: 41 }, (_, i) => a.interp(i / 40)) });
                ctx.strokeStyle = 'rgba(201, 169, 97, 0.85)';
                ctx.lineWidth = 1;
                ctx.stroke();
            }
            ctx.setLineDash([]);

            // Capitals
            ctx.font = '10px "JetBrains Mono", monospace';
            for (const c of capitals) {
                if (!visible(c.coords)) continue;
                const [x, y] = projection(c.coords)!;
                const isHovered = hovered === c;
                if (c.tier === 'home') {
                    ctx.beginPath();
                    ctx.arc(x, y, 3.5, 0, Math.PI * 2);
                    ctx.fillStyle = '#c9a961';
                    ctx.fill();
                    const t = (pingT % 180) / 180;
                    ctx.beginPath();
                    ctx.arc(x, y, 4 + t * 16, 0, Math.PI * 2);
                    ctx.strokeStyle = `rgba(201, 169, 97, ${0.8 * (1 - t)})`;
                    ctx.lineWidth = 1;
                    ctx.stroke();
                    ctx.fillStyle = '#c9a961';
                    ctx.fillText(c.name, x + 8, y + 3.5);
                } else if (c.tier === 'fvey') {
                    ctx.beginPath();
                    ctx.arc(x, y, isHovered ? 3.2 : 2.5, 0, Math.PI * 2);
                    ctx.fillStyle = '#fafaf8';
                    ctx.fill();
                    ctx.fillStyle = 'rgba(250, 250, 248, 0.75)';
                    ctx.fillText(c.name, x + 8, y + 3.5);
                } else {
                    // NATO / partner: small point, label on hover only
                    ctx.beginPath();
                    ctx.arc(x, y, isHovered ? 2.6 : 1.6, 0, Math.PI * 2);
                    ctx.fillStyle = isHovered ? '#c9a961' : 'rgba(250, 250, 248, 0.6)';
                    ctx.fill();
                    if (isHovered) {
                        ctx.fillStyle = '#c9a961';
                        ctx.fillText(c.name, x + 8, y + 3.5);
                    }
                }
            }
        }

        function frame() {
            if (!dragging) {
                if (Math.abs(velocity) > 0.005) {
                    rotation[0] += velocity;
                    velocity *= 0.95;
                } else if (autorotate) {
                    rotation[0] += 0.06;
                }
            }
            if (!reduceMotion) pingT++;
            draw();
            requestAnimationFrame(frame);
        }

        function pauseAutorotate() {
            autorotate = false;
            if (idleTimer) clearTimeout(idleTimer);
            idleTimer = setTimeout(() => { autorotate = !reduceMotion; }, 4000);
        }

        canvas.addEventListener('pointerdown', (e) => {
            dragging = true;
            lastX = e.clientX; lastY = e.clientY;
            velocity = 0;
            canvas.setPointerCapture(e.pointerId);
            pauseAutorotate();
        });
        canvas.addEventListener('pointermove', (e) => {
            if (!dragging) {
                // hover hit-test: nearest visible capital within 12px
                const rect = canvas.getBoundingClientRect();
                const mx = e.clientX - rect.left;
                const my = e.clientY - rect.top;
                let best: typeof capitals[number] | null = null;
                let bestD = 12;
                for (const c of capitals) {
                    if (!visible(c.coords)) continue;
                    const p = projection(c.coords);
                    if (!p) continue;
                    const d = Math.hypot(p[0] - mx, p[1] - my);
                    if (d < bestD) { bestD = d; best = c; }
                }
                hovered = best;
                return;
            }
            const dx = e.clientX - lastX;
            const dy = e.clientY - lastY;
            const k = 90 / radius; // degrees per pixel, scaled to globe size
            rotation[0] += dx * k;
            rotation[1] = Math.max(-75, Math.min(75, rotation[1] - dy * k));
            velocity = dx * k;
            lastX = e.clientX; lastY = e.clientY;
        });
        const endDrag = () => { dragging = false; pauseAutorotate(); };
        canvas.addEventListener('pointerup', endDrag);
        canvas.addEventListener('pointercancel', endDrag);

        new ResizeObserver(() => { resize(); }).observe(canvas.parentElement!);
        resize();
        if (reduceMotion) { draw(); requestAnimationFrame(frame); } else { frame(); }
    }
</script>

<style>
    .globe-wrap {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.7rem;
        padding: 0.4rem 0 0.8rem;
    }
    .globe-legend {
        font-family: var(--mono);
        font-size: 0.58rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--text-medium);
    }
    .globe-wrap canvas {
        display: block;
        cursor: grab;
        touch-action: none;
        max-width: 100%;
    }
    .globe-wrap canvas:active { cursor: grabbing; }
</style>
