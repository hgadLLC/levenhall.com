---
interface Props {
    heading?: string;
    description?: string;
    primaryLabel?: string;
    primaryHref?: string;
    secondaryLabel?: string;
    secondaryHref?: string;
}

const {
    heading = 'Ready to work with us?',
    description = 'Schedule a confidential consultation to explore how Levenhall can support your work — whether you need market intelligence, US federal market entry, a venture engagement, or access to our products.',
    primaryLabel = 'Request a Briefing',
    primaryHref = 'https://calendly.com/hgad-levenhall/30min',
    secondaryLabel = '',
    secondaryHref = '',
} = Astro.props;
---

<section class="cta-section sweep-field">
    <div class="cta-inner">
        <div class="cta-text">
            <span class="route-line">LEVENHALL / ENGAGEMENT / CONFIDENTIAL</span>
            <h2>{heading}</h2>
            <p>{description}</p>
        </div>
        <div class="cta-actions">
            <a href={primaryHref} class="btn btn-primary" target={primaryHref.startsWith('http') ? '_blank' : undefined} rel={primaryHref.startsWith('http') ? 'noopener noreferrer' : undefined}>{primaryLabel}</a>
            {secondaryLabel && (
                <a href={secondaryHref} class="mono-link">{secondaryLabel} →</a>
            )}
        </div>
    </div>
</section>

<style>
    .cta-section {
        background: var(--ink-panel);
        border-top: 1px solid var(--hairline);
        border-bottom: 1px solid var(--hairline);
        padding: 4.5rem 2rem;
    }

    .cta-inner {
        max-width: var(--col-wide);
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        gap: 3rem;
    }

    .cta-text .route-line {
        display: block;
        margin-bottom: 1.4rem;
    }

    .cta-section h2 {
        font-size: clamp(1.7rem, 3vw, 2.4rem);
        color: var(--bone);
        margin-bottom: 1rem;
        max-width: 18ch;
    }

    .cta-section p {
        color: var(--muted);
        font-size: 1rem;
        line-height: 1.7;
        max-width: 56ch;
    }

    .cta-actions {
        display: flex;
        align-items: center;
        gap: 1.6rem;
        flex-shrink: 0;
        padding-bottom: 0.4rem;
    }

    @media (max-width: 860px) {
        .cta-inner {
            flex-direction: column;
            align-items: flex-start;
        }
        .cta-actions { padding-bottom: 0; }
    }
</style>
