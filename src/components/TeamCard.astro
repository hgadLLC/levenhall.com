---
interface Props {
    name: string;
    title: string;
    photo: string;
    linkedin: string;
    summary?: string;
    isModalTrigger?: boolean;
    showSummary?: boolean;
}

const { name, title, photo, linkedin, summary, isModalTrigger = false, showSummary = false } = Astro.props;
const Tag = isModalTrigger ? 'div' : 'a';

// Generate a modal ID from the name (e.g. "Adam J.P. Leslie" → "adam", "Nishank Motwani, PhD" → "nishank")
const modalId = name.split(/[\s.]/)[0].toLowerCase();
---

<Tag
    class="team-card"
    {...(isModalTrigger ? { id: `${modalId}-card`, onclick: `open${modalId.charAt(0).toUpperCase() + modalId.slice(1)}Bio()` } : { href: linkedin, target: '_blank', rel: 'noopener noreferrer' })}
>
    <div class="team-photo-wrapper">
        <img src={photo} alt={name} class="team-photo" loading="lazy">
        <span class="team-resolve">{isModalTrigger ? 'View Bio' : 'LinkedIn'} →</span>
    </div>
    <div class="team-info">
        <h3>{name}</h3>
        <p class="team-title-text">{title}</p>
        {showSummary && summary && <p class="team-summary">{summary}</p>}
    </div>
</Tag>

<style>
    .team-card {
        display: block;
        text-decoration: none;
        border: 1px solid var(--hairline-paper);
        background: var(--cream);
        cursor: pointer;
        transition: border-color 0.3s ease;
    }

    .team-card:hover {
        border-color: var(--gold);
    }

    .team-photo-wrapper {
        position: relative;
        overflow: hidden;
        aspect-ratio: 1 / 1.04;
        clip-path: polygon(0 0, calc(100% - 18px) 0, 100% 18px, 100% 100%, 0 100%);
        background: var(--deep-navy);
    }

    /* Duotone by default — resolves to true color on hover (the Lens, applied to people) */
    .team-photo {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center 20%;
        filter: grayscale(1) contrast(1.06) brightness(0.92) sepia(0.32) hue-rotate(180deg) saturate(1.5);
        transition: filter 0.45s var(--ease-enter), transform 0.45s var(--ease-enter);
    }

    .team-card:hover .team-photo {
        filter: none;
        transform: scale(1.02);
    }

    .team-resolve {
        position: absolute;
        left: 1.1rem;
        bottom: 0.9rem;
        font-family: var(--mono);
        font-size: 0.58rem;
        font-weight: 500;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--bone);
        background: rgba(10, 18, 32, 0.85);
        padding: 0.4rem 0.7rem;
        opacity: 0;
        transform: translateY(4px);
        transition: opacity 0.3s ease, transform 0.3s var(--ease-enter);
    }

    .team-card:hover .team-resolve {
        opacity: 1;
        transform: translateY(0);
    }

    .team-info {
        padding: 1.3rem 1.4rem 1.5rem;
        border-top: 1px solid var(--hairline-paper);
    }

    .team-info h3 {
        font-family: var(--serif);
        font-size: 1.25rem;
        font-weight: 600;
        letter-spacing: -0.01em;
        color: var(--deep-navy);
        margin-bottom: 0.45rem;
    }

    .team-title-text {
        font-family: var(--mono);
        font-size: 0.6rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--text-medium);
        line-height: 1.6;
    }

    .team-summary {
        font-size: 0.88rem;
        color: var(--text-medium);
        line-height: 1.65;
        margin-top: 0.9rem;
    }

    @media (prefers-reduced-motion: reduce) {
        .team-photo { transition: none; }
    }
</style>
