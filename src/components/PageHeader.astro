---
interface Props {
    label: string;
    title: string;
    description?: string;
    index?: string;
}

const { label, title, description, index } = Astro.props;
---

<section class="page-header sweep-field">
    <div class="page-header-inner">
        <span class="route-line ph-route">LEVENHALL / {label} <span class="live">●</span></span>
        <div class="ph-title-row">
            {index && <span class="ph-index">{index}</span>}
            <h1>{title}</h1>
        </div>
        {description && <p class="ph-desc">{description}</p>}
    </div>
</section>

<style>
    .page-header {
        background: var(--ink);
        padding: 10rem 2rem 4.5rem;
        border-bottom: 1px solid var(--hairline);
        position: relative;
    }

    .page-header-inner {
        max-width: var(--col-wide);
        margin: 0 auto;
    }

    .ph-route {
        display: block;
        margin-bottom: 2.2rem;
    }

    .ph-title-row {
        display: flex;
        align-items: baseline;
        gap: 1.6rem;
    }

    .ph-index {
        font-family: var(--serif);
        font-style: italic;
        font-weight: 400;
        font-size: clamp(1.6rem, 3vw, 2.6rem);
        color: var(--gold);
        flex-shrink: 0;
    }

    .page-header h1 {
        color: var(--bone);
        font-size: clamp(2.6rem, 5vw, 4.2rem);
        max-width: 16ch;
    }

    .ph-desc {
        color: var(--muted);
        font-size: 1.08rem;
        line-height: 1.7;
        max-width: 58ch;
        margin-top: 1.6rem;
    }
</style>
