---
const year = new Date().getFullYear();
---

<footer>
    <div class="footer-accent"></div>
    <div class="footer-inner">
        <div class="footer-grid">
            <div class="footer-brand">
                <img src="/images/levenhall-wordmark.png" alt="Levenhall" class="footer-logo">
                <p class="footer-description">Market intelligence consulting for defense, government, and dual-use markets. Intelligence, US federal market entry, ventures, and proprietary products &mdash; one firm, one method.</p>
            </div>
            <div class="footer-section">
                <h4>Company</h4>
                <a href="/about">About</a>
                <a href="/services">Practice</a>
                <a href="/team">Team</a>
                <a href="/partners">Partners</a>
                <a href="/ventures">Ventures</a>
            </div>
            <div class="footer-section">
                <h4>Products</h4>
                <a href="/products/bridger">Bridger</a>
                <a href="/products/aigis">AIGIS</a>
                <a href="/products/intelligence">Intelligence</a>
            </div>
            <div class="footer-section">
                <h4>Practice</h4>
                <a href="/services#market-intelligence">Market Intelligence</a>
                <a href="/services#advisory">Market Entry</a>
                <a href="/services#rapid-procurement">Rapid Procurement</a>
                <a href="/services#executive-placement">Executive Placement</a>
                <a href="/services#tax-services">Tax Advisory</a>
            </div>
            <div class="footer-section">
                <h4>Connect</h4>
                <a href="/contact">Contact</a>
                <a href="https://calendly.com/hgad-levenhall/30min" target="_blank" rel="noopener noreferrer">Schedule Consultation</a>
                <a href="https://www.linkedin.com/in/adamjpleslie/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
            </div>
        </div>
        <div class="footer-bottom">
            <p class="footer-route">LEVENHALL LLC / WASHINGTON DC / FVEY / {year}</p>
            <p class="footer-credentials">
                <span><span class="cred-label">UEI</span> Z4N8GQNVG826</span>
                <span class="cred-sep">·</span>
                <span><span class="cred-label">CAGE</span> 20CN1</span>
                <span class="cred-sep">·</span>
                <span>&copy; {year} Levenhall LLC. All rights reserved.</span>
            </p>
        </div>
    </div>
</footer>

<style>
    footer {
        background: var(--ink);
        color: var(--muted);
        padding: 0;
        position: relative;
    }

    .footer-accent {
        height: 1px;
        background: var(--hairline);
    }

    .footer-inner {
        max-width: 1200px;
        margin: 0 auto;
        padding: 3.5rem 2rem 0;
    }

    .footer-grid {
        display: grid;
        grid-template-columns: 2fr 1fr 0.8fr 1fr 1fr;
        gap: 2.5rem;
        padding-bottom: 2.5rem;
    }

    .footer-logo {
        height: 18px;
        width: auto;
        filter: brightness(0) invert(1);
        opacity: 0.7;
        margin-bottom: 1.2rem;
    }

    .footer-description {
        font-size: 0.88rem;
        line-height: 1.7;
        color: rgba(255, 255, 255, 0.4);
        max-width: 320px;
    }

    .footer-section h4 {
        font-family: var(--mono);
        font-weight: 500;
        font-size: 0.62rem;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--gold);
        margin-bottom: 1.2rem;
    }

    .footer-section a {
        display: block;
        font-size: 0.88rem;
        color: var(--muted);
        text-decoration: none;
        margin-bottom: 0.6rem;
        transition: color 0.25s ease;
    }

    .footer-section a:hover {
        color: var(--bone);
    }

    .footer-bottom {
        border-top: 1px solid var(--hairline-soft);
        padding: 1.8rem 0;
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .footer-bottom p {
        margin: 0;
    }

    .footer-route {
        font-family: var(--mono);
        font-size: 0.62rem;
        letter-spacing: 0.2em;
        color: var(--dim);
    }

    .footer-credentials {
        font-family: var(--mono);
        font-size: 0.64rem;
        letter-spacing: 0.06em;
        color: var(--dim) !important;
    }

    .footer-credentials .cred-label {
        color: var(--gold);
        font-weight: 500;
        letter-spacing: 0.14em;
        margin-right: 0.3rem;
    }

    .footer-credentials .cred-sep {
        margin: 0 0.6rem;
        opacity: 0.5;
    }

    @media (max-width: 768px) {
        .footer-grid {
            grid-template-columns: 1fr 1fr;
            gap: 2rem;
        }
        .footer-brand {
            grid-column: 1 / -1;
        }
    }

    @media (max-width: 480px) {
        .footer-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
